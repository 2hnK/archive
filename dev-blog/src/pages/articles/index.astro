---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryCount: Record<string, number> = {};
sortedArticles.forEach(a => {
  const cat = a.data.category;
  categoryCount[cat] = (categoryCount[cat] || 0) + 1;
});
const categories = Object.keys(categoryCount);
---

<BaseLayout title="Articles | DevArchive" description="모든 아티클 및 저널 목록입니다.">
  <main class="pt-32 pb-20 max-w-7xl mx-auto px-6 min-h-[70vh] flex flex-col lg:flex-row gap-12 relative">
    
    <div class="flex-grow w-full max-w-4xl">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-6 gap-6">
        <div>
          <h1 class="text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">아티클 보관소</h1>
          <p class="text-zinc-500 dark:text-zinc-400 max-w-2xl text-lg break-keep">시스템 설계, 기술 리더십, 그리고 미니멀 프로그래밍에 대한 치열한 탐구.</p>
        </div>
        
        <!-- Apple-style Rounded Toggle -->
        <div class="hidden sm:flex items-center">
          <div class="relative bg-zinc-200/60 dark:bg-zinc-800 p-[3px] rounded-full flex items-center w-[72px] h-[34px] cursor-pointer select-none" id="view-toggle" role="switch" aria-label="뷰 전환">
            <div id="toggle-thumb" class="absolute w-[28px] h-[28px] bg-white dark:bg-zinc-600 rounded-full shadow-md transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] left-[3px] flex items-center justify-center">
              <span id="toggle-icon" class="material-symbols-outlined text-[14px] text-zinc-700 dark:text-zinc-200 leading-none">grid_view</span>
            </div>
          </div>
        </div>
      </div>

      <div id="article-container" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16 transition-all duration-500 ease-in-out">
        {sortedArticles.map(article => (
          <div class="article-item transition-all duration-500 ease-in-out" data-category={article.data.category}>
            <ArticleCard 
              title={article.data.title}
              description={article.data.description}
              category={article.data.category}
              date={article.data.date.toLocaleDateString('ko-KR')}
              href={`/articles/${article.id}`}
              imageUrl={article.data.imageUrl}
            />
          </div>
        ))}
      </div>
    </div>

    <!-- 사이드바 -->
    <aside class="w-full lg:w-48 flex-shrink-0 lg:sticky lg:top-32 self-start hidden lg:block">
      <div class="py-2">
        <h3 class="text-[0.65rem] font-bold tracking-[0.2em] uppercase text-zinc-400 dark:text-zinc-500 mb-6 px-3">카테고리</h3>
        <ul class="flex flex-col gap-1.5">
          <li>
            <button data-filter="all" class="cat-filter active-cat group w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm text-zinc-900 dark:text-zinc-100 font-bold bg-zinc-100/50 dark:bg-zinc-800/50 transition-all border border-zinc-200/50 dark:border-zinc-700/50 cursor-pointer text-left">
              <span class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-zinc-900 dark:bg-zinc-100"></span>
                전체보기
              </span>
              <span class="text-[10px] text-zinc-500 dark:text-zinc-400 font-mono tracking-widest">{sortedArticles.length}</span>
            </button>
          </li>
          {categories.map(cat => (
            <li>
              <button data-filter={cat} class="cat-filter group w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-50 dark:hover:bg-zinc-900/40 transition-all cursor-pointer text-left">
                <span class="flex items-center gap-2 relative">
                  <span class="absolute -left-3 w-1 h-1 rounded-full bg-zinc-300 dark:bg-zinc-600 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                  <span class="font-medium">{cat}</span>
                </span>
                <span class="text-[10px] text-zinc-300 dark:text-zinc-600 font-mono tracking-widest group-hover:text-zinc-400 transition-colors">{categoryCount[cat]}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </main>

  <script>
    document.addEventListener('astro:page-load', () => {
      const toggle = document.getElementById('view-toggle');
      const thumb = document.getElementById('toggle-thumb');
      const icon = document.getElementById('toggle-icon');
      const container = document.getElementById('article-container');
      const items = document.querySelectorAll('.article-item');
      const catBtns = document.querySelectorAll('.cat-filter');
      
      if(!toggle || !thumb || !icon || !container) return;
      
      let isGrid = (localStorage.getItem('article-view') || 'grid') === 'grid';

      const applyView = () => {
        if (isGrid) {
          thumb.style.left = '3px';
          icon.textContent = 'grid_view';
          container.classList.remove('flex', 'flex-col', 'gap-6');
          container.classList.add('grid', 'grid-cols-1', 'md:grid-cols-2', 'gap-x-8', 'gap-y-16');
          items.forEach(item => {
            const article = item.querySelector('article');
            const imgWrap = item.querySelector('article > a');
            if(article && imgWrap) {
              article.classList.remove('md:flex-row', 'items-center', 'gap-8');
              imgWrap.classList.remove('md:w-64', 'md:h-40', 'md:mb-0', 'shrink-0');
              imgWrap.classList.add('w-full', 'aspect-[16/10]', 'mb-6');
            }
          });
        } else {
          thumb.style.left = '41px';
          icon.textContent = 'view_list';
          container.classList.remove('grid', 'grid-cols-1', 'md:grid-cols-2', 'gap-x-8', 'gap-y-16');
          container.classList.add('flex', 'flex-col', 'gap-6');
          items.forEach(item => {
            const article = item.querySelector('article');
            const imgWrap = item.querySelector('article > a');
            if(article && imgWrap) {
              article.classList.add('md:flex-row', 'items-center', 'gap-8');
              imgWrap.classList.add('md:w-64', 'md:h-40', 'md:mb-0', 'shrink-0');
              imgWrap.classList.remove('w-full', 'aspect-[16/10]', 'mb-6');
            }
          });
        }
        localStorage.setItem('article-view', isGrid ? 'grid' : 'list');
      };

      applyView();

      toggle.addEventListener('click', () => {
        isGrid = !isGrid;
        applyView();
      });

      // Category filtering
      catBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = (btn as HTMLElement).dataset.filter;
          catBtns.forEach(b => {
            b.classList.remove('active-cat', 'bg-zinc-100/50', 'dark:bg-zinc-800/50', 'text-zinc-900', 'dark:text-zinc-100', 'font-bold', 'border', 'border-zinc-200/50', 'dark:border-zinc-700/50');
            b.classList.add('text-zinc-500', 'dark:text-zinc-400');
          });
          btn.classList.add('active-cat', 'bg-zinc-100/50', 'dark:bg-zinc-800/50', 'text-zinc-900', 'dark:text-zinc-100', 'font-bold', 'border', 'border-zinc-200/50', 'dark:border-zinc-700/50');
          btn.classList.remove('text-zinc-500', 'dark:text-zinc-400');
          items.forEach(item => {
            const el = item as HTMLElement;
            if (filter === 'all' || el.dataset.category === filter) {
              el.style.display = '';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            } else {
              el.style.opacity = '0';
              el.style.transform = 'translateY(8px)';
              setTimeout(() => { el.style.display = 'none'; }, 300);
            }
          });
        });
      });
    });
  </script>
</BaseLayout>

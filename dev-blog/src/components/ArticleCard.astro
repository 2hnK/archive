---
// src/components/ArticleCard.astro
interface Props {
  category: string;
  date: string;
  title: string;
  description: string;
  imageUrl: string;
  href: string;
}

const { category, date, title, description, imageUrl, href } = Astro.props;
---
<article class="group flex flex-col h-full">
  <a href={href} class="block w-full aspect-[16/10] mb-6 overflow-hidden rounded-xl bg-zinc-100 dark:bg-zinc-800">
    <img alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={imageUrl} />
  </a>
  <div class="flex flex-col gap-3 flex-grow">
    <div class="flex items-center gap-3">
      <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-zinc-900 dark:text-zinc-100">{category}</span>
      <span class="w-1 h-1 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
      <time class="text-[10px] uppercase tracking-[0.2em] font-bold text-zinc-400 dark:text-zinc-500">{date}</time>
    </div>
    <h3 class="text-xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-500 dark:group-hover:text-zinc-400 transition-colors leading-tight">
      <a href={href}>{title}</a>
    </h3>
    <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed text-sm">
      {description}
    </p>
    <div class="mt-auto pt-4">
      <a class="text-xs font-bold border-b border-zinc-900 dark:border-zinc-100 text-zinc-900 dark:text-zinc-100 pb-0.5 hover:text-zinc-500 hover:border-zinc-500 transition-all" href={href}>Read Post</a>
    </div>
  </div>
</article>

---
// src/components/TimeProgress.astro
interface Props {
  mini?: boolean;
}

const { mini = false } = Astro.props;
---

<div
  class={`time-progress-container bg-white/50 dark:bg-white/5 backdrop-blur-md text-[#4c4f69] dark:text-[#cdd6f4] ${mini ? "py-4 px-3 sm:px-4 rounded-2xl" : "py-6 px-6 sm:px-8 rounded-3xl"} shadow-xl border border-black/5 dark:border-white/5 my-6 relative overflow-hidden`}
  style="margin-top: 0px"
>
  <div class={`text-center flex flex-col items-center ${mini ? "mb-4" : "mb-6"}`}>
    <p
      id="current-time-display"
      class={`${mini ? "text-[12px]" : "text-[16px] md:text-[18px]"} font-bold tracking-tight font-mono tabular-nums ${mini ? "mb-2" : "mb-3"}`}
    >
    </p>
    <div
      class={`${mini ? "text-[10px]" : "text-[14px] sm:text-[15px]"} text-[#5c5f77] dark:text-[#a6adc8] font-medium flex items-center justify-center gap-1.5`}
    >
      <span
        class={`flex items-center gap-1 ml-1 bg-black/[0.03] dark:bg-white/[0.05] ${mini ? "px-1.5 py-0" : "px-2 py-0.5"} rounded-full ring-1 ring-black/5 dark:ring-white/10`}
      >
      </span>
    </div>

    <div class={`mx-auto ${mini ? "space-y-2.5 w-full" : "space-y-4 max-w-xl"}`}>
      <!-- Year -->
      <div class="progress-item">
        <div class={`flex justify-between ${mini ? "mb-1" : "mb-2"}`}>
          <span
            class={`${mini ? "text-[11px]" : "text-[14px]"} font-bold tracking-wide text-[#40a02b] dark:text-[#a6e3a1] flex items-center gap-1.5`}
            ><span class={`material-symbols-outlined ${mini ? "text-[12px]" : "text-[16px]"}`}
              >eco</span
            >Year</span
          >
        </div>
        <div
          class={`h-[6px] w-full bg-black/5 dark:bg-black/40 rounded-full overflow-hidden shadow-inner`}
        >
          <div
            id="progress-year"
            class="h-full bg-gradient-to-r from-[#40a02b] to-[#a6e3a1] rounded-full transition-all duration-75 ease-linear w-0 relative"
          >
            <div
              class="absolute inset-0 bg-white/10 opacity-0 hover:opacity-100 transition-opacity"
            >
            </div>
          </div>
        </div>
        <div class="text-right mt-0.5">
          <span
            id="percent-year"
            class={`${mini ? "text-[9px]" : "text-[12px]"} text-[#5c5f77] dark:text-[#a6adc8] font-mono font-bold tracking-wider tabular-nums`}>0.0%</span
          >
        </div>
      </div>

      <!-- Month -->
      <div class="progress-item">
        <div class={`flex justify-between ${mini ? "mb-1" : "mb-2"}`}>
          <span
            class={`${mini ? "text-[11px]" : "text-[14px]"} font-bold tracking-wide text-[#179299] dark:text-[#94e2d5] flex items-center gap-1.5`}
            ><span class={`material-symbols-outlined ${mini ? "text-[12px]" : "text-[16px]"}`}
              >coffee_maker</span
            >Month</span
          >
        </div>
        <div
          class={`h-[6px] w-full bg-black/5 dark:bg-black/40 rounded-full overflow-hidden shadow-inner`}
        >
          <div
            id="progress-month"
            class="h-full bg-gradient-to-r from-[#179299] to-[#94e2d5] rounded-full transition-all duration-75 ease-linear w-0 relative"
          >
            <div
              class="absolute inset-0 bg-white/10 opacity-0 hover:opacity-100 transition-opacity"
            >
            </div>
          </div>
        </div>
        <div class="text-right mt-0.5">
          <span
            id="percent-month"
            class={`${mini ? "text-[9px]" : "text-[12px]"} text-[#5c5f77] dark:text-[#a6adc8] font-mono font-bold tracking-wider tabular-nums`}>0.0%</span
          >
        </div>
      </div>

      <!-- Day -->
      <div class="progress-item">
        <div class={`flex justify-between ${mini ? "mb-1" : "mb-2"}`}>
          <span
            class={`${mini ? "text-[11px]" : "text-[14px]"} font-bold tracking-wide text-[#209fb5] dark:text-[#74c7ec] flex items-center gap-1.5`}
            ><span class={`material-symbols-outlined ${mini ? "text-[12px]" : "text-[16px]"}`}
              >local_cafe</span
            >Day</span
          >
        </div>
        <div
          class={`h-[6px] w-full bg-black/5 dark:bg-black/40 rounded-full overflow-hidden shadow-inner`}
        >
          <div
            id="progress-day"
            class="h-full bg-gradient-to-r from-[#209fb5] to-[#74c7ec] rounded-full transition-all duration-75 ease-linear w-0 relative"
          >
            <div
              class="absolute inset-0 bg-white/10 opacity-0 hover:opacity-100 transition-opacity"
            >
            </div>
          </div>
        </div>
        <div class="text-right mt-0.5">
          <span
            id="percent-day"
            class={`${mini ? "text-[9px]" : "text-[12px]"} text-[#5c5f77] dark:text-[#a6adc8] font-mono font-bold tracking-wider tabular-nums`}>0.0%</span
          >
        </div>
      </div>

      <!-- Hour -->
      <div class="progress-item">
        <div class={`flex justify-between ${mini ? "mb-1" : "mb-2"}`}>
          <span
            class={`${mini ? "text-[11px]" : "text-[14px]"} font-bold tracking-wide text-[#04a5e5] dark:text-[#89dceb] flex items-center gap-1.5`}
            ><span class={`material-symbols-outlined ${mini ? "text-[12px]" : "text-[16px]"}`}
              >keyboard</span
            >Hour</span
          >
        </div>
        <div
          class={`h-[6px] w-full bg-black/5 dark:bg-black/40 rounded-full overflow-hidden shadow-inner`}
        >
          <div
            id="progress-hour"
            class="h-full bg-gradient-to-r from-[#04a5e5] to-[#89dceb] rounded-full transition-all duration-75 ease-linear w-0 relative"
          >
            <div
              class="absolute inset-0 bg-white/10 opacity-0 hover:opacity-100 transition-opacity"
            >
            </div>
          </div>
        </div>
        <div class="text-right mt-0.5">
          <span
            id="percent-hour"
            class={`${mini ? "text-[9px]" : "text-[12px]"} text-[#5c5f77] dark:text-[#a6adc8] font-mono font-bold tracking-wider tabular-nums`}>0.0%</span
          >
        </div>
      </div>

      <!-- Minute -->
      <div class="progress-item">
        <div class={`flex justify-between ${mini ? "mb-1" : "mb-2"}`}>
          <span
            class={`${mini ? "text-[11px]" : "text-[14px]"} font-bold tracking-wide text-[#7287fd] dark:text-[#b4befe] flex items-center gap-1.5`}
            ><span class={`material-symbols-outlined ${mini ? "text-[12px]" : "text-[16px]"}`}
              >terminal</span
            >Minute</span
          >
        </div>
        <div
          class={`${mini ? "h-2" : "h-3.5"} w-full bg-black/5 dark:bg-black/40 rounded-full overflow-hidden shadow-inner relative`}
        >
          <div
            id="progress-minute"
            class="h-full bg-gradient-to-r from-[#7287fd] to-[#b4befe] rounded-full transition-all duration-75 ease-linear w-0 relative"
          >
            <div
              class="absolute inset-y-0 right-0 w-20 bg-gradient-to-r from-transparent to-white/30 rounded-full animate-pulse"
            >
            </div>
          </div>
        </div>
        <div class="text-right mt-0.5">
          <span
            id="percent-minute"
            class={`${mini ? "text-[9px]" : "text-[12px]"} text-[#5c5f77] dark:text-[#a6adc8] font-mono font-bold tracking-wider tabular-nums`}>0.0%</span
          >
        </div>
      </div>
    </div>
  </div>

  <script>
    function isLeapYear(year: number) {
      return (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;
    }

    function getDaysInMonth(year: number, month: number) {
      return new Date(year, month + 1, 0).getDate();
    }

    function getDaysInYear(year: number) {
      return isLeapYear(year) ? 366 : 365;
    }

    function formatNumber(num: number, pad: number = 2) {
      return num.toString().padStart(pad, "0");
    }

    const daysOfWeek = [
      "Sunday",
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
    ];

    function updateProgress() {
      const now = new Date();

      const year = now.getFullYear();
      const month = now.getMonth(); // 0-11
      const day = now.getDate(); // 1-31
      const hour = now.getHours(); // 0-23
      const minute = now.getMinutes(); // 0-59
      const second = now.getSeconds(); // 0-59
      const ms = now.getMilliseconds(); // 0-999

      // --- Update Date Text ---
      const dateStr = `${year}/${formatNumber(month + 1)}/${formatNumber(day)} ${formatNumber(hour)}:${formatNumber(minute)}:${formatNumber(second)}`;
      const dayStr = `(${daysOfWeek[now.getDay()]})`;

      const displayEl = document.getElementById("current-time-display");
      if (displayEl) {
        displayEl.textContent = `${dateStr}  ${dayStr}`;
      }

      // --- Calculate Percentages ---

      // 1. Minute Progress (0 to 60 seconds)
      const currentMsInMinute = second * 1000 + ms;
      const totalMsInMinute = 60 * 1000;
      const pctMinute = (currentMsInMinute / totalMsInMinute) * 100;

      // 2. Hour Progress (0 to 60 minutes)
      const currentMsInHour = minute * totalMsInMinute + currentMsInMinute;
      const totalMsInHour = 60 * totalMsInMinute;
      const pctHour = (currentMsInHour / totalMsInHour) * 100;

      // 3. Day Progress (0 to 24 hours)
      const currentMsInDay = hour * totalMsInHour + currentMsInHour;
      const totalMsInDay = 24 * totalMsInHour;
      const pctDay = (currentMsInDay / totalMsInDay) * 100;

      // 4. Month Progress
      const daysInMonth = getDaysInMonth(year, month);
      const msInMonth = daysInMonth * totalMsInDay;
      const currentMsInMonth = (day - 1) * totalMsInDay + currentMsInDay;
      const pctMonth = (currentMsInMonth / msInMonth) * 100;

      // 5. Year Progress
      const startOfYearMs = new Date(year, 0, 1).getTime();
      const endOfYearMs = new Date(year + 1, 0, 1).getTime();
      const msInYear = endOfYearMs - startOfYearMs;
      const currentMsOutYear = now.getTime() - startOfYearMs;
      const pctYear = (currentMsOutYear / msInYear) * 100;

      // --- Update DOM Elements ---
      const updateElement = (id: string, pct: number) => {
        const bar = document.getElementById(`progress-${id}`);
        const text = document.getElementById(`percent-${id}`);
        if (bar && text) {
          bar.style.width = `${pct}%`;
          text.textContent = `${pct.toFixed(1)}%`;
        }
      };

      updateElement("year", pctYear);
      updateElement("month", pctMonth);
      updateElement("day", pctDay);
      updateElement("hour", pctHour);
      updateElement("minute", pctMinute);

      requestAnimationFrame(updateProgress);
    }

    // Initialize loop when Astro loads or view transitions
    document.addEventListener("astro:page-load", () => {
      // start loop only if current-time-display exists
      if (document.getElementById("current-time-display")) {
        requestAnimationFrame(updateProgress);
      }
    });

    // Since Astro component scripts might run once on first load:
    if (document.getElementById("current-time-display")) {
      requestAnimationFrame(updateProgress);
    }
  </script>
</div>

---
import { getCollection } from "astro:content";

export interface Props {
  currentCat?: string;
  currentSub?: string;
}

const { currentCat, currentSub } = Astro.props;

const allArticles = await getCollection("articles");
const categoryTree: Record<string, string[]> = {};
const catCounts: Record<string, number> = {};
const subCounts: Record<string, Record<string, number>> = {};

allArticles.forEach((a) => {
  const cat = a.data.category;
  const sub = a.data.subcategory;
  if (!cat) return;
  if (!categoryTree[cat]) {
    categoryTree[cat] = [];
    catCounts[cat] = 0;
    subCounts[cat] = {};
  }
  catCounts[cat]++;
  if (sub) {
    if (!categoryTree[cat].includes(sub)) categoryTree[cat].push(sub);
    subCounts[cat][sub] = (subCounts[cat][sub] || 0) + 1;
  }
});
const categories = Object.keys(categoryTree).sort();
const totalArticleCount = allArticles.length;

const getLink = (cat?: string, sub?: string) => {
  if (sub) return `/articles?cat=${encodeURIComponent(cat!)}&sub=${encodeURIComponent(sub)}`;
  if (cat) return `/articles?cat=${encodeURIComponent(cat)}`;
  return `/articles`;
};

const BTN_INACTIVE =
  "outline-none focus:outline-none border-none ring-0 appearance-none bg-transparent text-text-color opacity-40 hover:opacity-100 transition-opacity duration-300 font-sans font-medium group/btn";
const BTN_ACTIVE =
  "active-item outline-none focus:outline-none border-none ring-0 appearance-none bg-transparent text-[#1e66f5] dark:text-[#89b4fa] opacity-100 font-bold transition-colors duration-300 group/btn font-sans";

const getClasses = (isActive: boolean) => (isActive ? BTN_ACTIVE : BTN_INACTIVE);
---

<div class="w-full h-auto flex flex-col pl-4 reveal-up stagger-1" style="padding-right: 8px;">
  <h2
    class="text-[12px] font-bold tracking-[0.15em] uppercase text-text-color opacity-60 mb-8 text-right pr-2"
    style="margin-bottom: 16px;"
  >
    TOPICS
  </h2>
  <div class="relative flex flex-col gap-1 pb-2 pr-[2px]" id="cat-list-container">
    <div class="absolute right-0 top-3 bottom-0 w-[1px] bg-border-color/20 pointer-events-none z-0">
    </div>

    <div
      id="grid-highlight"
      class="absolute -right-[3.5px] w-[calc(100%-12px)] rounded-[1.2rem] custom-glass-highlight z-20 pointer-events-none opacity-0 flex items-center justify-end pr-0 transition-all duration-400 ease-[cubic-bezier(0.25,1,0.5,1)]"
    >
    </div>

    <a
      href="/articles"
      data-filter="all"
      class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-2.5 cursor-pointer ${getClasses(!currentCat)}`}
    >
      <span class="text-[13px] text-right flex items-center gap-1.5 leading-none"
        >All <span class="text-[10px] font-bold opacity-60">{totalArticleCount}</span></span
      >
      <span
        class="inactive-dot absolute right-[-3.5px] top-1/2 -translate-y-1/2 w-[8px] h-[8px] rounded-full bg-black/20 dark:bg-white/20 transition-all duration-300 group-hover/btn:bg-black/40 dark:group-hover/btn:bg-white/40 z-10"
      ></span>
    </a>

    {
      categories.map((cat) => {
        const isCatActive = cat === currentCat;
        return (
          <div class="category-group group/cat flex flex-col gap-1 w-full" data-group-cat={cat}>
            <a
              href={getLink(cat)}
              data-filter-cat={cat}
              class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-2.5 cursor-pointer ${getClasses(isCatActive && !currentSub)}`}
            >
              <span class="text-[13px] text-right flex items-center gap-1.5 leading-none">
                {cat} <span class="text-[10px] font-bold opacity-60">{catCounts[cat]}</span>
              </span>
              <span class="inactive-dot absolute right-[-3.5px] top-1/2 -translate-y-1/2 w-[8px] h-[8px] rounded-full bg-black/20 dark:bg-white/20 transition-all duration-300 group-hover/btn:bg-black/40 dark:group-hover/btn:bg-white/40 z-10" />
            </a>
            {categoryTree[cat].length > 0 && (
              <div
                class={`sub-list flex-col gap-1 ${isCatActive ? "flex" : "hidden"} group-hover/cat:flex`}
              >
                {categoryTree[cat].map((sub) => {
                  const isSubActive = cat === currentCat && sub === currentSub;
                  return (
                    <a
                      href={getLink(cat, sub)}
                      data-filter-cat={cat}
                      data-filter-sub={sub}
                      class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-1.5 cursor-pointer pl-6 ${getClasses(isSubActive)}`}
                    >
                      <span class="text-[11px] text-right opacity-80 flex items-center gap-1.5 leading-none">
                        {sub}{" "}
                        <span class="text-[9px] font-bold opacity-60">{subCounts[cat][sub]}</span>
                      </span>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        );
      })
    }
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const containerId = "cat-list-container";
    const highlightId = "grid-highlight";
    const itemSelector = ".cat-filter";

    const container = document.getElementById(containerId);
    const highlight = document.getElementById(highlightId);
    if (!container || !highlight) return;

    let activeItem =
      (container.querySelector(`${itemSelector}.active-item`) as HTMLElement | null) ||
      (container.querySelector(itemSelector) as HTMLElement | null);

    const removeActiveText = (el: HTMLElement) => {
      el.classList.remove("text-[#1e66f5]", "dark:text-[#89b4fa]", "opacity-100", "font-bold");
      el.classList.add("text-text-color", "opacity-40", "font-medium");
    };
    const addActiveText = (el: HTMLElement) => {
      el.classList.remove("text-text-color", "opacity-40", "font-medium");
      el.classList.add("text-[#1e66f5]", "dark:text-[#89b4fa]", "opacity-100", "font-bold");
    };

    const targetHeight = 32; // Fixed height

    const move = (el: HTMLElement) => {
      // Calculate centering for fixed height
      const topOffset = el.offsetTop + (el.offsetHeight - targetHeight) / 2;
      highlight.style.height = `${targetHeight}px`;
      highlight.style.transform = `translateY(${topOffset}px)`;
      highlight.style.opacity = "1";

      container
        .querySelectorAll(itemSelector)
        .forEach((btn) => removeActiveText(btn as HTMLElement));
      addActiveText(el);
    };

    if (activeItem) move(activeItem);

    const items = container.querySelectorAll(itemSelector);
    items.forEach((item) => {
      item.addEventListener("mouseenter", () => move(item as HTMLElement));
      item.addEventListener("click", () => {
        activeItem = item as HTMLElement;
        move(item as HTMLElement);
      });
    });

    container.addEventListener("mouseleave", () => {
      if (activeItem) {
        move(activeItem);
      } else {
        highlight.style.opacity = "0";
      }
    });

    window.addEventListener("resize", () => {
      if (activeItem && container.offsetParent !== null) move(activeItem);
    });

    document.addEventListener("update-sliders", () => {
      if (activeItem && container.offsetParent !== null) move(activeItem);
    });
  });
</script>

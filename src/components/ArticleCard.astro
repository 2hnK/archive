---
// src/components/ArticleCard.astro
interface Props {
  category: string;
  date: string;
  title: string;
  description: string;
  imageUrl: string;
  href: string;
}

const { category, date, title, description, imageUrl, href } = Astro.props;
---
<article class="group flex flex-col h-full w-full">
  <a href={href} class="img-wrap block w-full aspect-video md:aspect-[4/3] mb-5 overflow-hidden rounded-[1.5rem] bg-black/5 dark:bg-white/5 ring-1 ring-black/5 dark:ring-white/10 shadow-[0_4px_24px_rgba(0,0,0,0.04)] dark:shadow-[0_4px_24px_rgba(0,0,0,0.2)]">
    <img alt={title} class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]" src={imageUrl} loading="lazy" />
  </a>
  <div class="content-wrap flex flex-col gap-2.5 flex-grow px-1">
    <div class="flex items-center gap-2 mb-1">
      <span class="text-[11px] uppercase tracking-widest font-bold text-apple-textMuted dark:text-apple-darkTextMuted">{category}</span>
      <span class="w-1 h-1 rounded-full bg-apple-border dark:bg-apple-darkBorder"></span>
      <time class="text-[11px] uppercase tracking-[0.1em] font-bold text-apple-textMuted dark:text-apple-darkTextMuted opacity-70">{date}</time>
    </div>
    <h3 class="text-[22px] md:text-[24px] font-bold tracking-tight text-apple-text dark:text-apple-darkText group-hover:opacity-70 transition-opacity leading-[1.3] break-keep">
      <a href={href} class="before:absolute before:inset-0 block relative">
        {title}
      </a>
    </h3>
    <p class="text-[15px] font-medium text-apple-textMuted dark:text-apple-darkTextMuted leading-[1.6] line-clamp-2 md:line-clamp-3">
      {description}
    </p>
  </div>
</article>

---
// src/components/ArticleCard.astro
interface Props {
  category: string;
  date: string;
  title: string;
  description: string;
  imageUrl?: string;
  href: string;
}

const { category, date, title, description, imageUrl, href } = Astro.props;
---
<article class="group flex flex-col h-full w-full">
  {imageUrl ? (
    <a href={href} class="img-wrap block w-full aspect-video md:aspect-[4/3] mb-5 overflow-hidden glass-panel">
      <img alt={title} class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]" src={imageUrl} loading="lazy" />
    </a>
  ) : (
    <a href={href} class="img-wrap flex items-center justify-center w-full aspect-video md:aspect-[4/3] mb-5 overflow-hidden glass-panel transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.02] relative">
      <span class="absolute inset-0 flex items-center justify-center text-[80px] md:text-[120px] font-black text-black/[0.03] dark:text-white/[0.02] tracking-tighter select-none leading-none opacity-50 overflow-hidden transform -rotate-12 scale-150">
        {category}
      </span>
      <div class="relative z-10 flex flex-col items-center gap-2">
        <span class="material-symbols-outlined text-[40px] text-black/10 dark:text-white/10">article</span>
      </div>
    </a>
  )}
  <div class="content-wrap flex flex-col gap-2.5 flex-grow px-1 mt-1">
    <div class="flex items-center gap-2 mb-1">
      <span class="text-[12px] uppercase tracking-widest font-bold text-accent-color">{category}</span>
      <span class="w-[3px] h-[3px] rounded-full bg-border-color"></span>
      <time class="text-[11px] font-sans font-medium text-text-color opacity-60 tabular-nums">
        {date.replace(/\./g, "-").replace(/ /g, "").slice(0, -1)}
      </time>
    </div>
    <h3 class="text-2xl md:text-3xl font-serif font-bold tracking-tight text-text-color group-hover:text-accent-color transition-colors duration-300 leading-[1.3] break-keep">
      <a href={href} class="before:absolute before:inset-0 block relative">
        {title}
      </a>
    </h3>
    <p class="text-[15px] font-sans font-medium text-text-color opacity-70 leading-[1.65] line-clamp-2 mt-1">
      {description}
    </p>
  </div>
</article>

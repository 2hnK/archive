---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Format date
const formattedDate = entry.data.date.toLocaleDateString("ko-KR");

const allArticles = await getCollection("articles");
const categoryTree: Record<string, string[]> = {};
const catCounts: Record<string, number> = {};
const subCounts: Record<string, Record<string, number>> = {};
allArticles.forEach(a => {
  const cat = a.data.category;
  const sub = a.data.subcategory;
  if (!categoryTree[cat]) { categoryTree[cat] = []; catCounts[cat] = 0; subCounts[cat] = {}; }
  catCounts[cat]++;
  if (sub) {
    if (!categoryTree[cat].includes(sub)) categoryTree[cat].push(sub);
    subCounts[cat][sub] = (subCounts[cat][sub] || 0) + 1;
  }
});
const categories = Object.keys(categoryTree).sort();
const totalArticleCount = allArticles.length;
const currentCat = entry.data.category;
const currentSub = entry.data.subcategory;
---

<BaseLayout title={`${entry.data.title} | DevArchive`} description={entry.data.description}>
  <main class="pt-32 pb-24 px-6 md:px-0">
    <div
      class="max-w-[1700px] mx-auto grid grid-cols-1 xl:grid-cols-[1fr_minmax(auto,900px)_1fr] gap-x-8 gap-y-16 relative"
    >
      <!-- 1. LEFT COLUMN: SIDEBAR -->
      <div class="hidden xl:block w-full lg:w-[260px] xl:w-[280px] xl:ml-auto mt-12 lg:mt-0">
        <aside class="w-full flex flex-col sticky top-32 h-fit max-h-[calc(100vh-8rem)] flex-shrink-0 z-20 overflow-y-auto hide-scrollbar transition-all duration-500">
          <div class="w-full h-auto flex flex-col pl-4 reveal-up stagger-1" style="padding-right: 16px;">
            <h2 class="text-[10px] font-bold tracking-[0.15em] uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-8 text-right pr-2">TOPICS</h2>
            <div class="relative flex flex-col gap-1 pb-2 pr-[2px]" id="cat-list-container">
              <div class="absolute right-0 top-3 bottom-0 w-[1px] bg-black/10 dark:bg-white/10 pointer-events-none z-0"></div>
              
              <div
                id="grid-highlight"
                class="absolute -right-[3.5px] w-[calc(100%-12px)] rounded-[1.2rem] custom-glass-highlight border border-white/20 dark:border-white/10 shadow-sm transition-all duration-400 ease-[cubic-bezier(0.25,1,0.5,1)] z-20 pointer-events-none opacity-0 flex items-center justify-end pr-0"
              >
                <!-- The active blue dot sits on the line inside the pill, sliding OVER the gray dots -->
                <div class="w-[8px] h-[8px] rounded-full bg-blue-600 dark:bg-blue-400 flex-shrink-0 shadow-[0_0_8px_rgba(59,130,246,0.6)]"></div>
              </div>

              <a href="/articles" class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-2.5 cursor-pointer transition-colors duration-300 group ${!currentCat ? 'active-item text-blue-600 dark:text-blue-400 font-bold' : 'text-apple-textMuted dark:text-apple-darkTextMuted font-medium'}`}>
                <span class="text-[13px] text-right flex items-center gap-1.5 leading-none">All <span class="text-[10px] font-bold opacity-60">{totalArticleCount}</span></span>
                <span class="inactive-dot absolute right-[-3.5px] top-1/2 -translate-y-1/2 w-[8px] h-[8px] rounded-full bg-black/20 dark:bg-white/20 group-hover:bg-black/40 dark:group-hover:bg-white/40 transition-all duration-300 z-10"></span>
              </a>
              
              {categories.map(cat => (
                <div class="flex flex-col gap-1 w-full category-group" data-group-cat={cat}>
                  <a href={`/articles`} class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-2.5 cursor-pointer transition-colors duration-300 group ${cat === currentCat && !currentSub ? 'active-item text-blue-600 dark:text-blue-400 font-bold' : 'text-apple-textMuted dark:text-apple-darkTextMuted font-medium'}`}>
                    <span class="text-[13px] text-right flex items-center gap-1.5 leading-none">{cat} <span class="text-[10px] font-bold opacity-60">{catCounts[cat]}</span></span>
                    <span class="inactive-dot absolute right-[-3.5px] top-1/2 -translate-y-1/2 w-[8px] h-[8px] rounded-full bg-black/20 dark:bg-white/20 group-hover:bg-black/40 dark:group-hover:bg-white/40 transition-all duration-300 z-10"></span>
                  </a>
                  {categoryTree[cat].length > 0 && (
                    <div class={`sub-list flex flex-col gap-1 ${cat !== currentCat ? 'hidden' : ''}`}>
                      {categoryTree[cat].map(sub => (
                        <a href={`/articles`} class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-1.5 cursor-pointer pl-6 transition-colors duration-300 group ${sub === currentSub ? 'active-item text-blue-600 dark:text-blue-400 font-bold' : 'text-apple-textMuted dark:text-apple-darkTextMuted font-medium'}`}>
                          <span class="text-[11px] text-right opacity-80 flex items-center gap-1.5 leading-none">{sub} <span class="text-[9px] font-bold opacity-60">{subCounts[cat][sub]}</span></span>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </aside>
      </div>

      <!-- 2. Main Article Content (Centered inside a Card) -->
      <article class="w-full max-w-[900px] mx-auto min-w-0 bg-white/70 dark:bg-[#1a1b26]/50 backdrop-blur-xl rounded-[2.5rem] p-8 md:p-14 border border-black/5 dark:border-white/5 shadow-[0_8px_48px_rgba(0,0,0,0.04)] reveal-up transition-all duration-500">
        <!-- Metadata -->
        <div class="mb-10 flex flex-col gap-6">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <a href="/articles" class="flex items-center justify-center w-8 h-8 rounded-full bg-black/5 dark:bg-white/10 hover:bg-black/10 dark:hover:bg-white/20 transition-colors text-apple-text dark:text-apple-darkText" title="목록으로 돌아가기">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
              </a>
              <nav class="flex items-center gap-2 text-[11px] uppercase tracking-[0.08em] font-medium text-apple-textMuted dark:text-apple-darkTextMuted">
                <a class="hover:text-apple-text dark:hover:text-apple-darkText transition-colors font-bold" href="/articles">아티클</a>
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                <span class="text-apple-text dark:text-apple-darkText font-bold">{entry.data.category}</span>
              </nav>
            </div>
          </div>

          <h1
            class="text-3xl md:text-4xl leading-[1.2] font-bold tracking-tight text-apple-text dark:text-apple-darkText mb-6 break-keep"
          >
            {entry.data.title}
          </h1>

          <div
            class="flex items-center gap-4 text-apple-textMuted dark:text-apple-darkTextMuted text-sm font-medium"
          >
            <div class="flex items-center gap-2">
              <span class="font-semibold text-apple-text dark:text-apple-darkText">DevArchive</span>
            </div>
            <span class="w-1 h-1 rounded-full bg-apple-border dark:bg-apple-darkBorder"></span>
            <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
            <span class="w-1 h-1 rounded-full bg-apple-border dark:bg-apple-darkBorder"></span>
            <span class="uppercase tracking-widest text-[#9e3f4e] dark:text-[#ff8b9a] font-bold"
              >{entry.data.category}</span
            >
          </div>
        </div>

        <!-- Hero Image -->
        {
          entry.data.imageUrl && (
            <div class="mb-12 rounded-2xl overflow-hidden shadow-sm reveal-up stagger-1">
              <img
                class="w-full h-auto aspect-video object-cover"
                alt={entry.data.title}
                src={entry.data.imageUrl}
              />
            </div>
          )
        }

        <!-- Body Content -->
        <div
          class="prose max-w-none prose-zinc dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-apple-text dark:prose-a:text-apple-darkText text-[17px] leading-[1.7] tracking-tight"
        >
          <Content />
        </div>
      </article>

      <!-- 3. Right Sidebar (Apple Glassmorphic Side Bar) -->
      <div class="hidden xl:block w-full">
        <aside class="w-[260px] sticky top-32 self-start reveal-up stagger-2">
          <div class="flex flex-col pl-4 gap-2">
            <h3
              class="text-[11px] font-bold tracking-[0.2em] uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-2"
            >
              목차
            </h3>
            <div class="relative flex flex-col gap-0 pb-2" id="toc-container">
              <!-- Sliding Background Pill (No Dots) -->
              <div id="toc-highlight" class="absolute left-0 w-full rounded-[0.5rem] custom-glass-highlight border border-white/20 dark:border-white/10 shadow-sm transition-all duration-400 ease-[cubic-bezier(0.25,1,0.5,1)] z-20 pointer-events-none opacity-0"></div>
            
              {headings.length > 0 ? (
                headings
                  .filter((heading) => heading.depth <= 3)
                  .map((heading) => (
                    <a 
                      href={`#${heading.slug}`} 
                      class="toc-item relative z-10 w-full flex items-center py-[4.5px] pr-2 cursor-pointer text-apple-textMuted dark:text-apple-darkTextMuted font-medium transition-colors duration-300 hover:text-apple-text dark:hover:text-apple-darkText"
                      data-slug={heading.slug}
                    >
                      <span class="text-[12.5px] line-clamp-1" style={`padding-left: ${(heading.depth - 1) * 14 + 8}px`}>{heading.text}</span>
                    </a>
                  ))
              ) : (
                <div class="py-2 text-[12px] font-medium text-apple-textMuted dark:text-apple-darkTextMuted opacity-60">
                  목차가 없습니다.
                </div>
              )}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      // Intersection Observer Reveal
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px 500px 0px", threshold: 0.05 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));

      // TOPICS / TOC Sliding Highlight Logic
      const setupSlidingHighlight = (
        containerId: string,
        highlightId: string,
        itemSelector: string,
      ) => {
        const container = document.getElementById(containerId);
        const highlight = document.getElementById(highlightId);
        if (!container || !highlight) return;

        let activeItem =
          (container.querySelector(`${itemSelector}.active-item`) as HTMLElement | null) ||
          (container.querySelector(itemSelector) as HTMLElement | null);

        const removeBlueText = (el: HTMLElement) => {
          el.classList.remove("text-blue-600", "dark:text-blue-400", "font-bold");
          el.classList.add("text-apple-textMuted", "dark:text-apple-darkTextMuted", "font-medium");
        };
        const addBlueText = (el: HTMLElement) => {
          el.classList.remove(
            "text-apple-textMuted",
            "dark:text-apple-darkTextMuted",
            "font-medium"
          );
          el.classList.add("text-blue-600", "dark:text-blue-400", "font-bold");
        };

        const move = (el: HTMLElement) => {
          highlight.style.height = `${el.offsetHeight}px`;
          highlight.style.transform = `translateY(${el.offsetTop}px)`;
          highlight.style.opacity = "1";

          container
            .querySelectorAll(itemSelector)
            .forEach((btn) => removeBlueText(btn as HTMLElement));
          addBlueText(el);
        };

        if (activeItem) move(activeItem);

        const items = container.querySelectorAll(itemSelector);
        items.forEach((item) => {
          item.addEventListener("mouseenter", () => move(item as HTMLElement));
        });

        container.addEventListener("mouseleave", () => {
          if (activeItem) {
            move(activeItem);
          } else {
            highlight.style.opacity = "0";
          }
        });

        window.addEventListener("resize", () => {
          if (activeItem && container.offsetParent !== null) move(activeItem);
        });
      };

      // INIT TOPICS HIGHLIGHT
      setupSlidingHighlight("cat-list-container", "grid-highlight", ".cat-filter");

      // TOC Sliding Highlight & ScrollSpy
      const tocContainer = document.getElementById('toc-container');
      const tocHighlight = document.getElementById('toc-highlight');
      const tocItems = document.querySelectorAll('.toc-item');

      if (tocContainer && tocHighlight && tocItems.length > 0) {
        let activeTocItem: Element | null = null;

        const moveToc = (el: HTMLElement) => {
          tocHighlight.style.height = `${el.offsetHeight}px`;
          tocHighlight.style.transform = `translateY(${el.offsetTop}px)`;
          tocHighlight.style.opacity = '1';

          tocItems.forEach(item => {
            item.classList.remove('text-blue-600', 'dark:text-blue-400', 'font-bold');
            item.classList.add('text-apple-textMuted', 'dark:text-apple-darkTextMuted', 'font-medium');
          });

          el.classList.remove('text-apple-textMuted', 'dark:text-apple-darkTextMuted', 'font-medium');
          el.classList.add('text-blue-600', 'dark:text-blue-400', 'font-bold');
        };

        // Click & Scrolling Highlights
        tocItems.forEach(item => {
          item.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = item.getAttribute('href')?.slice(1);
            if (!targetId) return;
            
            const targetEl = document.getElementById(targetId);
            if (targetEl) {
              const headerOffset = 100;
              const elementPosition = targetEl.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });
            }

            activeTocItem = item;
            moveToc(item as HTMLElement);
          });
        });

        // ScrollSpy
        const headings = Array.from(document.querySelectorAll('.prose h1, .prose h2, .prose h3'));
        let headingOffsets: { id: string, offsetTop: number }[] = [];

        // Calculate offsets on load and resize
        const calculateOffsets = () => {
          headingOffsets = headings.map(h => ({
            id: h.id,
            offsetTop: (h as HTMLElement).offsetTop
          }));
        };

        calculateOffsets();
        window.addEventListener('resize', calculateOffsets);

        const onScroll = () => {
          const scrollPos = window.scrollY + 120; // fixed header offset margin
          let currentId: string | null = null;

          for (let i = headingOffsets.length - 1; i >= 0; i--) {
            if (scrollPos >= headingOffsets[i].offsetTop) {
              currentId = headingOffsets[i].id;
              break;
            }
          }

          if (currentId) {
            const activeEl = document.querySelector(`.toc-item[data-slug="${currentId}"]`);
            if (activeEl && activeEl !== activeTocItem) {
              activeTocItem = activeEl;
              moveToc(activeEl as HTMLElement);
            }
          } else {
            // If we are above any heading (at the top), highlight the first one
            const firstEl = tocItems[0];
            if (firstEl && firstEl !== activeTocItem) {
              activeTocItem = firstEl;
              moveToc(firstEl as HTMLElement);
            }
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        // Trigger once to set initial state
        setTimeout(onScroll, 100);
      }

      // Code block copy buttons
      const preTags = document.querySelectorAll(".prose pre");
      preTags.forEach((pre) => {
        if (pre.parentElement?.classList.contains("code-block-wrapper")) return;
        const wrapper = document.createElement("div");
        wrapper.className = "code-block-wrapper relative mt-6 mb-6";
        pre.parentElement?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
        const copyBtn = document.createElement("button");
        copyBtn.className =
          "copy-btn absolute top-2 right-2 px-3 py-1 bg-white/10 hover:bg-white/20 text-white/50 hover:text-white text-[11px] font-mono rounded backdrop-blur-md transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10";
        copyBtn.textContent = "Copy";
        wrapper.classList.add("group");
        copyBtn.addEventListener("click", async () => {
          const codeText = pre.textContent || "";
          await navigator.clipboard.writeText(codeText);
          copyBtn.textContent = "Copied!";
          setTimeout(() => (copyBtn.textContent = "Copy"), 2000);
        });
        wrapper.appendChild(copyBtn);
      });
    });
  </script>
</BaseLayout>

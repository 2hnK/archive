---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TopicsSidebar from "../../components/TopicsSidebar.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Format date
const formattedDate = entry.data.date.toLocaleDateString("ko-KR");

const currentCat = entry.data.category;
const currentSub = entry.data.subcategory;
---

<BaseLayout title={`${entry.data.title} | DevArchive`} description={entry.data.description}>
  <main class="pt-32 pb-24">
    <!-- Top Bar: Title & Metadata (Moved outside grid to align sidebars with card) -->
    <div class="max-w-[900px] mx-auto w-full px-4 sm:px-6 md:px-8 mb-10 border-b border-apple-border dark:border-apple-darkBorder pb-6">
      <div class="flex items-center gap-2 mb-2">
        <a href="/articles" class="flex items-center justify-center w-6 h-6 rounded-full bg-black/5 dark:bg-white/10 hover:bg-black/10 dark:hover:bg-white/20 transition-colors text-apple-text dark:text-apple-darkText" title="목록으로 돌아가기">
          <span class="material-symbols-outlined text-[14px]">arrow_back</span>
        </a>
        <span class="text-[10px] uppercase tracking-[0.25em] font-bold text-apple-textMuted dark:text-apple-darkTextMuted">
          ARTICLES
        </span>
      </div>
      
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 w-full">
        <h1 class="text-2xl font-bold tracking-tight text-apple-text dark:text-apple-darkText break-keep leading-[1.3]">
          {entry.data.title}
        </h1>
        
        <div class="flex items-center justify-end gap-2 text-apple-textMuted dark:text-apple-darkTextMuted text-[12px] font-medium shrink-0 mb-1 lg:mb-0">
          <span class="font-semibold text-apple-text dark:text-apple-darkText">DevArchive</span>
          <span class="w-[3px] h-[3px] rounded-full bg-apple-border dark:bg-apple-darkBorder"></span>
          <time datetime={entry.data.date.toISOString()} class="tabular-nums">
            {entry.data.date
              .toLocaleDateString("ko-KR", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              })
              .replace(/\./g, "-")
              .replace(/ /g, "")
              .slice(0, -1)}
          </time>
          <span class="w-[3px] h-[3px] rounded-full bg-apple-border dark:bg-apple-darkBorder"></span>
          <span class="uppercase tracking-[0.08em] font-bold text-[#1e66f5] dark:text-[#89b4fa]">
            {entry.data.category}
          </span>
        </div>
      </div>
    </div>

    <div class="mx-auto w-full max-w-[1700px] grid grid-cols-1 xl:grid-cols-[1fr_minmax(0,900px)_1fr] gap-x-8 gap-y-16 relative px-4 sm:px-6 md:px-8 xl:px-4">
      
      <!-- MOBILE BACK TO LIST (Hidden on XL) -->
      <div class="xl:hidden w-full flex items-center justify-between pb-2 border-b border-black/5 dark:border-white/5 -mt-6 mb-2">
        <div class="flex items-center gap-1.5 text-apple-textMuted dark:text-apple-darkTextMuted hover:text-black dark:hover:text-white transition-colors">
          <a href="/articles" class="flex items-center gap-1 text-[13px] font-bold">
            <span class="material-symbols-outlined text-[16px]">arrow_back</span>
            목록으로
          </a>
        </div>
      </div>

      <!-- 1. LEFT COLUMN: SIDEBAR -->
      <div class="hidden xl:block w-full min-w-0 xl:ml-auto lg:mt-0 relative">
        <aside class="w-full max-w-[280px] ml-auto flex flex-col sticky top-32 h-fit max-h-[calc(100vh-8rem)] flex-shrink-0 z-20 overflow-y-auto hide-scrollbar transition-all duration-500">
          <TopicsSidebar currentCat={currentCat} currentSub={currentSub} />
        </aside>
      </div>

      <!-- 2. Main Article Content (Centered inside a Card) -->
      <div class="w-full max-w-[900px] mx-auto min-w-0 transition-opacity duration-500 relative min-h-[70vh]">
        <article class="w-full bg-white/70 dark:bg-[#1a1b26]/50 backdrop-blur-xl rounded-[2.5rem] p-6 md:p-14 border border-black/5 dark:border-white/5 shadow-[0_8px_48px_rgba(0,0,0,0.04)] reveal-up transition-all duration-500">
        
        <!-- Hero Image -->
        {
          entry.data.imageUrl && (
            <div class="mb-10 md:mb-12 rounded-2xl overflow-hidden shadow-sm reveal-up stagger-1">
              <img
                class="w-full h-auto aspect-video object-cover"
                alt={entry.data.title}
                src={entry.data.imageUrl}
              />
            </div>
          )
        }

        <!-- MOBILE TOC (Visible only below XL) -->
        <div class="block xl:hidden mb-12 bg-black/5 dark:bg-white/5 p-5 md:p-6 rounded-2xl reveal-up stagger-1">
          <h3 class="text-[12px] font-bold tracking-[0.2em] uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-4">
            목차
          </h3>
          <div class="flex flex-col gap-2 relative">
            {headings.length > 0 ? (
              headings
                .filter((heading) => heading.depth <= 3)
                .map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    class="toc-item-mobile text-apple-textMuted dark:text-apple-darkTextMuted font-medium hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300"
                    data-slug={heading.slug}
                  >
                    <span class="text-[14px]" style={`padding-left: ${(heading.depth - 1) * 12}px`}>{heading.text}</span>
                  </a>
                ))
            ) : (
              <div class="text-[13px] text-apple-textMuted dark:text-apple-darkTextMuted opacity-60">목차가 없습니다.</div>
            )}
          </div>
        </div>

        <!-- Body Content -->
        <div
          class="prose max-w-none prose-zinc dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-apple-text dark:prose-a:text-apple-darkText text-[17px] leading-[1.7] tracking-tight"
        >
          <Content />
        </div>
      </article>
      </div>

      <!-- 3. Right Sidebar (Apple Glassmorphic Side Bar) -->
      <div class="hidden xl:block w-full min-w-0 relative h-full">
        <aside class="w-full max-w-[280px] mr-auto sticky top-32 h-fit max-h-[calc(100vh-8rem)] overflow-y-auto hide-scrollbar reveal-up stagger-2">
          <div class="flex flex-col pl-4 gap-2">
            <h3
              class="text-[11px] font-bold tracking-[0.2em] uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-2"
            >
              목차
            </h3>
            <div class="relative flex flex-col gap-0 pb-2" id="toc-container">
              <!-- Sliding Background Pill (No Dots) -->
              <div id="toc-highlight" class="absolute left-0 w-full rounded-[1.2rem] custom-glass-highlight border border-white/20 dark:border-white/10 shadow-sm transition-all duration-400 ease-[cubic-bezier(0.25,1,0.5,1)] z-20 pointer-events-none opacity-0"></div>
            
              {headings.length > 0 ? (
                headings
                  .filter((heading) => heading.depth <= 3)
                  .map((heading) => (
                    <a
                      href={`#${heading.slug}`}
                      class="toc-item relative z-10 w-full flex items-center py-[4.5px] pr-2 cursor-pointer text-apple-textMuted dark:text-apple-darkTextMuted font-medium transition-colors duration-300"
                      data-slug={heading.slug}
                    >
                      <span class="text-[12.5px] line-clamp-1" style={`padding-left: ${(heading.depth - 1) * 14 + 8}px`}>{heading.text}</span>
                    </a>
                  ))
              ) : (
                <div class="py-2 text-[12px] font-medium text-apple-textMuted dark:text-apple-darkTextMuted opacity-60">
                  목차가 없습니다.
                </div>
              )}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <script>
    let slugRevealObserver;

    document.addEventListener("astro:page-load", () => {
      // Intersection Observer Reveal
      if (slugRevealObserver) slugRevealObserver.disconnect();
      slugRevealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px 500px 0px", threshold: 0.05 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => slugRevealObserver.observe(el));

      // TOC Sliding Highlight & ScrollSpy
      const tocContainer = document.getElementById('toc-container');
      const tocHighlight = document.getElementById('toc-highlight');
      const tocItems = document.querySelectorAll('.toc-item');

      if (tocContainer && tocHighlight && tocItems.length > 0) {
        let activeTocItem: Element | null = null;
        let isHovering = false;
        const targetTocHeight = 32; // Fixed height

        const moveToc = (el: HTMLElement) => {
          const topOffset = el.offsetTop + (el.offsetHeight - targetTocHeight) / 2;
          tocHighlight.style.height = `${targetTocHeight}px`;
          tocHighlight.style.transform = `translateY(${topOffset}px)`;
          tocHighlight.style.opacity = '1';

          tocItems.forEach(item => {
            item.classList.remove('text-blue-600', 'dark:text-blue-400', 'font-bold');
            item.classList.add('text-apple-textMuted', 'dark:text-apple-darkTextMuted', 'font-medium');
          });

          el.classList.remove('text-apple-textMuted', 'dark:text-apple-darkTextMuted', 'font-medium');
          el.classList.add('text-blue-600', 'dark:text-blue-400', 'font-bold');
        };

        // Hover Effect
        tocItems.forEach(item => {
          item.addEventListener('mouseenter', () => {
            isHovering = true;
            moveToc(item as HTMLElement);
          });
        });

        tocContainer.addEventListener('mouseleave', () => {
          isHovering = false;
          if (activeTocItem) {
            moveToc(activeTocItem as HTMLElement);
          } else {
            tocHighlight.style.opacity = '0';
          }
        });

        // Click & Scrolling Highlights
        tocItems.forEach(item => {
          item.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = item.getAttribute('href')?.slice(1);
            if (!targetId) return;
            
            const targetEl = document.getElementById(targetId);
            if (targetEl) {
              const headerOffset = 100;
              const elementPosition = targetEl.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });
            }

            activeTocItem = item;
            moveToc(item as HTMLElement);
          });
        });

        // ScrollSpy
        const headings = Array.from(document.querySelectorAll('.prose h1, .prose h2, .prose h3'));
        let headingOffsets: { id: string, offsetTop: number }[] = [];

        // Calculate offsets on load and resize
        const calculateOffsets = () => {
          headingOffsets = headings.map(h => ({
            id: h.id,
            offsetTop: (h as HTMLElement).offsetTop
          }));
        };

        calculateOffsets();
        window.addEventListener('resize', calculateOffsets);

        const onScroll = () => {
          const scrollPos = window.scrollY + 120; // fixed header offset margin
          let currentId: string | null = null;

          for (let i = headingOffsets.length - 1; i >= 0; i--) {
            if (scrollPos >= headingOffsets[i].offsetTop) {
              currentId = headingOffsets[i].id;
              break;
            }
          }

          if (currentId) {
            const activeEl = document.querySelector(`.toc-item[data-slug="${currentId}"]`);
            if (activeEl && activeEl !== activeTocItem) {
              activeTocItem = activeEl;
              if (!isHovering) moveToc(activeEl as HTMLElement);
            }
          } else {
            // If we are above any heading (at the top), highlight the first one
            const firstEl = tocItems[0];
            if (firstEl && firstEl !== activeTocItem) {
              activeTocItem = firstEl;
              if (!isHovering) moveToc(firstEl as HTMLElement);
            }
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        // Trigger once to set initial state
        setTimeout(onScroll, 100);
      }

      // Code block copy buttons
      const preTags = document.querySelectorAll(".prose pre");
      preTags.forEach((pre) => {
        if (pre.parentElement?.classList.contains("code-block-wrapper")) return;
        const wrapper = document.createElement("div");
        wrapper.className = "code-block-wrapper relative mt-6 mb-6";
        pre.parentElement?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
        const copyBtn = document.createElement("button");
        copyBtn.className =
          "copy-btn absolute top-2 right-2 px-3 py-1 bg-white/10 hover:bg-white/20 text-white/50 hover:text-white text-[11px] font-mono rounded backdrop-blur-md transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10";
        copyBtn.textContent = "Copy";
        wrapper.classList.add("group");
        copyBtn.addEventListener("click", async () => {
          const codeText = pre.textContent || "";
          await navigator.clipboard.writeText(codeText);
          copyBtn.textContent = "Copied!";
          setTimeout(() => (copyBtn.textContent = "Copy"), 2000);
        });
        wrapper.appendChild(copyBtn);
      });
    });
  </script>
</BaseLayout>

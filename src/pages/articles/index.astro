---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TopicsSidebar from "../../components/TopicsSidebar.astro";

const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryTree: Record<string, string[]> = {};
const catCounts: Record<string, number> = {};
const subCounts: Record<string, Record<string, number>> = {};
sortedArticles.forEach((a) => {
  const cat = a.data.category;
  const sub = a.data.subcategory;
  if (!categoryTree[cat]) {
    categoryTree[cat] = [];
    catCounts[cat] = 0;
    subCounts[cat] = {};
  }
  catCounts[cat]++;
  if (sub) {
    if (!categoryTree[cat].includes(sub)) categoryTree[cat].push(sub);
    subCounts[cat][sub] = (subCounts[cat][sub] || 0) + 1;
  }
});
const categories = Object.keys(categoryTree).sort();
const totalArticleCount = sortedArticles.length;
const currentCategory = Astro.url.searchParams.get("cat") || "";
const currentSubcategory = Astro.url.searchParams.get("sub") || "";
const resolveImageUrl = (imageUrl: string | { src: string } | undefined) =>
  typeof imageUrl === "string" ? imageUrl : imageUrl?.src;

// Extract raw text for feed preview (removing markdown syntaxes)
const getSnippet = (body: string) => {
  if (!body) return "";
  let text = body
    .replace(/^---[\s\S]*?---/m, "") // Remove frontmatter
    .replace(/#{1,6}\s+/g, "") // Remove headings
    .replace(/!\[.*?\]\(.*?\)/g, "") // Remove images
    .replace(/\[(.*?)\]\(.*?\)/g, "$1") // Remove links
    .replace(/[*_]{1,3}(.*?)[*_]{1,3}/g, "$1") // Remove bold/italic
    .replace(/```[\s\S]*?```/g, "") // Remove code blocks entirely
    .replace(/`([^`]*)`/g, "$1") // Extract text from inline code
    .replace(/<[^>]*>/g, "") // Remove HTML tags
    .replace(/^\s*[-*+]\s+/gm, "") // Remove ul bullet points
    .replace(/^\s*\d+\.\s+/gm, "") // Remove ol bullet points
    .replace(/\s+/g, " ") // Replace multiple spaces/newlines with single space
    .trim();
  // Cut string long enough for 4 lines. Let line-clamp handle the visual ellipsis.
  return text.length > 500 ? text.slice(0, 500) + "..." : text;
};

---

<BaseLayout title="Articles | DEVARCHIVE" description="모든 아티클 및 저널 목록입니다.">
  <div
    id="articles-page"
    class="mx-auto w-full pt-32 md:pt-[16vh] pb-32"
    data-current-cat={currentCategory}
    data-current-sub={currentSubcategory}
  >
    <!-- Editorial Header Section -->
    <div class="mx-auto w-full max-w-[1700px] px-4 sm:px-6 md:px-8 mb-12 md:mb-16 reveal-up">
      <div class="mx-auto max-w-[900px] flex items-end justify-between gap-6 border-b border-border-color pb-10">
        <h1
          class="text-6xl md:text-8xl font-serif font-black tracking-tighter leading-[0.85] uppercase text-text-color"
        >
          Articles
        </h1>
        <div class="flex shrink-0 items-end gap-8">
          <div class="hidden sm:flex items-center glass-pill p-1 select-none mb-0">
            <div class="relative flex items-center">
              <div
                id="toggle-bg"
                class="absolute w-[38px] h-[32px] custom-glass-highlight rounded-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] left-0 z-0 border border-text-color/10"
              >
              </div>

              <button
                id="btn-feed"
                class="relative z-10 w-[38px] h-[32px] flex justify-center items-center rounded-full outline-none focus:outline-none text-[#1e66f5] dark:text-[#89b4fa] font-bold transition-colors duration-300"
                aria-label="Feed View"
              >
                <span class="material-symbols-outlined text-[16px]">splitscreen</span>
              </button>
              <button
                id="btn-grid"
                class="relative z-10 w-[38px] h-[32px] flex justify-center items-center rounded-full outline-none focus:outline-none text-text-color opacity-50 hover:opacity-100 font-medium transition-opacity duration-300"
                aria-label="Grid View"
              >
                <span class="material-symbols-outlined text-[16px]">grid_view</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="mx-auto w-full max-w-[1700px] grid grid-cols-1 xl:grid-cols-[1fr_minmax(0,900px)_1fr] gap-x-8 gap-y-8 xl:gap-y-16 relative px-4 sm:px-6 md:px-8 xl:px-4"
    >
      <!-- MOBILE CATEGORY CHIPS (Shown only below XL) -->
      <div class="xl:hidden w-full max-w-[900px] mx-auto pb-6 pt-1 relative reveal-up">
        <div class="relative w-full">
          <!-- Optional: Scroll Masks (Fade edges) -->
          <div
            class="absolute left-0 top-0 bottom-0 w-12 bg-gradient-to-r from-[var(--bg-color)] via-[var(--bg-color)]/50 to-transparent z-10 pointer-events-none"
          >
          </div>
          <div
            class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-[var(--bg-color)] via-[var(--bg-color)]/50 to-transparent z-10 pointer-events-none"
          >
          </div>

          <div
            class="flex items-center gap-3 overflow-x-auto hide-scrollbar scroll-smooth py-3 px-6 select-none"
          >
            <a
              href="#"
              data-filter="all"
              class={`mobile-cat-filter glass-pill whitespace-nowrap px-5 py-2 text-[12px] font-bold tracking-tight transition-all duration-500 transform border shadow-sm ${
                !Astro.url.searchParams.get("cat")
                  ? "custom-glass-highlight text-[#1e66f5] dark:text-[#89b4fa] border-white/20 scale-[1.05] z-10"
                  : "bg-transparent text-text-color opacity-30 border-transparent hover:opacity-80 hover:bg-black/5 dark:hover:bg-white/5"
              }`}
            >
              All
            </a>
            {
              categories.map((cat) => (
                <a
                  href="#"
                  data-filter-cat={cat}
                  class={`mobile-cat-filter glass-pill whitespace-nowrap px-5 py-2 text-[12px] font-bold tracking-tight transition-all duration-500 transform border shadow-sm ${
                    Astro.url.searchParams.get("cat") === cat
                      ? "custom-glass-highlight text-[#1e66f5] dark:text-[#89b4fa] border-white/20 scale-[1.05] z-10"
                      : "bg-transparent text-text-color opacity-30 border-transparent hover:opacity-80 hover:bg-black/5 dark:hover:bg-white/5"
                  }`}
                >
                  {cat}
                </a>
              ))
            }
            <!-- Spacer for end of scroll -->
            <div class="min-w-[24px] h-1"></div>
          </div>
        </div>
      </div>

      <!-- LEFT COLUMN: SIDEBAR (Desktop) -->
      <div class="hidden xl:block w-full min-w-0 xl:ml-auto lg:mt-0">
        <aside
          class="sidebar-sticky w-full max-w-[280px] ml-auto flex flex-col z-20 hide-scrollbar transition-all duration-500"
        >
          <!-- SIDEBAR: UNIFIED GRID/CATEGORY MENU -->
          <div id="sidebar-category-menu">
            <TopicsSidebar />
          </div>
        </aside>
      </div>

      <!-- CENTER COLUMN: MAIN CONTENT (Perfectly Centered on XL) -->
      <main
        id="article-results"
        class="w-full max-w-[900px] mx-auto min-w-0 transition-opacity duration-500 relative min-h-[70vh]"
      >
        <!-- VIEW 1: FEED DETAILS (Vertical Scroll Layout) -->
        <div
          id="view-feed"
          class="w-full flex flex-col transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
        >
          <div class="relative w-full h-full" id="feed-details-container">
            {
              sortedArticles.map((entry, index) => (
                <div
                  data-category={entry.data.category}
                  data-subcategory={entry.data.subcategory}
                  class="post-detail relative w-full flex-col glass-panel rounded-[2.5rem] p-6 md:p-10 mb-12 reveal-up transition-all duration-500"
                >
                  <div class="mb-8">
                    <div class="flex items-center gap-2 mb-4 text-text-color opacity-60 text-[12px] font-bold uppercase tracking-widest font-sans">
                      <span class="text-accent-color max-w-max">{entry.data.category}</span>
                      <span class="w-[3px] h-[3px] rounded-full bg-border-color" />
                      <time class="tabular-nums">
                        {entry.data.date
                          .toLocaleDateString("ko-KR", {
                            year: "numeric",
                            month: "2-digit",
                            day: "2-digit",
                          })
                          .replace(/\./g, "-")
                          .replace(/ /g, "")
                          .slice(0, -1)}
                      </time>
                    </div>
                    <h2 class="text-3xl md:text-5xl font-serif font-bold tracking-tighter text-text-color leading-[1.2] mb-5 break-keep hover:text-accent-color transition-colors">
                      <a href={`/articles/${entry.id}`}>{entry.data.title}</a>
                    </h2>
                    {entry.data.imageUrl && (
                      <div
                        class="w-full aspect-[21/9] md:aspect-[16/9] rounded-[1rem] overflow-hidden bg-black/5 dark:bg-white/5 mb-8 relative group cursor-pointer"
                        onclick={`window.location.href='/articles/${entry.id}'`}
                      >
                        <img
                          src={resolveImageUrl(entry.data.imageUrl)}
                          alt={entry.data.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out"
                          loading="lazy"
                        />
                      </div>
                    )}
                  </div>

                  <div class="mb-6 space-y-4">
                    <h3 class="text-lg md:text-xl font-sans font-medium text-text-color leading-[1.65] tracking-tight break-keep opacity-90">
                      {entry.data.description}
                    </h3>
                    <div class="relative">
                      <p class="text-text-color text-sm leading-[1.8] tracking-tight break-keep line-clamp-4 font-sans opacity-70">
                        {entry.body ? getSnippet(entry.body) : ""}
                      </p>
                    </div>
                  </div>

                  <div class="mt-8 flex justify-end">
                    <a
                      href={`/articles/${entry.id}`}
                      class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full border border-border-color/20 dark:border-white/20 bg-transparent hover:bg-text-color hover:text-bg-color hover:border-transparent text-[11px] font-sans font-bold uppercase tracking-[0.2em] text-text-color transition-colors duration-400 group"
                    >
                      Read Article
                      <span class="material-symbols-outlined text-[15px] group-hover:translate-x-1 transition-transform">
                        arrow_forward
                      </span>
                    </a>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- VIEW 2: GRID ARTICLES -->
        <div
          id="view-grid"
          class="hidden opacity-0 translate-y-8 flex-col relative w-full h-0 pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] pb-20"
        >
          <div
            id="article-grid-container"
            class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 gap-x-8 gap-y-12 h-auto w-full"
          >
            {
              sortedArticles.map((article) => (
                <div
                  class="article-grid-item h-full flex flex-col reveal-up transition-all duration-500"
                  data-category={article.data.category}
                  data-subcategory={article.data.subcategory}
                >
                  <ArticleCard
                    title={article.data.title}
                    description={article.data.description}
                    category={article.data.category}
                    date={article.data.date.toLocaleDateString("ko-KR", {
                      year: "numeric",
                      month: "2-digit",
                      day: "2-digit",
                    })}
                    href={`/articles/${article.id}`}
                    imageUrl={article.data.imageUrl || ""}
                    subcategory={article.data.subcategory}
                  />
                </div>
              ))
            }
          </div>
        </div>

        <nav id="article-pagination" class="mt-14 md:mt-16 flex items-center justify-center gap-2 reveal-up" aria-label="게시물 페이지">
          <button id="pagination-prev" class="pagination-button" type="button" aria-label="이전 페이지">
            <span class="material-symbols-outlined text-[17px]">arrow_back</span>
          </button>
          <div id="pagination-numbers" class="flex items-center justify-center gap-2">
            <button class="pagination-button is-active" type="button" aria-current="page">1</button>
          </div>
          <button id="pagination-next" class="pagination-button" type="button" aria-label="다음 페이지">
            <span class="material-symbols-outlined text-[17px]">arrow_forward</span>
          </button>
        </nav>
      </main>

      <!-- RIGHT COLUMN: SPACER (For perfect centering on XL) -->
      <div class="hidden xl:block w-full min-w-0 order-3"></div>
    </div><!-- /page container -->

    <script>
      let articleRevealObserver: IntersectionObserver | null = null;

      document.addEventListener("astro:page-load", () => {
        if (articleRevealObserver) articleRevealObserver.disconnect();

        // Reveal Animation Observer
        articleRevealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
                observer.unobserve(entry.target);
              }
            });
          },
          { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
        );
        document
          .querySelectorAll<HTMLElement>(".reveal-up")
          .forEach((el) => articleRevealObserver?.observe(el));

        // View Toggle Logic
        const btnFeed = document.getElementById("btn-feed");
        const btnGrid = document.getElementById("btn-grid");
        const toggleBg = document.getElementById("toggle-bg");

        const viewFeed = document.getElementById("view-feed");
        const viewGrid = document.getElementById("view-grid");

        if (btnFeed && btnGrid && toggleBg && viewFeed && viewGrid) {
          let isFeed = (localStorage.getItem("article-view") || "feed") === "feed";

          const moveToggle = (btn: HTMLElement) => {
            toggleBg.style.transform = btn === btnFeed ? "translateX(0)" : "translateX(38px)";
            [btnFeed, btnGrid].forEach((b) => {
              b.classList.remove(
                "text-[#1e66f5]",
                "dark:text-[#89b4fa]",
                "font-bold",
                "opacity-100",
              );
              b.classList.add("text-text-color", "font-medium", "opacity-50");
            });
            btn.classList.remove("text-text-color", "font-medium", "opacity-50");
            btn.classList.add("text-[#1e66f5]", "dark:text-[#89b4fa]", "font-bold", "opacity-100");
          };

          const applyView = () => {
            moveToggle(isFeed ? btnFeed : btnGrid);
            if (isFeed) {
              viewGrid.classList.add("hidden", "opacity-0", "translate-y-8", "pointer-events-none");
              viewGrid.classList.remove("flex", "h-auto");
              viewGrid.style.height = "0";

              viewFeed.classList.remove(
                "hidden",
                "opacity-0",
                "translate-y-8",
                "pointer-events-none",
              );
              viewFeed.classList.add("flex", "opacity-100", "translate-y-0");
            } else {
              viewFeed.classList.add("hidden", "opacity-0", "translate-y-8", "pointer-events-none");
              viewFeed.classList.remove("flex", "opacity-100", "translate-y-0");

              viewGrid.classList.remove("hidden", "pointer-events-none");
              viewGrid.style.height = "auto";
              void viewGrid.offsetWidth; // force reflow
              viewGrid.classList.add("flex", "opacity-100");
              viewGrid.classList.remove("translate-y-8");
            }
            localStorage.setItem("article-view", isFeed ? "feed" : "grid");

            setTimeout(() => window.dispatchEvent(new Event("resize")), 50); // recalculate highlights
          };

          applyView();
          btnFeed.addEventListener("click", () => {
            if (!isFeed) {
              isFeed = true;
              applyView();
            }
          });
          btnGrid.addEventListener("click", () => {
            if (isFeed) {
              isFeed = false;
              applyView();
            }
          });

          // Hover sliding effect for view toggle
          const toggleBtns = [btnFeed, btnGrid];
          toggleBtns.forEach((btn) => {
            btn.addEventListener("mouseenter", () => {
              toggleBg.style.transform = btn === btnFeed ? "translateX(0)" : "translateX(38px)";
              toggleBg.style.transitionDuration = "400ms"; // slightly faster on hover
            });

            btn.addEventListener("mouseleave", () => {
              toggleBg.style.transform = isFeed ? "translateX(0)" : "translateX(38px)";
              toggleBg.style.transitionDuration = "500ms"; // restore active transition speed
            });
          });
        }

        // Unified Category Filter & Pagination Logic
        const btnActiveClasses = "active-item text-blue-600 dark:text-blue-400 font-bold group"
          .split(" ")
          .filter(Boolean);
        const btnInactiveClasses =
          "text-apple-textMuted dark:text-apple-darkTextMuted font-medium group"
            .split(" ")
            .filter(Boolean);

        const mobileActiveClasses =
          "custom-glass-highlight text-[#1e66f5] dark:text-[#89b4fa] border-white/20 scale-[1.05] z-10"
            .split(" ")
            .filter(Boolean);
        const mobileInactiveClasses = "bg-transparent text-text-color opacity-30 border-transparent"
          .split(" ")
          .filter(Boolean);

        const catBtns = document.querySelectorAll(".cat-filter");
        const mobileCatBtns = document.querySelectorAll(".mobile-cat-filter");
        const gridItems = document.querySelectorAll<HTMLElement>(".article-grid-item");
        const feedItems = document.querySelectorAll<HTMLElement>(".post-detail");
        const articlesPage = document.getElementById("articles-page");
        const articleResults = document.getElementById("article-results");
        const pagination = document.getElementById("article-pagination");
        const paginationNumbers = document.getElementById("pagination-numbers");
        const paginationPrev = document.getElementById("pagination-prev") as HTMLButtonElement | null;
        const paginationNext = document.getElementById("pagination-next") as HTMLButtonElement | null;
        const pageSize = 6;
        const requestedPage = Number.parseInt(new URLSearchParams(window.location.search).get("page") || "1", 10);
        let currentPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;
        let activeCategory = articlesPage?.dataset.currentCat || "";
        let activeSubcategory = articlesPage?.dataset.currentSub || "";

        const matchesActiveFilter = (element: HTMLElement) => {
          if (!activeCategory) return true;
          if (activeSubcategory) {
            return element.dataset.category === activeCategory && element.dataset.subcategory === activeSubcategory;
          }
          return element.dataset.category === activeCategory;
        };

        const pageTokens = (totalPages: number): Array<number | string> => {
          if (totalPages <= 7) return Array.from({ length: totalPages }, (_, index) => index + 1);

          const tokens: Array<number | string> = [1];
          const start = Math.max(2, currentPage - 1);
          const end = Math.min(totalPages - 1, currentPage + 1);
          if (start > 2) tokens.push("ellipsis-start");
          for (let page = start; page <= end; page += 1) tokens.push(page);
          if (end < totalPages - 1) tokens.push("ellipsis-end");
          tokens.push(totalPages);
          return tokens;
        };

        const updateLocation = () => {
          const url = new URL(window.location.href);
          if (currentPage > 1) url.searchParams.set("page", String(currentPage));
          else url.searchParams.delete("page");
          if (activeCategory) url.searchParams.set("cat", activeCategory);
          else url.searchParams.delete("cat");
          if (activeSubcategory) url.searchParams.set("sub", activeSubcategory);
          else url.searchParams.delete("sub");
          window.history.replaceState({}, "", `${url.pathname}${url.search}`);
        };

        const renderPagination = (totalPages: number) => {
          if (!pagination || !paginationNumbers || !paginationPrev || !paginationNext) return;
          paginationNumbers.replaceChildren();

          pageTokens(totalPages).forEach((token) => {
            if (typeof token !== "number") {
              const ellipsis = document.createElement("span");
              ellipsis.className = "pagination-ellipsis";
              ellipsis.textContent = "…";
              paginationNumbers.appendChild(ellipsis);
              return;
            }

            const button = document.createElement("button");
            button.type = "button";
            button.className = `pagination-button${token === currentPage ? " is-active" : ""}`;
            button.textContent = String(token);
            button.setAttribute("aria-label", `${token}페이지`);
            if (token === currentPage) button.setAttribute("aria-current", "page");
            button.addEventListener("click", () => moveToPage(token));
            paginationNumbers.appendChild(button);
          });

          paginationPrev.disabled = currentPage <= 1;
          paginationNext.disabled = currentPage >= totalPages;
        };

        const applyPagination = () => {
          const matchingCount = Array.from(feedItems).filter(matchesActiveFilter).length;
          const totalPages = Math.max(1, Math.ceil(matchingCount / pageSize));
          currentPage = Math.min(Math.max(1, currentPage), totalPages);
          const startIndex = (currentPage - 1) * pageSize;
          const endIndex = startIndex + pageSize;

          [feedItems, gridItems].forEach((items) => {
            let matchingIndex = 0;
            items.forEach((item) => {
              const matches = matchesActiveFilter(item);
              const visible = matches && matchingIndex >= startIndex && matchingIndex < endIndex;
              if (matches) matchingIndex += 1;
              item.style.display = visible ? "" : "none";
              item.style.opacity = visible ? "1" : "0";
              item.style.transform = visible ? "translateY(0) scale(1)" : "translateY(10px) scale(0.98)";
            });
          });

          renderPagination(totalPages);
          updateLocation();
        };

        function moveToPage(page: number) {
          currentPage = page;
          applyPagination();
          articleResults?.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        const executeFilter = (
          filter: string | undefined,
          filterCat: string | undefined,
          filterSub: string | undefined,
        ) => {
          catBtns.forEach((b) => {
            const bFilter = (b as HTMLElement).dataset.filter;
            const bCat = (b as HTMLElement).dataset.filterCat;
            const bSub = (b as HTMLElement).dataset.filterSub;

            const isMatch =
              (filter === "all" && bFilter === "all") ||
              (filterCat && !filterSub && bCat === filterCat && !bSub) ||
              (filterCat && filterSub && bCat === filterCat && bSub === filterSub);

            if (isMatch) {
              b.classList.remove(...btnInactiveClasses);
              b.classList.add(...btnActiveClasses);
            } else {
              b.classList.remove(...btnActiveClasses);
              b.classList.add(...btnInactiveClasses);
            }
          });

          mobileCatBtns.forEach((b) => {
            const bFilter = (b as HTMLElement).dataset.filter;
            const bCat = (b as HTMLElement).dataset.filterCat;
            const isMatch =
              (filter === "all" && bFilter === "all") || (filterCat && bCat === filterCat);

            if (isMatch) {
              b.classList.remove(...mobileInactiveClasses);
              b.classList.add(...mobileActiveClasses);
            } else {
              b.classList.remove(...mobileActiveClasses);
              b.classList.add(...mobileInactiveClasses);
            }
          });

          document.querySelectorAll(".sub-list").forEach((list) => {
            list.classList.add("hidden");
            list.classList.remove("flex");
          });

          if (filterCat) {
            const group = document.querySelector(`.category-group[data-group-cat="${filterCat}"]`);
            if (group) {
              const subList = group.querySelector(".sub-list");
              if (subList) {
                subList.classList.remove("hidden");
                subList.classList.add("flex");
              }
            }
          }

          activeCategory = filter === "all" ? "" : filterCat || "";
          activeSubcategory = filter === "all" ? "" : filterSub || "";
          currentPage = 1;
          applyPagination();
          setTimeout(() => document.dispatchEvent(new Event("update-sliders")), 10);
        };

        const allButtons = [...Array.from(catBtns), ...Array.from(mobileCatBtns)];
        allButtons.forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.preventDefault();
            const targetBtn = e.currentTarget as HTMLElement;
            executeFilter(
              targetBtn.dataset.filter,
              targetBtn.dataset.filterCat,
              targetBtn.dataset.filterSub,
            );
          });
        });

        paginationPrev?.addEventListener("click", () => moveToPage(currentPage - 1));
        paginationNext?.addEventListener("click", () => moveToPage(currentPage + 1));
        applyPagination();

        // Code Block Copy Animation
        const preTags = document.querySelectorAll(".prose pre");
        preTags.forEach((pre) => {
          const parent = pre.parentNode as HTMLElement;
          if (!parent || parent.classList.contains("code-block-wrapper")) return;
          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper relative mt-6 mb-6 group";
          parent.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);
          const copyBtn = document.createElement("button");
          copyBtn.className =
            "copy-btn absolute top-2 right-2 px-3 py-1 bg-white/10 hover:bg-white/20 text-white/50 hover:text-white text-[11px] font-mono rounded backdrop-blur-md transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10";
          copyBtn.textContent = "Copy";
          copyBtn.addEventListener("click", async () => {
            const codeText = pre.textContent || "";
            await navigator.clipboard.writeText(codeText);
            copyBtn.textContent = "Copied!";
            setTimeout(() => (copyBtn.textContent = "Copy"), 2000);
          });
          wrapper.appendChild(copyBtn);
        });
      });
    </script>
  </div>
</BaseLayout>

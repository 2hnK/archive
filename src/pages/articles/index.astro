---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const renderedArticles = await Promise.all(sortedArticles.map(async (entry) => {
  const { Content } = await render(entry);
  return { entry, Content };
}));

const categoryCount: Record<string, number> = {};
sortedArticles.forEach(a => {
  const cat = a.data.category;
  categoryCount[cat] = (categoryCount[cat] || 0) + 1;
});
const categories = Object.keys(categoryCount);

const LIQUID_GLASS_TOKEN = "custom-glass-highlight border border-white/20 dark:border-white/10";
const BTN_INACTIVE = 'outline-none focus:outline-none border-none ring-0 appearance-none bg-transparent text-apple-textMuted dark:text-apple-darkTextMuted transition-colors duration-300 font-medium group';
const BTN_ACTIVE = 'active-item outline-none focus:outline-none border-none ring-0 appearance-none bg-transparent text-blue-600 dark:text-blue-400 font-bold transition-colors duration-300 group';
---

<BaseLayout title="Articles | DevArchive" description="모든 아티클 및 저널 목록입니다.">
  
  <div class="mx-auto w-full max-w-[1700px] grid grid-cols-1 lg:grid-cols-[260px_1fr] xl:grid-cols-[1fr_minmax(auto,1000px)_1fr] gap-8 lg:gap-14 px-4 sm:px-6 md:px-8 pt-24 pb-20 relative" style="padding-top: 160px;">
    
    <!-- LEFT COLUMN: SIDEBAR (Floats to the right side of this column on xl) -->
    <div class="w-full lg:w-auto order-2 lg:order-1 mt-12 lg:mt-0">
      <aside class="w-full lg:w-[260px] xl:w-[280px] xl:ml-auto flex flex-col lg:sticky lg:top-32 h-fit max-h-[calc(100vh-8rem)] flex-shrink-0 z-20 overflow-y-auto hide-scrollbar transition-all duration-500">
        
        <!-- SIDEBAR: UNIFIED GRID/CATEGORY MENU -->
        <div id="sidebar-category-menu" class="w-full h-auto flex flex-col pl-4 reveal-up stagger-1" style="margin-top: 170px;padding-right: 16px;">
          <h2 class="text-[12px] font-bold tracking-[0.15em] uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-8 text-right pr-2">TOPICS</h2>
          
          <div class="relative flex flex-col gap-1 pb-2 pr-[2px]" id="cat-list-container">
            <!-- The vertical line -->
            <div class="absolute right-0 top-3 bottom-0 w-[1px] bg-black/10 dark:bg-white/10 pointer-events-none z-0"></div>

            <!-- The glassmorphism highlight pill encompassing text and dot (Narrower Width) -->
            <div id="grid-highlight" class="absolute left-[12px] w-[calc(100%-5px)] rounded-[1rem] custom-glass-highlight border border-black/5 dark:border-white/10 shadow-sm transition-all duration-400 ease-[cubic-bezier(0.25,1,0.5,1)] z-20 pointer-events-none opacity-0 flex items-center justify-end pr-[4px]">
               <!-- The active blue dot sits on the line inside the pill, sliding OVER the gray dots -->
               <div class="w-[6px] h-[6px] rounded-full bg-blue-600 dark:bg-blue-400 flex-shrink-0 shadow-[0_0_8px_rgba(59,130,246,0.6)]"></div>
            </div>

            <button data-filter="all" class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-3 cursor-pointer ${BTN_ACTIVE}`}>
              <span class="text-[14.5px] text-right">All</span>
              <!-- Gray dot is permanently visible, blue dot slides over it -->
              <span class="inactive-dot absolute right-[-1.5px] top-1/2 -translate-y-1/2 w-[4px] h-[4px] rounded-full bg-black/20 dark:bg-white/20 transition-all duration-300"></span>
            </button>
            {categories.map(cat => (
              <button data-filter={cat} class={`cat-filter relative z-10 w-full flex items-center justify-end pr-[24px] py-3 cursor-pointer ${BTN_INACTIVE}`}>
                <span class="text-[14.5px] text-right">{cat}</span>
                <span class="inactive-dot absolute right-[-1.5px] top-1/2 -translate-y-1/2 w-[4px] h-[4px] rounded-full bg-black/20 dark:bg-white/20 transition-all duration-300 group-hover:bg-black/40 dark:group-hover:bg-white/40"></span>
              </button>
            ))}
          </div>
        </div>

      </aside>
    </div>

    <!-- CENTER COLUMN: MAIN CONTENT (Perfectly Centered on XL) -->
    <main class="w-full min-w-0 transition-opacity duration-500 relative min-h-[70vh] order-1 lg:order-2">

      <!-- Top Bar: Title & View Toggle -->
      <div class="w-full flex flex-col sm:flex-row sm:justify-between sm:items-end mb-10 border-b border-apple-border dark:border-apple-darkBorder pb-6 gap-6">
        <div>
          <h1 class="text-[2.5rem] md:text-5xl font-bold tracking-tighter text-apple-text dark:text-apple-darkText mb-3">Article</h1>
          <p class="text-apple-textMuted dark:text-apple-darkTextMuted max-w-2xl text-[17px] md:text-[19px] tracking-tight font-medium break-keep">지식 저장소</p>
        </div>
        
        <!-- Liquid Glass Segmented Control Toggle -->
        <div class="hidden sm:flex items-center bg-black/[0.04] dark:bg-white/[0.06] p-1.5 rounded-[1.2rem] ring-1 ring-black/5 dark:ring-white/10 shadow-[inset_0_1px_4px_rgba(0,0,0,0.05)] select-none">
          <div class="relative flex items-center">
            <div id="toggle-bg" class={`absolute w-[44px] h-[36px] rounded-[1rem] transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] left-0 z-0 ${LIQUID_GLASS_TOKEN}`}></div>
            
            <button id="btn-feed" class="relative z-10 w-[44px] h-[36px] flex justify-center items-center rounded-xl text-blue-600 dark:text-blue-400 transition-colors duration-300" aria-label="Feed View">
              <span class="material-symbols-outlined text-[18px]">splitscreen</span>
            </button>
            <button id="btn-grid" class="relative z-10 w-[44px] h-[36px] flex justify-center items-center rounded-xl text-apple-textMuted dark:text-apple-darkTextMuted transition-colors duration-300" aria-label="Grid View">
              <span class="material-symbols-outlined text-[18px]">grid_view</span>
            </button>
          </div>
        </div>
      </div>
      
      <div class="h-4"></div>
      
      <!-- VIEW 1: FEED DETAILS (Vertical Scroll Layout) -->
      <div id="view-feed" class="w-full flex flex-col transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
        <div class="relative w-full h-full" id="feed-details-container">
          {renderedArticles.map(({ entry, Content }, index) => (
            <div 
              data-category={entry.data.category}
              class="post-detail relative block w-full flex-col bg-apple-surface dark:bg-apple-darkSurface rounded-[2.5rem] p-8 md:p-14 mb-[4rem] border border-apple-border/40 dark:border-apple-darkBorder/40 shadow-[0_8px_32px_rgba(0,0,0,0.04)] reveal-up transition-all duration-500"
            >
              <div class="mb-10">
                <div class="flex items-center gap-2 mb-4 text-apple-textMuted dark:text-apple-darkTextMuted text-[13px] font-bold uppercase tracking-widest">
                  <span class="text-[#a34455] dark:text-[#ff92a6]">{entry.data.category}</span>
                  <span class="w-1 h-1 rounded-full bg-apple-border dark:bg-apple-darkBorder"></span>
                  <time>{entry.data.date.toLocaleDateString('ko-KR')}</time>
                </div>
                <h2 class="text-[2.2rem] md:text-[3.2rem] font-bold tracking-tighter text-apple-text dark:text-apple-darkText leading-[1.1] mb-6 break-keep hover:text-blue-500 transition-colors">
                  <a href={`/articles/${entry.id}`}>{entry.data.title}</a>
                </h2>
                {entry.data.imageUrl && (
                  <div class="w-full aspect-[21/9] md:aspect-[16/9] rounded-[1.5rem] overflow-hidden bg-black/5 dark:bg-white/5 border border-black/5 dark:border-white/10 mb-10 shadow-sm relative group cursor-pointer" onclick={`window.location.href='/articles/${entry.id}'`}>
                    <img src={entry.data.imageUrl} alt={entry.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out" loading="lazy" />
                  </div>
                )}
              </div>
              
              <!-- line-clamp-[12] limits height and adds '...' to the end -->
              <div class="prose max-w-none prose-zinc dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-apple-text dark:prose-a:text-apple-darkText text-[17px] leading-[1.75] tracking-tight break-keep line-clamp-[12]">
                <Content />
              </div>
              
              <div class="mt-16 pt-8 border-t border-apple-border/40 dark:border-apple-darkBorder/40 flex justify-end items-center">
                <a href={`/articles/${entry.id}`} class="btn-premium">
                  전체 화면으로 읽기
                  <span class="material-symbols-outlined text-[16px] leading-none">arrow_forward</span>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- VIEW 2: GRID ARTICLES -->
      <div id="view-grid" class="hidden opacity-0 translate-y-8 flex-col relative w-full h-0 pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] pb-20">
        <div id="article-grid-container" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 gap-x-8 gap-y-12 h-auto w-full">
          {sortedArticles.map(article => (
            <div class="article-grid-item h-full flex flex-col reveal-up transition-all duration-500" data-category={article.data.category}>
              <ArticleCard 
                title={article.data.title}
                description={article.data.description}
                category={article.data.category}
                date={article.data.date.toLocaleDateString('ko-KR')}
                href={`/articles/${article.id}`}
                imageUrl={article.data.imageUrl}
              />
            </div>
          ))}
        </div>
      </div>

    </main>

    <!-- RIGHT COLUMN: SPACER (For perfect centering on XL) -->
    <div class="hidden xl:block order-3"></div>

  </div><!-- /page container -->

  <script>
    document.addEventListener('astro:page-load', () => {
      // Reveal Animation Observer
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          }
        });
      }, { root: null, rootMargin: '0px 0px -50px 0px', threshold: 0.1 });
      document.querySelectorAll(".reveal-up").forEach(el => revealObserver.observe(el));

      // View Toggle Logic
      const btnFeed = document.getElementById('btn-feed');
      const btnGrid = document.getElementById('btn-grid');
      const toggleBg = document.getElementById('toggle-bg');
      
      const viewFeed = document.getElementById('view-feed');
      const viewGrid = document.getElementById('view-grid');

      if(btnFeed && btnGrid && toggleBg && viewFeed && viewGrid) {
        let isFeed = (localStorage.getItem('article-view') || 'feed') === 'feed';
        
        const toggleContainer = toggleBg.parentElement;
        const moveToggle = (btn) => {
          toggleBg.style.transform = btn === btnFeed ? 'translateX(0)' : 'translateX(44px)';
          [btnFeed, btnGrid].forEach(b => {
             b.classList.remove('text-blue-600', 'dark:text-blue-400');
             b.classList.add('text-apple-textMuted', 'dark:text-apple-darkTextMuted');
          });
          btn.classList.remove('text-apple-textMuted', 'dark:text-apple-darkTextMuted');
          btn.classList.add('text-blue-600', 'dark:text-blue-400');
        };

        const applyView = () => {
          moveToggle(isFeed ? btnFeed : btnGrid);
          if (isFeed) {
            viewGrid.classList.add('hidden', 'opacity-0', 'translate-y-8', 'pointer-events-none');
            viewGrid.classList.remove('flex', 'h-auto');
            viewGrid.style.height = '0';
            
            viewFeed.classList.remove('hidden', 'opacity-0', 'translate-y-8', 'pointer-events-none');
            viewFeed.classList.add('flex', 'opacity-100', 'translate-y-0');
          } else {
            viewFeed.classList.add('hidden', 'opacity-0', 'translate-y-8', 'pointer-events-none');
            viewFeed.classList.remove('flex', 'opacity-100', 'translate-y-0');
            
            viewGrid.classList.remove('hidden', 'pointer-events-none');
            viewGrid.style.height = 'auto';
            void viewGrid.offsetWidth; // force reflow
            viewGrid.classList.add('flex', 'opacity-100');
            viewGrid.classList.remove('translate-y-8');
          }
          localStorage.setItem('article-view', isFeed ? 'feed' : 'grid');
          
          setTimeout(() => window.dispatchEvent(new Event('resize')), 50); // recalculate highlights
        };
        
        applyView();
        btnFeed.addEventListener('click', () => { if (!isFeed) { isFeed = true; applyView(); } });
        btnGrid.addEventListener('click', () => { if (isFeed) { isFeed = false; applyView(); } });
        
        // Sliding hover effect
        if (toggleContainer) {
          [btnFeed, btnGrid].forEach(btn => {
             btn.addEventListener('mouseenter', () => moveToggle(btn));
          });
          toggleContainer.addEventListener('mouseleave', () => {
             moveToggle(isFeed ? btnFeed : btnGrid);
          });
        }
      }

      // Unified Category Filter Logic
      const btnActiveClasses = 'active-item text-blue-600 dark:text-blue-400 font-bold group'.split(' ').filter(Boolean);
      const btnInactiveClasses = 'text-apple-textMuted dark:text-apple-darkTextMuted font-medium group'.split(' ').filter(Boolean);

      const catBtns = document.querySelectorAll('.cat-filter');
      const gridItems = document.querySelectorAll('.article-grid-item');
      const feedItems = document.querySelectorAll('.post-detail');
      
      catBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = (btn as HTMLElement).dataset.filter;
          catBtns.forEach(b => {
             b.classList.remove(...btnActiveClasses);
             b.classList.add(...btnInactiveClasses);
             const ic = b.querySelector('.material-symbols-outlined');
             if(ic) ic.textContent = 'folder';
          });
          
          btn.classList.add(...btnActiveClasses);
          btn.classList.remove(...btnInactiveClasses);
          
          const activeIc = btn.querySelector('.material-symbols-outlined');
          if(activeIc) activeIc.textContent = filter === 'all' ? 'all_inbox' : 'folder_open';

          // Filter Grid View
          gridItems.forEach(item => {
            const el = item as HTMLElement;
            if (filter === 'all' || el.dataset.category === filter) {
              el.style.display = '';
              setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'translateY(0) scale(1)'; }, 50);
            } else {
              el.style.opacity = '0';
              el.style.transform = 'translateY(10px) scale(0.98)';
              setTimeout(() => { el.style.display = 'none'; }, 400);
            }
          });

          // Filter Feed View
          feedItems.forEach(item => {
            const el = item as HTMLElement;
            if (filter === 'all' || el.dataset.category === filter) {
              el.style.display = '';
              setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'translateY(0) scale(1)'; }, 50);
            } else {
              el.style.opacity = '0';
              el.style.transform = 'translateY(10px) scale(0.98)';
              setTimeout(() => { el.style.display = 'none'; }, 400);
            }
          });

          // Dispatch update event for sliding highlight recalculation
          document.dispatchEvent(new Event('update-sliders'));
        });
      });

      // Shared Sliding Highlight
      const setupSlidingHighlight = (containerId, highlightId, itemSelector) => {
        const container = document.getElementById(containerId);
        const highlight = document.getElementById(highlightId);
        if (!container || !highlight) return;
        
        let activeItem = container.querySelector(`${itemSelector}.active-item`) || container.querySelector(itemSelector);

        const removeBlueText = (el) => {
           el.classList.remove('text-blue-600', 'dark:text-blue-400', 'font-bold');
           el.classList.add('text-apple-textMuted', 'dark:text-apple-darkTextMuted', 'font-medium');
        };
        const addBlueText = (el) => {
           el.classList.remove('text-apple-textMuted', 'dark:text-apple-darkTextMuted', 'font-medium');
           el.classList.add('text-blue-600', 'dark:text-blue-400', 'font-bold');
        };

        const move = (el) => {
          highlight.style.height = `${el.offsetHeight}px`;
          highlight.style.transform = `translateY(${el.offsetTop}px)`;
          highlight.style.opacity = '1';
          
          container.querySelectorAll(itemSelector).forEach(btn => removeBlueText(btn));
          addBlueText(el);
        };

        if (activeItem) setTimeout(() => move(activeItem), 50);

        const items = container.querySelectorAll(itemSelector);
        items.forEach(item => {
          item.addEventListener('mouseenter', () => move(item));
          item.addEventListener('click', () => {
            activeItem = item;
            move(item);
          });
        });

        container.addEventListener('mouseleave', () => {
          if (activeItem) {
            move(activeItem);
          } else {
            highlight.style.opacity = '0';
          }
        });
        
        window.addEventListener('resize', () => {
          if (activeItem && container.offsetParent !== null) move(activeItem);
        });
        document.addEventListener('update-sliders', () => {
          activeItem = container.querySelector(`${itemSelector}.active-item`) || activeItem;
          if (activeItem && container.offsetParent !== null) move(activeItem);
        });
      };

      setupSlidingHighlight('cat-list-container', 'grid-highlight', '.cat-filter');

      // Code Block Copy Animation
      const preTags = document.querySelectorAll('.prose pre');
      preTags.forEach((pre) => {
        if (pre.parentNode?.classList.contains('code-block-wrapper')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'code-block-wrapper relative mt-6 mb-6 group';
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
        const copyBtn = document.createElement('button');
        copyBtn.className = 'copy-btn absolute top-2 right-2 px-3 py-1 bg-white/10 hover:bg-white/20 text-white/50 hover:text-white text-[11px] font-mono rounded backdrop-blur-md transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10';
        copyBtn.textContent = 'Copy';
        copyBtn.addEventListener('click', async () => {
          const codeText = pre.textContent || '';
          await navigator.clipboard.writeText(codeText);
          copyBtn.textContent = 'Copied!';
          setTimeout(() => copyBtn.textContent = 'Copy', 2000);
        });
        wrapper.appendChild(copyBtn);
      });
    });
  </script>
</BaseLayout>

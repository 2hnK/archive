---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TopicsSidebar from "../../components/TopicsSidebar.astro";

const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryTree: Record<string, string[]> = {};
const catCounts: Record<string, number> = {};
const subCounts: Record<string, Record<string, number>> = {};
sortedArticles.forEach((a) => {
  const cat = a.data.category;
  const sub = a.data.subcategory;
  if (!categoryTree[cat]) {
    categoryTree[cat] = [];
    catCounts[cat] = 0;
    subCounts[cat] = {};
  }
  catCounts[cat]++;
  if (sub) {
    if (!categoryTree[cat].includes(sub)) categoryTree[cat].push(sub);
    subCounts[cat][sub] = (subCounts[cat][sub] || 0) + 1;
  }
});
const categories = Object.keys(categoryTree).sort();
const totalArticleCount = sortedArticles.length;

// Extract raw text for feed preview (removing markdown syntaxes)
const getSnippet = (body: string) => {
  if (!body) return "";
  let text = body
    .replace(/^---[\s\S]*?---/m, "") // Remove frontmatter
    .replace(/#{1,6}\s+/g, "") // Remove headings
    .replace(/!\[.*?\]\(.*?\)/g, "") // Remove images
    .replace(/\[(.*?)\]\(.*?\)/g, "$1") // Remove links
    .replace(/[*_]{1,3}(.*?)[*_]{1,3}/g, "$1") // Remove bold/italic
    .replace(/```[\s\S]*?```/g, "") // Remove code blocks entirely
    .replace(/`([^`]*)`/g, "$1") // Extract text from inline code
    .replace(/<[^>]*>/g, "") // Remove HTML tags
    .replace(/^\s*[-*+]\s+/gm, "") // Remove ul bullet points
    .replace(/^\s*\d+\.\s+/gm, "") // Remove ol bullet points
    .replace(/\s+/g, " ") // Replace multiple spaces/newlines with single space
    .trim();
  // Cut string long enough for 4 lines. Let line-clamp handle the visual ellipsis.
  return text.length > 500 ? text.slice(0, 500) + "..." : text;
};

const LIQUID_GLASS_TOKEN = "custom-glass-highlight border border-white/20 dark:border-white/10";
const BTN_INACTIVE =
  "outline-none focus:outline-none border-none ring-0 appearance-none bg-transparent text-apple-textMuted dark:text-apple-darkTextMuted transition-colors duration-300 font-medium group";
const BTN_ACTIVE =
  "active-item outline-none focus:outline-none border-none ring-0 appearance-none bg-transparent text-blue-600 dark:text-blue-400 font-bold transition-colors duration-300 group";
---

<BaseLayout title="Articles | DevArchive" description="모든 아티클 및 저널 목록입니다.">
  <div class="mx-auto w-full pt-24 pb-20" style="padding-top: 140px;">
    <!-- Top Bar: Title & View Toggle (Moved outside grid to match slug layout) -->
    <div
      class="mx-auto w-full max-w-[900px] px-4 sm:px-6 md:px-8 flex flex-col sm:flex-row sm:justify-between sm:items-end mb-10 border-b border-apple-border dark:border-apple-darkBorder pb-6 gap-6"
      style="
    padding-bottom: 12px;  "
    >
      <div>
        <span
          class="text-[10px] uppercase tracking-[0.25em] font-bold text-apple-textMuted dark:text-apple-darkTextMuted block mb-2"
          >ARTICLES</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-apple-text dark:text-apple-darkText mb-2">
          아티클
        </h1>
      </div>

      <!-- Liquid Glass Segmented Control Toggle -->
      <div
        class="hidden sm:flex items-center bg-black/[0.04] dark:bg-white/[0.06] p-1.5 rounded-[1.2rem] ring-1 ring-black/5 dark:ring-white/10 shadow-[inset_0_1px_4px_rgba(0,0,0,0.05)] select-none"
      >
        <div class="relative flex items-center">
          <div
            id="toggle-bg"
            class={`absolute w-[44px] h-[36px] rounded-[1.5rem] transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] right-9 z-0 ${LIQUID_GLASS_TOKEN}`}
          >
          </div>

          <button
            id="btn-feed"
            class="relative z-10 w-[38px] h-[32px] flex justify-center items-center rounded-xl text-blue-600 dark:text-blue-400 transition-colors duration-300"
            aria-label="Feed View"
          >
            <span class="material-symbols-outlined text-[16px]">splitscreen</span>
          </button>
          <button
            id="btn-grid"
            class="relative z-10 w-[38px] h-[32px] flex justify-center items-center rounded-xl text-apple-textMuted dark:text-apple-darkTextMuted transition-colors duration-300"
            aria-label="Grid View"
          >
            <span class="material-symbols-outlined text-[16px]">grid_view</span>
          </button>
        </div>
      </div>
    </div>

    <div
      class="mx-auto w-full max-w-[1700px] grid grid-cols-1 xl:grid-cols-[1fr_minmax(0,900px)_1fr] gap-x-8 gap-y-8 xl:gap-y-16 relative px-4 sm:px-6 md:px-8 xl:px-4"
    >
      <!-- MOBILE CATEGORY CHIPS (Shown only below XL) -->
      <div class="xl:hidden w-full max-w-[900px] mx-auto pb-4 pt-1">
        <div class="flex flex-wrap items-center gap-2">
          <a
            href="/articles"
            class={`glass-pill px-4 py-1.5 text-[12px] font-semibold tracking-wide transition-all duration-300 transform hover:scale-[1.05] border shadow-sm ${
              !Astro.url.searchParams.get("cat")
                ? "bg-black/10 dark:bg-white/10 text-[#1e66f5] dark:text-[#89b4fa] border-black/10 dark:border-white/10"
                : "text-apple-text dark:text-apple-darkText border-black/5 dark:border-white/10 hover:text-[#1e66f5] dark:hover:text-[#89b4fa] hover:bg-black/5 dark:hover:bg-white/10"
            }`}
          >
            All
          </a>
          {
            categories.map((cat) => (
              <a
                href={`/articles?cat=${encodeURIComponent(cat)}`}
                class={`glass-pill px-4 py-1.5 text-[12px] font-semibold tracking-wide transition-all duration-300 transform hover:scale-[1.05] border shadow-sm ${
                  Astro.url.searchParams.get("cat") === cat
                    ? "bg-black/10 dark:bg-white/10 text-[#1e66f5] dark:text-[#89b4fa] border-black/10 dark:border-white/10"
                    : "text-apple-text dark:text-apple-darkText border-black/5 dark:border-white/10 hover:text-[#1e66f5] dark:hover:text-[#89b4fa] hover:bg-black/5 dark:hover:bg-white/10"
                }`}
              >
                {cat}
              </a>
            ))
          }
        </div>
      </div>

      <!-- LEFT COLUMN: SIDEBAR (Desktop) -->
      <div class="hidden xl:block w-full min-w-0 xl:ml-auto lg:mt-0 relative h-full">
        <aside
          class="w-full max-w-[280px] ml-auto flex flex-col sticky top-32 h-fit max-h-[calc(100vh-8rem)] flex-shrink-0 z-20 overflow-y-auto hide-scrollbar transition-all duration-500"
        >
          <!-- SIDEBAR: UNIFIED GRID/CATEGORY MENU -->
          <div id="sidebar-category-menu">
            <TopicsSidebar />
          </div>
        </aside>
      </div>

      <!-- CENTER COLUMN: MAIN CONTENT (Perfectly Centered on XL) -->
      <main
        class="w-full max-w-[900px] mx-auto min-w-0 transition-opacity duration-500 relative min-h-[70vh]"
      >
        <!-- VIEW 1: FEED DETAILS (Vertical Scroll Layout) -->
        <div
          id="view-feed"
          class="w-full flex flex-col transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
        >
          <div class="relative w-full h-full" id="feed-details-container">
            {
              sortedArticles.map((entry, index) => (
                <div
                  data-category={entry.data.category}
                  data-subcategory={entry.data.subcategory}
                  class="post-detail relative w-full flex-col bg-white/70 dark:bg-[#1a1b26]/50 backdrop-blur-md rounded-[2.5rem] p-6 md:p-10 mb-12 shadow-[0_8px_48px_rgba(0,0,0,0.04)] border border-black/5 dark:border-white/5 reveal-up transition-all duration-500"
                >
                  <div class="mb-8">
                    <div class="flex items-center gap-2 mb-4 text-apple-textMuted dark:text-apple-darkTextMuted text-[12px] font-bold uppercase tracking-[0.2em]">
                      <span class="text-[#1e66f5] dark:text-[#89b4fa]">{entry.data.category}</span>
                      <span class="w-[3px] h-[3px] rounded-full bg-apple-border dark:bg-apple-darkBorder" />
                      <time class="tabular-nums">
                        {entry.data.date
                          .toLocaleDateString("ko-KR", {
                            year: "numeric",
                            month: "2-digit",
                            day: "2-digit",
                          })
                          .replace(/\./g, "-")
                          .replace(/ /g, "")
                          .slice(0, -1)}
                      </time>
                    </div>
                    <h2 class="text-xl md:text-2xl font-bold tracking-tight text-apple-text dark:text-apple-darkText leading-[1.25] mb-5 break-keep hover:text-[#1e66f5] dark:hover:text-[#89b4fa] transition-colors">
                      <a href={`/articles/${entry.id}`}>{entry.data.title}</a>
                    </h2>
                    {entry.data.imageUrl && (
                      <div
                        class="w-full aspect-[21/9] md:aspect-[16/9] rounded-[1rem] overflow-hidden bg-black/5 dark:bg-white/5 mb-8 relative group cursor-pointer"
                        onclick={`window.location.href='/articles/${entry.id}'`}
                      >
                        <img
                          src={entry.data.imageUrl}
                          alt={entry.data.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out"
                          loading="lazy"
                        />
                      </div>
                    )}
                  </div>

                  <div class="mb-6 space-y-4">
                    <h3 class="text-[17px] font-semibold text-apple-text dark:text-apple-darkText leading-[1.65] tracking-tight break-keep">
                      {entry.data.description}
                    </h3>
                    <div class="relative">
                      <p class="text-apple-textMuted dark:text-apple-darkTextMuted text-[15px] leading-[1.8] tracking-tight break-keep line-clamp-4 font-medium opacity-85">
                        {entry.body ? getSnippet(entry.body) : ""}
                      </p>
                    </div>
                  </div>

                  <div class="mt-6 flex justify-end">
                    <a
                      href={`/articles/${entry.id}`}
                      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-black/5 dark:bg-white/5 hover:bg-[#1e66f5]/10 dark:hover:bg-[#89b4fa]/15 text-[12px] font-bold uppercase tracking-[0.15em] text-[#1e66f5] dark:text-[#89b4fa] transition-all group"
                    >
                      Read Article
                      <span class="material-symbols-outlined text-[15px] group-hover:translate-x-1 transition-transform">
                        arrow_forward
                      </span>
                    </a>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- VIEW 2: GRID ARTICLES -->
        <div
          id="view-grid"
          class="hidden opacity-0 translate-y-8 flex-col relative w-full h-0 pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] pb-20"
        >
          <div
            id="article-grid-container"
            class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 gap-x-8 gap-y-12 h-auto w-full"
          >
            {
              sortedArticles.map((article) => (
                <div
                  class="article-grid-item h-full flex flex-col reveal-up transition-all duration-500"
                  data-category={article.data.category}
                  data-subcategory={article.data.subcategory}
                >
                  <ArticleCard
                    title={article.data.title}
                    description={article.data.description}
                    category={article.data.category}
                    date={article.data.date.toLocaleDateString("ko-KR")}
                    href={`/articles/${article.id}`}
                    imageUrl={article.data.imageUrl || ""}
                  />
                </div>
              ))
            }
          </div>
        </div>
      </main>

      <!-- RIGHT COLUMN: SPACER (For perfect centering on XL) -->
      <div class="hidden xl:block w-full min-w-0 order-3"></div>
    </div><!-- /page container -->

    <script>
      let articleRevealObserver;

      document.addEventListener("astro:page-load", () => {
        if (articleRevealObserver) articleRevealObserver.disconnect();

        // Reveal Animation Observer
        articleRevealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
                observer.unobserve(entry.target);
              }
            });
          },
          { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
        );
        document.querySelectorAll(".reveal-up").forEach((el) => articleRevealObserver.observe(el));

        // View Toggle Logic
        const btnFeed = document.getElementById("btn-feed");
        const btnGrid = document.getElementById("btn-grid");
        const toggleBg = document.getElementById("toggle-bg");

        const viewFeed = document.getElementById("view-feed");
        const viewGrid = document.getElementById("view-grid");

        if (btnFeed && btnGrid && toggleBg && viewFeed && viewGrid) {
          let isFeed = (localStorage.getItem("article-view") || "feed") === "feed";

          const toggleContainer = toggleBg.parentElement;
          const moveToggle = (btn: HTMLElement) => {
            toggleBg.style.transform = btn === btnFeed ? "translateX(0)" : "translateX(38px)";
            [btnFeed, btnGrid].forEach((b) => {
              b.classList.remove("text-blue-600", "dark:text-blue-400");
              b.classList.add("text-apple-textMuted", "dark:text-apple-darkTextMuted");
            });
            btn.classList.remove("text-apple-textMuted", "dark:text-apple-darkTextMuted");
            btn.classList.add("text-blue-600", "dark:text-blue-400");
          };

          const applyView = () => {
            moveToggle(isFeed ? btnFeed : btnGrid);
            if (isFeed) {
              viewGrid.classList.add("hidden", "opacity-0", "translate-y-8", "pointer-events-none");
              viewGrid.classList.remove("flex", "h-auto");
              viewGrid.style.height = "0";

              viewFeed.classList.remove(
                "hidden",
                "opacity-0",
                "translate-y-8",
                "pointer-events-none",
              );
              viewFeed.classList.add("flex", "opacity-100", "translate-y-0");
            } else {
              viewFeed.classList.add("hidden", "opacity-0", "translate-y-8", "pointer-events-none");
              viewFeed.classList.remove("flex", "opacity-100", "translate-y-0");

              viewGrid.classList.remove("hidden", "pointer-events-none");
              viewGrid.style.height = "auto";
              void viewGrid.offsetWidth; // force reflow
              viewGrid.classList.add("flex", "opacity-100");
              viewGrid.classList.remove("translate-y-8");
            }
            localStorage.setItem("article-view", isFeed ? "feed" : "grid");

            setTimeout(() => window.dispatchEvent(new Event("resize")), 50); // recalculate highlights
          };

          applyView();
          btnFeed.addEventListener("click", () => {
            if (!isFeed) {
              isFeed = true;
              applyView();
            }
          });
          btnGrid.addEventListener("click", () => {
            if (isFeed) {
              isFeed = false;
              applyView();
            }
          });

          // Hover sliding effect for view toggle
          const toggleBtns = [btnFeed, btnGrid];
          toggleBtns.forEach((btn) => {
            btn.addEventListener("mouseenter", () => {
              toggleBg.style.transform = btn === btnFeed ? "translateX(0)" : "translateX(38px)";
              toggleBg.style.transitionDuration = "400ms"; // slightly faster on hover
            });

            btn.addEventListener("mouseleave", () => {
              toggleBg.style.transform = isFeed ? "translateX(0)" : "translateX(38px)";
              toggleBg.style.transitionDuration = "500ms"; // restore active transition speed
            });
          });
        }

        // Unified Category Filter Logic
        const btnActiveClasses = "active-item text-blue-600 dark:text-blue-400 font-bold group"
          .split(" ")
          .filter(Boolean);
        const btnInactiveClasses =
          "text-apple-textMuted dark:text-apple-darkTextMuted font-medium group"
            .split(" ")
            .filter(Boolean);

        const catBtns = document.querySelectorAll(".cat-filter");
        const gridItems = document.querySelectorAll(".article-grid-item");
        const feedItems = document.querySelectorAll(".post-detail");

        catBtns.forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.preventDefault();
            const targetBtn = e.currentTarget as HTMLElement;
            const filter = targetBtn.dataset.filter;
            const filterCat = targetBtn.dataset.filterCat;
            const filterSub = targetBtn.dataset.filterSub;

            catBtns.forEach((b) => {
              b.classList.remove(...btnActiveClasses);
              b.classList.add(...btnInactiveClasses);
            });

            btn.classList.add(...btnActiveClasses);
            btn.classList.remove(...btnInactiveClasses);

            // Sub-list toggle logic
            document.querySelectorAll(".sub-list").forEach((list) => {
              list.classList.add("hidden");
              list.classList.remove("flex");
            });

            if (filterCat) {
              const group = document.querySelector(
                `.category-group[data-group-cat="${filterCat}"]`,
              );
              if (group) {
                const subList = group.querySelector(".sub-list");
                if (subList) {
                  subList.classList.remove("hidden");
                  subList.classList.add("flex");
                }
              }
            }

            const matches = (el: HTMLElement) => {
              if (filter === "all") return true;
              if (filterSub) {
                return el.dataset.category === filterCat && el.dataset.subcategory === filterSub;
              }
              return el.dataset.category === filterCat;
            };

            // Filter Grid & Feed Views (Simplified merge)
            const allItems = [...gridItems, ...feedItems];
            allItems.forEach((item) => {
              const el = item as HTMLElement;
              if (matches(el)) {
                el.style.display = "";
                setTimeout(() => {
                  el.style.opacity = "1";
                  el.style.transform = "translateY(0) scale(1)";
                }, 50);
              } else {
                el.style.opacity = "0";
                el.style.transform = "translateY(10px) scale(0.98)";
                setTimeout(() => {
                  el.style.display = "none";
                }, 400);
              }
            });

            // Dispatch update event for sliding highlight recalculation
            // Needs a brief delay for sub-list expansion to finish layout
            setTimeout(() => {
              document.dispatchEvent(new Event("update-sliders"));
            }, 10);
          });
        });

        // Code Block Copy Animation
        const preTags = document.querySelectorAll(".prose pre");
        preTags.forEach((pre) => {
          const parent = pre.parentNode as HTMLElement;
          if (!parent || parent.classList.contains("code-block-wrapper")) return;
          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper relative mt-6 mb-6 group";
          parent.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);
          const copyBtn = document.createElement("button");
          copyBtn.className =
            "copy-btn absolute top-2 right-2 px-3 py-1 bg-white/10 hover:bg-white/20 text-white/50 hover:text-white text-[11px] font-mono rounded backdrop-blur-md transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10";
          copyBtn.textContent = "Copy";
          copyBtn.addEventListener("click", async () => {
            const codeText = pre.textContent || "";
            await navigator.clipboard.writeText(codeText);
            copyBtn.textContent = "Copied!";
            setTimeout(() => (copyBtn.textContent = "Copy"), 2000);
          });
          wrapper.appendChild(copyBtn);
        });
      });
    </script>
  </div>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = [
    {
      slug: "ai-canvas-writer",
      title: "AI Canvas Writer",
      description: "로직 노드 기반의 시각적 AI 프롬프트 에디터 도구입니다.",
      tags: ["React", "Zustand", "TailwindCSS"],
      year: "2026",
      image:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuD6TjGTWs53bAhDdSkfxKbZdM2TzdQI_ZJtmDiDK-bbOzPxxSssBUA9FGmSjTtwcgK7txfWRF9vt7TvbvgbPq1PuassGBT7NETRH7F8x-cNetH-9yuMvSaiweyZStMjrtnCbvCfhkcgQ8Kyf4uE9HpJkV3GYFlP7w4aCH8Yn3tshg_UDfWDNBnT5BEM4cw804ZWp6CEeh2apzFDSwCCB2W7VEJcZe43KkAhavwv3opq_ebTxM_VC5EKdLBDvyn4K0p49vYkMzWJkVnJ",
      content: `<h2>Project Overview</h2>
<p>이 프로젝트는 AI 프롬프트를 시각적으로 관리하기 위해 만들어졌습니다. 기존의 텍스트 기반 에디터에서 벗어나 노드 기반의 그래프 형태를 차용했습니다.</p>
<h3>Features</h3>
<ul>
<li>노드 기반 비주얼 에디팅</li>
<li>백그라운드 자동 저장 기능</li>
<li>실시간 AI 응답 프리뷰</li>
</ul>
<h3>Tech Stack</h3>
<p>Frontend: React, Zustand, TailwindCSS<br/>Backend: Node.js, Express</p>`,
    },
    {
      slug: "devjournal-cli",
      title: "DevJournal CLI",
      description: "마크다운 포스트 작성 및 Vercel 환경 배포 시스템.",
      tags: ["Rust", "CLI", "Astro"],
      year: "2025",
      image:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuC5AEbqrNzQ1-SvYIJIWt1EuApIbBHl_HBblfMw96fDdkS7EzKHu6Zew16nnCG6WbwvC3aqDeHI0EFJeqB14NjzgjVvsEn67XJU_OV4uJscdG7XFLkIoYOclpv1m1ZPOgQLmeus5zT3nsjuPlZHEPgM298MUI-3mJiEwc_byTMWwtC93z0TzmIsh5nzbS8zndKZ_aGWJls6nfuWluG_lw7BqYVGhrj0lt521kef-xRmkyI83OhraLasbTeVB6f6BhrrLNwvuj8SjvMu",
      content: `<h2>Project Overview</h2>
<p>DevJournal CLI는 터미널 마니아들을 위한 문서 관리 도구입니다.</p>
<h3>Features</h3>
<ul>
<li><code>dj new</code> 명령어로 템플릿 생성</li>
<li>Vercel 연동으로 즉시 자동 배포</li>
<li>오프라인 마크다운 프리뷰 지원 터미널 UI</li>
</ul>`,
    },
    {
      slug: "minimal-system",
      title: "Minimal System",
      description: "사내 공통 디자인 시스템 컴포넌트 프레임워크.",
      tags: ["Storybook", "Figma", "CSS"],
      year: "2024",
      image:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuC4eQMIkMBmHMy3whVOgSHFkBGYJ9Bcspd0PMXpnMrd2KLWPfT10Pbd5wWQ3W_-bRtrli8_P0ppaeAg_NZqzjWFAxixxlsgUYzpY98m81uCXn5c7sIAikTX7ioocJTKj9q0XPdEpQMU482kUmXh5zaDUW5GWUUcaHRsucLRWdzAepOgcw57JITm-UG49TI_cYso5dZR_hdhjWj2vogjS1-mnyOqLOu4elVXDrOKtj7gj6NU_eN_ykKRC-CtszyDvnJfT3zZqynw0Pst",
      content: `<h2>Project Overview</h2>
<p>단순함을 모토로 한 디자인 시스템입니다. 애플의 Glassmorphism과 예술적 에디토리얼 테마를 컴포넌트로 규격화했습니다.</p>
<h3>Highlights</h3>
<ul>
<li>Zero dependencies for Core Components</li>
<li>100% Custom CSS Variables with Vanilla JavaScript</li>
<li>Accessibility friendly & Responsive UI</li>
</ul>`,
    },
  ];

  return projects.map((proj) => ({
    params: { slug: proj.slug },
    props: { project: proj },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} | DEVARCHIVE`} description={project.description}>
  <main class="w-full min-h-screen pt-[15vh] pb-32 px-6 md:px-12 lg:px-24 max-w-5xl mx-auto">
    <!-- Breadcrumb & Nav -->
    <div class="mb-12 reveal-up">
      <a
        href="/project"
        class="inline-flex items-center gap-2 text-sm font-sans uppercase tracking-widest font-bold opacity-60 hover:opacity-100 transition-opacity"
      >
        <span class="material-symbols-outlined text-[16px]">arrow_back</span>
        All Works
      </a>
    </div>

    <!-- Header -->
    <header class="mb-16 reveal-up stagger-1">
      <div class="flex items-center gap-4 mb-6">
        <span class="glass-pill px-4 py-1 text-sm font-bold opacity-80">{project.year}</span>
        <div class="flex gap-2">
          {
            project.tags.map((tag) => (
              <span class="border border-border-color px-2 py-1 text-xs uppercase font-sans font-bold tracking-widest">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
      <h1 class="text-5xl md:text-7xl font-serif font-black tracking-tighter mb-6 break-keep">
        {project.title}
      </h1>
      <p class="text-xl md:text-2xl font-sans opacity-80 max-w-2xl leading-relaxed break-keep">
        {project.description}
      </p>
    </header>

    <!-- Hero Image -->
    <div
      class="w-full h-auto md:h-[60vh] rounded-[2.5rem] overflow-hidden mb-16 reveal-up stagger-2 glass-panel p-2 shadow-2xl"
    >
      <img
        src={project.image}
        alt={project.title}
        class="w-full h-full object-cover rounded-[2rem] grayscale-[0.2]"
      />
    </div>

    <!-- Content (Prose) -->
    <article class="prose max-w-3xl mx-auto reveal-up stagger-3" set:html={project.content} />
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));
    });
  </script>
</BaseLayout>

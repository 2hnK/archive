---
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = [
    {
      slug: "ai-canvas-writer",
      title: "AI Canvas Writer",
      description: "로직 노드 기반의 시각적 AI 프롬프트 에디터 도구입니다.",
      tags: ["React", "Zustand", "TailwindCSS"],
      year: "2026",
      image:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuD6TjGTWs53bAhDdSkfxKbZdM2TzdQI_ZJtmDiDK-bbOzPxxSssBUA9FGmSjTtwcgK7txfWRF9vt7TvbvgbPq1PuassGBT7NETRH7F8x-cNetH-9yuMvSaiweyZStMjrtnCbvCfhkcgQ8Kyf4uE9HpJkV3GYFlP7w4aCH8Yn3tshg_UDfWDNBnT5BEM4cw804ZWp6CEeh2apzFDSwCCB2W7VEJcZe43KkAhavwv3opq_ebTxM_VC5EKdLBDvyn4K0p49vYkMzWJkVnJ",
      content: `<h2>Project Overview</h2>
<p>이 프로젝트는 AI 프롬프트를 시각적으로 관리하기 위해 만들어졌습니다. 기존의 텍스트 기반 에디터에서 벗어나 노드 기반의 그래프 형태를 차용했습니다.</p>
<h3>Features</h3>
<ul>
<li>노드 기반 비주얼 에디팅</li>
<li>백그라운드 자동 저장 기능</li>
<li>실시간 AI 응답 프리뷰</li>
</ul>
<h3>Tech Stack</h3>
<p>Frontend: React, Zustand, TailwindCSS<br/>Backend: Node.js, Express</p>`,
    },
    {
      slug: "devjournal-cli",
      title: "DevJournal CLI",
      description: "마크다운 포스트 작성 및 Vercel 환경 배포 시스템.",
      tags: ["Rust", "CLI", "Astro"],
      year: "2025",
      image:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuC5AEbqrNzQ1-SvYIJIWt1EuApIbBHl_HBblfMw96fDdkS7EzKHu6Zew16nnCG6WbwvC3aqDeHI0EFJeqB14NjzgjVvsEn67XJU_OV4uJscdG7XFLkIoYOclpv1m1ZPOgQLmeus5zT3nsjuPlZHEPgM298MUI-3mJiEwc_byTMWwtC93z0TzmIsh5nzbS8zndKZ_aGWJls6nfuWluG_lw7BqYVGhrj0lt521kef-xRmkyI83OhraLasbTeVB6f6BhrrLNwvuj8SjvMu",
      content: `<h2>Project Overview</h2>
<p>DevJournal CLI는 터미널 마니아들을 위한 문서 관리 도구입니다.</p>
<h3>Features</h3>
<ul>
<li><code>dj new</code> 명령어로 템플릿 생성</li>
<li>Vercel 연동으로 즉시 자동 배포</li>
<li>오프라인 마크다운 프리뷰 지원 터미널 UI</li>
</ul>`,
    },
    {
      slug: "minimal-system",
      title: "Minimal System",
      description: "사내 공통 디자인 시스템 컴포넌트 프레임워크.",
      tags: ["Storybook", "Figma", "CSS"],
      year: "2024",
      image:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuC4eQMIkMBmHMy3whVOgSHFkBGYJ9Bcspd0PMXpnMrd2KLWPfT10Pbd5wWQ3W_-bRtrli8_P0ppaeAg_NZqzjWFAxixxlsgUYzpY98m81uCXn5c7sIAikTX7ioocJTKj9q0XPdEpQMU482kUmXh5zaDUW5GWUUcaHRsucLRWdzAepOgcw57JITm-UG49TI_cYso5dZR_hdhjWj2vogjS1-mnyOqLOu4elVXDrOKtj7gj6NU_eN_ykKRC-CtszyDvnJfT3zZqynw0Pst",
      content: `<h2>Project Overview</h2>
<p>단순함을 모토로 한 디자인 시스템입니다. 애플의 Glassmorphism과 예술적 에디토리얼 테마를 컴포넌트로 규격화했습니다.</p>
<h3>Highlights</h3>
<ul>
<li>Zero dependencies for Core Components</li>
<li>100% Custom CSS Variables with Vanilla JavaScript</li>
<li>Accessibility friendly & Responsive UI</li>
</ul>`,
    },
  ];

  return projects.map((proj) => ({
    params: { slug: proj.slug },
    props: { project: proj },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} | DEVARCHIVE`} description={project.description}>
  <main class="w-full min-h-screen pt-[18vh] pb-32 px-6 md:px-12 lg:px-24">
    <div class="max-w-[1400px] mx-auto">
      <!-- Top Navigation -->
      <nav class="mb-20 reveal-up flex justify-between items-center">
        <a
          href="/project"
          class="group inline-flex items-center gap-3 text-[10px] font-sans uppercase tracking-[0.2em] font-bold opacity-60 hover:opacity-100 transition-all"
        >
          <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
          Back to Archives
        </a>
        <div class="hidden md:flex items-center gap-4 text-[10px] font-bold opacity-40 uppercase tracking-[0.2em]">
          <span>Project Details</span>
          <div class="w-12 h-[1px] bg-text-color opacity-30"></div>
          <span>{project.year}</span>
        </div>
      </nav>

      <!-- Editorial Header -->
      <header class="mb-24 reveal-up stagger-1">
        <div class="flex flex-wrap items-center gap-2 mb-10">
          <span class="glass-pill px-4 py-1 text-[10px] font-bold border border-text-color/10 opacity-60 uppercase tracking-widest">{project.year} Edition</span>
          {
            project.tags.map((tag) => (
              <span class="border border-text-color/10 rounded-full px-4 py-1 text-[10px] uppercase font-sans font-bold tracking-widest opacity-40">
                {tag}
              </span>
            ))
          }
        </div>
        
        <h1 class="text-6xl md:text-[9.5rem] font-serif font-black tracking-tighter leading-[0.85] mb-12 break-keep reveal-up stagger-2">
          {project.title}
        </h1>
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end reveal-up stagger-3">
          <p class="lg:col-span-8 text-xl md:text-3xl font-sans opacity-70 leading-tight tracking-tight break-keep italic py-4 border-l-4 border-accent-color pl-8">
            {project.description}
          </p>
          <div class="lg:col-span-4 flex flex-col gap-2 text-[11px] font-bold uppercase tracking-widest opacity-50 text-right">
             <p>Project Archive Code</p>
             <p class="text-2xl font-serif tracking-tighter opacity-100 text-text-color">PRJ-{project.slug.split('-')[0].toUpperCase()}</p>
          </div>
        </div>
      </header>

      <!-- Hero Gallery Frame -->
      <section class="mb-32 reveal-up stagger-4">
        <div class="relative glass-panel p-3 md:p-5 rounded-[3rem] shadow-[0_40px_100px_-20px_rgba(0,0,0,0.1)] overflow-hidden transition-all duration-700 hover:shadow-accent-color/5">
          <div class="w-full h-auto md:h-[75vh] overflow-hidden rounded-[2.2rem]">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover grayscale-[0.3] hover:grayscale-0 scale-105 hover:scale-100 transition-all duration-1000 ease-out"
            />
          </div>
          <!-- Corner Accents -->
          <div class="absolute top-8 right-8 text-[10px] font-black opacity-20 uppercase tracking-[0.4em] rotate-90 origin-right">Digital Experience</div>
        </div>
      </section>

      <!-- Content Narrative Area -->
      <section class="grid grid-cols-1 lg:grid-cols-12 gap-20">
        <!-- Sidebar Meta -->
        <aside class="lg:col-span-4 reveal-up order-2 lg:order-1">
          <div class="sticky top-32 flex flex-col gap-12">
            <div>
              <h4 class="text-[10px] font-black uppercase tracking-[0.3em] opacity-30 mb-6 border-b border-text-color/10 pb-2">Core Categories</h4>
              <div class="flex flex-wrap gap-2">
                {project.tags.map(tag => (
                   <span class="text-xs font-bold font-sans tracking-tight opacity-80">{tag} /</span>
                ))}
              </div>
            </div>
            <div>
              <h4 class="text-[10px] font-black uppercase tracking-[0.3em] opacity-30 mb-6 border-b border-text-color/10 pb-2">Archival Note</h4>
              <p class="text-sm font-sans leading-relaxed opacity-60">
                This project represents a milestone in my creative journey, exploring the boundaries between functional logic and artistic expression in the digital realm.
              </p>
            </div>
            <div class="pt-8 opacity-20">
               <span class="material-symbols-outlined text-6xl">all_inclusive</span>
            </div>
          </div>
        </aside>

        <!-- Main Prose Content -->
        <div class="lg:col-span-8 reveal-up stagger-1 order-1 lg:order-2">
          <article class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-serif prose-headings:tracking-tighter prose-p:leading-relaxed prose-p:text-text-color/80" set:html={project.content} />
          
          <!-- Bottom Navigation -->
          <div class="mt-32 pt-16 border-t border-text-color/10 flex justify-between items-center">
            <div class="text-[10px] font-black uppercase tracking-[0.3em] opacity-30">End of Record</div>
            <a href="/project" class="text-xs font-bold uppercase tracking-widest hover:text-accent-color transition-colors">Return to Showcase →</a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));
    });
  </script>
</BaseLayout>

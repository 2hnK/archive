---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeProgress from "../components/TimeProgress.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestArticles = sortedArticles.slice(0, 15); // Show more articles in the board

const categories = Array.from(new Set(allArticles.map((a) => a.data.category))).sort();
---

<BaseLayout title="DevArchive" description="개발 아카이브">
  <main class="pb-24" style="padding-top: 140px;">
    <section class="max-w-[1100px] mx-auto px-6 reveal-up md:flex md:items-start md:gap-x-16">
      <!-- Left Sidebar -->
      <div class="mb-16 md:mb-0 w-full md:w-[240px] flex-shrink-0 md:sticky md:top-32">
        <div class="mb-12">
          <span
            class="text-[10px] uppercase tracking-[0.25em] font-bold text-apple-textMuted dark:text-apple-darkTextMuted block mb-4"
          >
            Explore Topics
          </span>
          <div class="flex flex-wrap gap-2">
            {
              categories.map((cat) => (
                <a
                  href={`/articles`}
                  class="glass-pill px-4 py-1.5 text-[11px] font-bold tracking-widest text-apple-text dark:text-apple-darkText hover:text-[#1e66f5] dark:hover:text-[#89b4fa] hover:bg-white dark:hover:bg-white/10 transition-all duration-300 transform hover:scale-[1.05] uppercase border-black/5 dark:border-white/10 shadow-md"
                >
                  {cat}
                </a>
              ))
            }
          </div>
        </div>

        <div>
          <TimeProgress mini={true} />
        </div>
      </div>

      <!-- Main Column: Board View Articles -->
      <div class="flex-1 w-full relative">
        <div
          class="flex justify-between items-end mb-8 border-b border-apple-border dark:border-apple-darkBorder pb-4"
          style="padding-bottom: 8px;"
        >
          <div>
            <span
              class="text-[10px] uppercase tracking-[0.25em] font-bold text-apple-textMuted dark:text-apple-darkTextMuted block mb-2"
              >Latest Articles</span
            >
            <h2 class="text-2xl font-bold tracking-tight text-apple-text dark:text-apple-darkText">
              최근 포스트
            </h2>
          </div>
          <a href="/articles" class="btn-premium group text-[12px] px-3.5 py-2">
            아티클 전체 보기
            <span
              class="material-symbols-outlined text-[15px] group-hover:translate-x-1 transition-transform"
              >arrow_forward</span
            >
          </a>
        </div>

        <div class="flex flex-col gap-1">
          {
            latestArticles.map((article) => (
              <a
                href={`/articles/${article.id}`}
                class="group flex flex-col sm:flex-row sm:items-center justify-between py-3 px-3 sm:px-4 rounded-2xl border border-transparent transition-all duration-300 hover:bg-white/70 dark:hover:bg-white/[0.05] hover:backdrop-blur-xl hover:shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:border-black/5 dark:hover:border-white/5"
              >
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6">
                  <span class="text-[9.5px] font-bold uppercase tracking-[0.15em] text-[#1e66f5] dark:text-[#89b4fa] w-[110px] shrink-0 sm:text-right mt-1 sm:mt-0">
                    {article.data.category}
                  </span>
                  <h3 class="text-[13px] xl:text-[14px] font-semibold text-apple-text dark:text-apple-darkText group-hover:translate-x-1 transition-transform duration-300 leading-snug break-keep">
                    {article.data.title}
                  </h3>
                </div>
                <div class="flex items-center gap-4 mt-2 sm:mt-0">
                  <span class="text-[11px] font-medium text-apple-textMuted dark:text-apple-darkTextMuted tabular-nums">
                    {article.data.date
                      .toLocaleDateString("ko-KR", {
                        year: "numeric",
                        month: "2-digit",
                        day: "2-digit",
                      })
                      .replace(/\./g, "-")
                      .replace(/ /g, "")
                      .slice(0, -1)}
                  </span>
                  <span class="material-symbols-outlined text-[15px] text-[#1e66f5] dark:text-[#89b4fa] opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                    arrow_forward
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
      <!-- End of Main Column -->
    </section>
  </main>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const revealObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active", "translate-y-0", "opacity-100");
            entry.target.classList.remove("translate-y-8", "opacity-0");
            observer.unobserve(entry.target);
          }
        });
      },
      { root: null, rootMargin: "0px 0px 100px 0px", threshold: 0 },
    );

    const els = document.querySelectorAll(".reveal-up, .fade-in-up");
    els.forEach((el) => {
      // Only hide if not already marked active (prevent double-hide on route change)
      if (!el.classList.contains("active")) {
        el.classList.add(
          "transition-all",
          "duration-1000",
          "ease-[cubic-bezier(0.16,1,0.3,1)]",
          "opacity-0",
          "translate-y-8",
        );
      }
      revealObserver.observe(el);
    });
  });
</script>

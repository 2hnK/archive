---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import hanbatLogo from "../assets/hanbat_logo.svg";
import ssafyLogo from "../assets/ssafy_logo.svg";
import kicsLogo from "../assets/kics_logo.jpg";
import engineerLogo from "../assets/engineer_information_processing_logo.png";
import sqldLogo from "../assets/sqld_logo.png";

const projects = [
  {
    title: "AI Canvas Writer",
    description:
      "로직 노드 기반의 시각적 AI 프롬프트 에디터 도구입니다. 복잡한 시스템 프롬프팅 아키텍처를 시각화하여 사용성을 극대화했습니다.",
    tags: ["React", "Zustand", "TailwindCSS"],
    url: "#",
    year: "2026",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuD6TjGTWs53bAhDdSkfxKbZdM2TzdQI_ZJtmDiDK-bbOzPxxSssBUA9FGmSjTtwcgK7txfWRF9vt7TvbvgbPq1PuassGBT7NETRH7F8x-cNetH-9yuMvSaiweyZStMjrtnCbvCfhkcgQ8Kyf4uE9HpJkV3GYFlP7w4aCH8Yn3tshg_UDfWDNBnT5BEM4cw804ZWp6CEeh2apzFDSwCCB2W7VEJcZe43KkAhavwv3opq_ebTxM_VC5EKdLBDvyn4K0p49vYkMzWJkVnJ",
  },
  {
    title: "DevJournal CLI",
    description:
      "터미널에서 직접 마크다운 포스트를 작성하고 Vercel 환경으로 자동 배포하는 서버리스 데스크탑 관리 시스템입니다.",
    tags: ["Rust", "CLI", "Astro", "Vercel"],
    url: "#",
    year: "2025",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuC5AEbqrNzQ1-SvYIJIWt1EuApIbBHl_HBblfMw96fDdkS7EzKHu6Zew16nnCG6WbwvC3aqDeHI0EFJeqB14NjzgjVvsEn67XJU_OV4uJscdG7XFLkIoYOclpv1m1ZPOgQLmeus5zT3nsjuPlZHEPgM298MUI-3mJiEwc_byTMWwtC93z0TzmIsh5nzbS8zndKZ_aGWJls6nfuWluG_lw7BqYVGhrj0lt521kef-xRmkyI83OhraLasbTeVB6f6BhrrLNwvuj8SjvMu",
  },
  {
    title: "Minimal Design System",
    description:
      "디자이너와 개발자 사이의 간극을 완전히 좁히기 위한 Tailwind CSS 기반 사내 공통 디자인 시스템 컴포넌트 프레임워크입니다.",
    tags: ["Storybook", "Figma", "Design", "CSS"],
    url: "#",
    year: "2024",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuC4eQMIkMBmHMy3whVOgSHFkBGYJ9Bcspd0PMXpnMrd2KLWPfT10Pbd5wWQ3W_-bRtrli8_P0ppaeAg_NZqzjWFAxixxlsgUYzpY98m81uCXn5c7sIAikTX7ioocJTKj9q0XPdEpQMU482kUmXh5zaDUW5GWUUcaHRsucLRWdzAepOgcw57JITm-UG49TI_cYso5dZR_hdhjWj2vogjS1-mnyOqLOu4elVXDrOKtj7gj6NU_eN_ykKRC-CtszyDvnJfT3zZqynw0Pst",
  },
];
---

<BaseLayout
  title="소개 | DevArchive"
  description="시스템 설계와 인간 중심의 의도에 대해 고민합니다."
>
  <main>
    <!-- Minimal Hero Section -->
    <section
      class="max-w-[900px] mx-auto px-0 pt-20 pb-10 fade-in-up md:pt-30 mt-4 md:mt-0 flex flex-col sm:flex-row sm:items-center gap-6 md:gap-16"
    >
      <!-- Profile Image Container -->
      <div
        class="w-24 h-24 sm:w-[120px] sm:h-[120px] rounded-[1.8rem] bg-gradient-to-br from-black/5 to-black/10 dark:from-white/5 dark:to-white/10 border border-black/5 dark:border-white/5 shadow-sm overflow-hidden flex-shrink-0 relative group flex items-center justify-center cursor-default"
      >
        <!-- Placeholder Icon. TODO: 교체할 실제 프로필 이미지가 있다면 이 위치에 <img> 태그나 <Image> 컴포넌트를 사용하세요. -->
        <span
          class="material-symbols-outlined text-[2.5rem] opacity-40 text-apple-text dark:text-apple-darkText transition-transform duration-500 group-hover:scale-110"
        >
          person
        </span>
      </div>

      <!-- Hero Text -->
      <div class="flex-1">
        <h1
          class="text-2xl sm:text-xl font-bold tracking-tight text-apple-text dark:text-apple-darkText mb-1 leading-snug break-keep"
        >
          안녕하세요.
          <!-- <span class="text-apple-textMuted dark:text-apple-darkTextMuted"
            >소프트웨어 개발자입니다.</span
          > -->
        </h1>
        <p
          class="text-[14px] md:text-[15px] text-apple-textMuted dark:text-apple-darkTextMuted font-medium leading-relaxed max-w-xl break-keep"
        >
          겉으로 보이는 결과보다 과정과 본질적인 것이 더 중요하다고 생각하여,<br />
          조금은 느리더라도 최대한 작은 문제 하나하나를 놓치지 않으려고 합니다.
        </p>
      </div>
    </section>

    <div class="bg-apple-background dark:bg-apple-darkBackground transition-colors pt-4 pb-12">
      <section class="max-w-[1000px] mx-auto px-6 mb-16 md:flex md:items-start md:gap-x-12">
        <div class="mb-4 md:mb-0 reveal-up shrink-0 md:w-[150px]">
          <span
            class="text-[9px] tracking-[0.15em] font-bold uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-1 block"
            >Capabilities</span
          >
          <h2
            class="text-xl md:text-2xl font-bold tracking-tight text-apple-text dark:text-apple-darkText md:leading-[1.15] break-keep"
          >
            역량 및 자격
          </h2>
        </div>

        <div
          class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-4 auto-rows-[minmax(140px,auto)] w-full"
        >
          <!-- Core Stack (Span 1) -->
          <div class="sm:col-span-1 glass-panel p-6 reveal-up flex flex-col justify-between">
            <div class="mb-4">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-[10px] font-bold tracking-wider uppercase mb-1 block"
                >Foundations</span
              >
              <h3 class="text-[17px] font-bold text-apple-text dark:text-apple-darkText">
                Core Stack
              </h3>
            </div>
            <div class="flex flex-wrap gap-2.5">
              <!-- Java -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#E44E004D] dark:hover:[--pill-glow:0_8px_20px_#E44E0066] ring-1 ring-transparent hover:ring-[#E44E00]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg"
                  alt="Java"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >Java</span
                >
              </div>
              <!-- Python -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#3776AB4D] dark:hover:[--pill-glow:0_8px_20px_#3776AB66] ring-1 ring-transparent hover:ring-[#3776AB]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
                  alt="Python"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >Python</span
                >
              </div>
              <!-- Spring -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#6DB33F4D] dark:hover:[--pill-glow:0_8px_20px_#6DB33F66] ring-1 ring-transparent hover:ring-[#6DB33F]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg"
                  alt="Spring"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >Spring</span
                >
              </div>
            </div>
          </div>

          <!-- AI Ecosystem (Span 1) -->
          <div
            class="sm:col-span-1 glass-panel p-6 reveal-up stagger-1 flex flex-col justify-between"
          >
            <div class="mb-4">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-[10px] font-bold tracking-wider uppercase mb-1 block"
                >Learning</span
              >
              <h3 class="text-[17px] font-bold text-apple-text dark:text-apple-darkText">
                AI Ecosystem
              </h3>
            </div>
            <div class="flex flex-wrap gap-2.5">
              <!-- Spring AI -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#6DB33F4D] dark:hover:[--pill-glow:0_8px_20px_#6DB33F66] ring-1 ring-transparent hover:ring-[#6DB33F]/40 cursor-default transition-all duration-300 opacity-80"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg"
                  alt="Spring AI"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >Spring AI</span
                >
              </div>
              <!-- LangChain -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#1E824C4D] dark:hover:[--pill-glow:0_8px_20px_#1E824C66] ring-1 ring-transparent hover:ring-[#1E824C]/40 cursor-default transition-all duration-300 opacity-80"
              >
                <svg
                  fill="currentColor"
                  role="img"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-[24px] h-[24px]"
                >
                  <title>LangChain</title>
                  <path
                    d="M6.0988 5.9175C2.7359 5.9175 0 8.6462 0 12s2.736 6.0825 6.0988 6.0825h11.8024C21.2641 18.0825 24 15.3538 24 12s-2.736-6.0825-6.0988-6.0825ZM5.9774 7.851c.493.0124 1.02.2496 1.273.6228.3673.4592.4778 1.0668.8944 1.4932.5604.6118 1.199 1.1505 1.7161 1.802.4892.5954.8386 1.2937 1.1436 1.9975.1244.2335.1257.5202.31.7197.0908.1204.5346.4483.4383.5645.0555.1204.4702.286.3263.4027-.1944.04-.4129.0476-.5616-.1074-.0549.126-.183.0596-.2819.0432a4 4 0 0 0-.025.0736c-.3288.0219-.5754-.3126-.732-.565-.3111-.168-.6642-.2702-.982-.446-.0182.2895.0452.6485-.231.8353-.014.5565.8436.0656.9222.4804-.061.0067-.1286-.0095-.1774.0373-.2239.2172-.4805-.1645-.7385-.007-.3464.174-.3808.3161-.8096.352-.0237-.0359-.0143-.0592.0059-.0811.1207-.1399.1295-.3046.3356-.3643-.2122-.0334-.3899.0833-.5686.1757-.2323.095-.2304-.2141-.5878.0164-.0396-.0322-.0208-.0615.0018-.0864.0908-.1107.2102-.127.345-.1208-.663-.3686-.9751.4507-1.2813.0432-.092.0243-.1265.1068-.1845.1652-.05-.0548-.0123-.1212-.0099-.1857-.0598-.028-.1356-.041-.1179-.1366-.1171-.0395-.1988.0295-.286.0952-.0787-.0608.0532-.1492.0776-.2125.0702-.1216.23-.025.3111-.1126.2306-.1308.552.0814.8155.0455.203.0255.4544-.1825.3526-.39-.2171-.2767-.179-.6386-.1839-.9695-.0268-.1929-.491-.4382-.6252-.6462-.1659-.1873-.295-.4047-.4243-.6182-.4666-.9008-.3198-2.0584-.9077-2.8947-.266.1466-.6125.0774-.8418-.119-.1238.1125-.1292.2598-.139.4161-.297-.2962-.2593-.8559-.022-1.1855.0969-.1302.2127-.2373.342-.3316.0292-.0213.0391-.0419.0385-.0747.1174-.5267.5764-.7391 1.0694-.7267m12.4071.46c.5575 0 1.0806.2159 1.474.6082s.61.9145.61 1.4704c0 .556-.2167 1.078-.61 1.4698v.0006l-.902.8995a2.08 2.08 0 0 1-.8597.5166l-.0164.0047-.0058.0164a2.05 2.05 0 0 1-.474.7308l-.9018.8995c-.3934.3924-.917.6083-1.4745.6083s-1.0806-.216-1.474-.6083c-.813-.8107-.813-2.1294 0-2.9402l.9019-.8995a2.056 2.056 0 0 1 .858-.5143l.017-.0053.0058-.0158a2.07 2.07 0 0 1 .4752-.7337l.9018-.8995c.3934-.3924.9171-.6083 1.4745-.6083zm0 .8965a1.18 1.18 0 0 0-.8388.3462l-.9018.8995a1.181 1.181 0 0 0-.3427.9252l.0053.0572c.0323.2652.149.5044.3374.6917.13.1296.2733.2114.4471.2686a.9.9 0 0 1 .014.1582.884.884 0 0 1-.2609.6304l-.0554.0554c-.3013-.1028-.5525-.253-.7794-.4792a2.06 2.06 0 0 1-.5761-1.0968l-.0099-.0578-.0461.0368a1.1 1.1 0 0 0-.0876.0794l-.9024.8995c-.4623.461-.4623 1.212 0 1.673.2311.2305.535.346.8394.3461.3043 0 .6077-.1156.8388-.3462l.9019-.8995c.4623-.461.4623-1.2113 0-1.673a1.17 1.17 0 0 0-.4367-.2749 1 1 0 0 1-.014-.1611c0-.2591.1023-.505.2901-.6923.3019.1028.57.2694.7962.495.3007.2999.4994.679.5756 1.0968l.0105.0578.0455-.0373a1.1 1.1 0 0 0 .0887-.0794l.902-.8996c.4622-.461.4628-1.2124 0-1.6735a1.18 1.18 0 0 0-.8395-.3462Zm-9.973 5.1567-.0006.0006c-.0793.3078-.1048.8318-.506.847-.033.1776.1228.2445.2655.1874.141-.0645.2081.0508.2557.1657.2177.0317.5394-.0725.5516-.3298-.325-.1867-.4253-.5418-.5662-.8709"
                  ></path>
                </svg>
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >LangChain</span
                >
              </div>
            </div>
          </div>

          <!-- Data Stores (Span 1) -->
          <div
            class="sm:col-span-1 glass-panel p-6 reveal-up stagger-2 flex flex-col justify-between"
          >
            <div class="mb-4">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-[10px] font-bold tracking-wider uppercase mb-1 block"
                >Storage</span
              >
              <h3 class="text-[17px] font-bold text-apple-text dark:text-apple-darkText">
                Data Stores
              </h3>
            </div>
            <div class="flex flex-wrap gap-2.5">
              <!-- MySQL -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#00758F4D] dark:hover:[--pill-glow:0_8px_20px_#00758F66] ring-1 ring-transparent hover:ring-[#00758F]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg"
                  alt="MySQL"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >MySQL</span
                >
              </div>
              <!-- PostgreSQL -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#3367914D] dark:hover:[--pill-glow:0_8px_20px_#33679166] ring-1 ring-transparent hover:ring-[#336791]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg"
                  alt="PostgreSQL"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >PostgreSQL</span
                >
              </div>
              <!-- Redis -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#DC3B224D] dark:hover:[--pill-glow:0_8px_20px_#DC3B2266] ring-1 ring-transparent hover:ring-[#DC3B22]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/redis/redis-original.svg"
                  alt="Redis"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >Redis</span
                >
              </div>
            </div>
          </div>

          <!-- Infrastructure (Span 1) -->
          <div
            class="sm:col-span-1 glass-panel p-6 reveal-up stagger-3 flex flex-col justify-between"
          >
            <div class="mb-4">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-[10px] font-bold tracking-wider uppercase mb-1 block"
                >Cloud & DevOps</span
              >
              <h3 class="text-[17px] font-bold text-apple-text dark:text-apple-darkText">
                Infrastructure
              </h3>
            </div>
            <div class="flex flex-wrap gap-2.5">
              <!-- Docker -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#2496ED4D] dark:hover:[--pill-glow:0_8px_20px_#2496ED66] ring-1 ring-transparent hover:ring-[#2496ED]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg"
                  alt="Docker"
                  class="w-[24px] h-[24px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >Docker</span
                >
              </div>
              <!-- AWS -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_#FF99004D] dark:hover:[--pill-glow:0_8px_20px_#FF990066] ring-1 ring-transparent hover:ring-[#FF9900]/40 cursor-default transition-all duration-300"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg"
                  alt="AWS"
                  class="w-[28px] h-[28px] object-contain"
                />
                <span class="font-semibold text-[13px] text-apple-text dark:text-apple-darkText"
                  >AWS</span
                >
              </div>
            </div>
          </div>

          <!-- Acquisitions / Certifications (Span 2) -->
          <div
            class="sm:col-span-2 glass-panel px-6 py-5 reveal-up flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6"
            style="height: 100px;"
          >
            <div class="flex-shrink-0">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-[10px] font-bold tracking-wider uppercase mb-1 block"
                >Milestones</span
              >
              <h3
                class="text-[17px] font-bold text-apple-text dark:text-apple-darkText leading-none"
              >
                Certifications
              </h3>
            </div>
            <div
              class="flex flex-col sm:flex-row gap-4 items-center sm:items-end justify-start sm:justify-end w-full"
            >
              <!-- 정보처리기사 -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_rgba(59,130,246,0.30)] dark:hover:[--pill-glow:0_8px_20px_rgba(59,130,246,0.40)] ring-1 ring-transparent hover:ring-blue-500/40 cursor-default transition-all duration-300"
              >
                <div
                  class="w-[30px] h-[30px] rounded-full bg-white dark:bg-apple-darkSurface flex flex-shrink-0 items-center justify-center border border-black/5 dark:border-white/10 overflow-hidden shadow-sm p-[3px] transition-shadow duration-300"
                >
                  <Image
                    src={engineerLogo}
                    alt="정보처리기사 로고"
                    class="w-full h-full object-contain rounded-full transition-transform duration-300"
                  />
                </div>
                <div class="flex flex-col justify-center leading-tight pt-0.5">
                  <h4
                    class="font-bold text-[13px] text-apple-text dark:text-apple-darkText transition-colors"
                  >
                    정보처리기사
                  </h4>
                  <span
                    class="text-[9px] font-medium text-apple-textMuted dark:text-apple-darkTextMuted block mt-0.5"
                    >2025.09.12</span
                  >
                </div>
              </div>
              <!-- SQLD -->
              <div
                class="flex items-center gap-2.5 glass-pill px-4 py-2.5 hover:-translate-y-1 hover:[--pill-glow:0_8px_20px_rgba(16,185,129,0.30)] dark:hover:[--pill-glow:0_8px_20px_rgba(16,185,129,0.40)] ring-1 ring-transparent hover:ring-emerald-500/40 cursor-default transition-all duration-300"
              >
                <div

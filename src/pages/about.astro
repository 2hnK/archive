---
import BaseLayout from "../layouts/BaseLayout.astro";

import ssafyLogo from "../assets/ssafy_logo.svg";
import hanbatLogo from "../assets/hanbat_logo.svg";
import kicsLogo from "../assets/kics_logo.jpg";
import sqldLogo from "../assets/sqld_logo.png";
import eipLogo from "../assets/engineer_information_processing_logo.png";

const timeline = [
  {
    year: "2026.06.26",
    desc: "SSAFY 1학기 프로젝트",
    detail: "생성형 AI와 공공데이터를 활용한 Soomgil 서비스로 1학기 관통 프로젝트 우수상 선정",
    logo: ssafyLogo,
    badge: "우수상",
  },
  {
    year: "2026.01 ~ 현재",
    desc: "삼성청년SW/AI아카데미(SSAFY)",
    detail: "체계적인 실무 중심의 교육을 통해 웹 개발 및 AI 활용 능력 역량 강화 및 알고리즘 문제 해결 능력 향상",
    logo: ssafyLogo,
  },
  {
    year: "2026.02",
    desc: "KICS 동계종합학술발표회",
    detail: "KICS 한국통신학회 · 2026년도 동계종합학술발표회(KICS Winter Conference 2026) - 비용효율적인 지능형 AICC를 위한 자가진화형 4계층 정규화 게이트",
    logo: kicsLogo,
    badge: "장려상",
  },
  {
    year: "2024.03 ~ 2026.02",
    desc: "국립한밭대학교 컴퓨터공학 학사 졸업",
    detail: "자료구조, 알고리즘 등 컴퓨터공학 전공 과정을 통해 소프트웨어 엔지니어링의 기본 소양 확립",
    logo: hanbatLogo,
  },
];

const certifications = [
  { item: "정보처리기사", date: "2025.09", desc: "한국산업인력공단", logo: eipLogo },
  { item: "SQLD", date: "2025.06", desc: "한국데이터산업진흥원", logo: sqldLogo },
];

const skillGroups = [
  {
    name: "Backend",
    description: "Server & Persistence",
    skills: [
      { name: "Java", icon: "https://cdn.simpleicons.org/openjdk" },
      { name: "Spring", icon: "https://cdn.simpleicons.org/spring" },
      { name: "Spring AI", icon: "https://cdn.simpleicons.org/spring" },
      { name: "JPA", icon: "https://cdn.simpleicons.org/hibernate" },
      { name: "MyBatis", icon: null },
    ],
  },
  {
    name: "AI",
    description: "Models & Orchestration",
    skills: [
      { name: "Python", icon: "https://cdn.simpleicons.org/python" },
      { name: "LangChain", icon: "https://cdn.simpleicons.org/langchain" },
    ],
  },
  {
    name: "Frontend",
    description: "Interface",
    skills: [{ name: "Vue", icon: "https://cdn.simpleicons.org/vuedotjs" }],
  },
  {
    name: "Data",
    description: "Storage & Cache",
    skills: [
      { name: "MySQL", icon: "https://cdn.simpleicons.org/mysql" },
      { name: "PostgreSQL", icon: "https://cdn.simpleicons.org/postgresql" },
      { name: "Redis", icon: "https://cdn.simpleicons.org/redis" },
    ],
  },
  {
    name: "Infra",
    description: "Build & Cloud",
    skills: [
      { name: "Docker", icon: "https://cdn.simpleicons.org/docker" },
      { name: "AWS", icon: "https://upload.wikimedia.org/wikipedia/commons/9/93/Amazon_Web_Services_Logo.svg" },
    ],
  },
];
---

<BaseLayout title="About | DEVARCHIVE" description="김지훈의 개발 경험과 기술 스택">
  <main class="w-full min-h-screen pb-32">
    <section class="relative w-full min-h-[68vh] flex flex-col items-center justify-center px-6 reveal-up overflow-hidden pt-24 pb-12 md:pt-28 md:pb-16">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] md:w-[45vw] md:h-[45vw] bg-accent-color/8 dark:bg-accent-color/15 rounded-full blur-[120px] pointer-events-none animate-pulse duration-1000"></div>

      <div class="relative z-10 mx-auto grid w-full max-w-4xl items-center gap-10 md:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)] md:gap-16">
        <figure class="glass-panel mx-auto w-full max-w-[280px] rounded-[2rem] p-2 shadow-xl transition-transform duration-700 md:max-w-none md:-rotate-1 hover:rotate-0">
          <img
            src="/images/profile.png"
            alt="김지훈 프로필"
            width="1086"
            height="1448"
            decoding="async"
            class="aspect-[3/4] w-full rounded-[1.5rem] object-cover object-center"
          />
        </figure>

        <div class="text-center md:text-left">
          <h1 class="mb-4 text-2xl md:text-3xl font-serif font-bold tracking-tight">안녕하세요, 김지훈입니다.</h1>
          <p class="text-base md:text-lg font-serif leading-relaxed opacity-80 italic pb-8 border-b border-border-color/30 px-4 md:px-0">
            "조금은 느리더라도 문제의 본질을<br class="hidden md:block" /> 놓치지 않는 개발자가 되겠습니다."
          </p>

          <div class="flex items-center justify-center md:justify-start gap-10 mt-8">
            <a
              href="mailto:kimgh921@gmail.com"
              data-copy-email
              class="flex flex-col items-center gap-3 opacity-50 hover:opacity-100 hover:text-accent-color hover:-translate-y-1 transition-all duration-300"
            >
              <span class="material-symbols-outlined text-[24px]">mail</span>
              <span class="email-text text-[10px] font-sans font-bold tracking-widest uppercase w-12 text-center mt-[1px]">Email</span>
            </a>
            <a href="https://github.com/2hnk" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-3 opacity-50 hover:opacity-100 hover:text-accent-color hover:-translate-y-1 transition-all duration-300 pt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
              <span class="text-[10px] font-sans font-bold tracking-widest uppercase mt-[1px]">Github</span>
            </a>
            <a href="https://www.instagram.com/__kimjihun" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-3 opacity-50 hover:opacity-100 hover:text-accent-color hover:-translate-y-1 transition-all duration-300 pt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              <span class="text-[10px] font-sans font-bold tracking-widest uppercase mt-[1px]">Instagram</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="w-full relative px-6 mt-16 md:mt-32 reveal-up max-w-5xl mx-auto">
      <div class="border-b border-border-color/60 pb-6 mb-4">
        <p class="text-[10px] font-sans font-bold opacity-40 tracking-[0.24em] uppercase mb-2">Trajectory</p>
        <h2 class="text-4xl md:text-5xl font-serif font-bold tracking-tight">Milestones</h2>
      </div>

      <div class="relative w-full">
        <div class="absolute left-[11px] md:left-[179px] top-0 bottom-0 w-[2px]" aria-hidden="true">
          <span class="absolute inset-0 bg-[var(--border-color)] opacity-20"></span>
          <span class="absolute inset-x-0 top-0 h-1/4 bg-[var(--accent-color)] opacity-70"></span>
        </div>

        <ol class="relative">
          {timeline.map((item, index) => (
            <li class="group relative pl-10 md:pl-0 py-9 md:py-11 border-b border-border-color/45 first:border-t first:border-t-transparent">
              <div class="md:grid md:grid-cols-[156px_16px_minmax(0,1fr)] md:gap-x-4 md:items-start">
                <time class="block mb-3 md:mb-0 text-[11px] font-mono font-bold uppercase tracking-[0.14em] opacity-65 md:pt-2">{item.year}</time>
                <span class:list={[
                  "absolute left-0 top-[40px] md:static md:mt-[6px] md:justify-self-center flex w-6 h-6 items-center justify-center rounded-full shadow-[0_0_0_5px_var(--bg-color)] text-[8px] font-mono font-bold transition-all duration-300 z-10",
                  index === 0
                    ? "bg-[var(--accent-color)] text-white border-2 border-[var(--accent-color)]"
                    : "bg-[var(--bg-color)] text-black/65 dark:text-white/65 border-2 border-black/30 dark:border-white/30 group-hover:border-[var(--accent-color)] group-hover:text-[var(--accent-color)] group-hover:scale-110",
                ]} aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
                <div class="min-w-0">
                  <div class="flex items-center flex-wrap gap-x-3 gap-y-2 mb-3">
                    <h3 class="text-2xl md:text-3xl font-serif font-bold tracking-tight leading-tight text-text-color">{item.desc}</h3>
                    {item.badge && (
                      <span class="inline-flex shrink-0 items-center justify-center gap-1.5 text-[10px] font-sans font-bold text-amber-700 dark:text-amber-400 bg-amber-500/10 px-2.5 py-1 leading-none rounded-full border border-amber-500/25">
                        <span class="material-symbols-outlined text-[13px] leading-none">emoji_events</span>
                        {item.badge}
                      </span>
                    )}
                  </div>
                  <p class="max-w-2xl text-sm md:text-[15px] font-sans opacity-60 leading-relaxed font-light break-keep">{item.detail}</p>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 mt-32 md:mt-40 reveal-up stagger-1">
      <div class="flex items-end justify-between gap-6 border-b border-border-color/60 pb-6 mb-4">
        <div>
          <p class="text-[10px] font-sans font-bold opacity-40 tracking-[0.24em] uppercase mb-2">Architecture & Canvas</p>
          <h2 class="text-4xl md:text-5xl font-serif font-bold tracking-tight">Tech Specs</h2>
        </div>
        <p class="hidden md:block max-w-xs text-right text-xs font-sans opacity-45 leading-relaxed break-keep">역할과 사용 맥락으로 정리한 기술 구성</p>
      </div>

      <div class="glass-panel rounded-3xl overflow-hidden border border-border-color/45 bg-white/75 dark:bg-[var(--bg-color)] shadow-sm">
        {skillGroups.map((group, index) => (
          <div class="grid grid-cols-1 md:grid-cols-[190px_minmax(0,1fr)] border-b border-border-color/45 last:border-b-0">
            <div class="p-6 md:p-8 bg-neutral-50/70 dark:bg-white/[0.025] border-b md:border-b-0 md:border-r border-border-color/45">
              <span class="block text-[9px] font-mono font-bold opacity-35 tracking-[0.18em] mb-2">{String(index + 1).padStart(2, "0")}</span>
              <h3 class="text-2xl font-serif font-bold tracking-tight mb-1">{group.name}</h3>
              <p class="text-[10px] font-sans uppercase tracking-[0.14em] opacity-40">{group.description}</p>
            </div>
            <div class="p-5 md:p-6 flex flex-wrap content-center gap-3">
              {group.skills.map((skill) => (
                <div class="group/skill flex flex-1 sm:flex-none min-w-[132px] items-center gap-3 rounded-2xl border border-border-color/45 bg-white dark:bg-white/[0.035] px-4 py-3.5 hover:-translate-y-1 hover:border-accent-color/25 hover:shadow-sm transition-all duration-300">
                  {skill.icon ? (
                    <img src={skill.icon} alt={skill.name} class="w-7 h-7 object-contain opacity-85 group-hover/skill:opacity-100 group-hover/skill:scale-110 transition-all duration-300" />
                  ) : (
                    <span class="w-7 h-7 rounded-lg bg-[var(--text-color)] text-[var(--bg-color)] flex items-center justify-center text-[8px] font-mono font-bold tracking-tighter" aria-hidden="true">MB</span>
                  )}
                  <span class="text-xs font-mono font-bold opacity-80 tracking-wide">{skill.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 mt-24 md:mt-32 mb-32 md:mb-40 reveal-up stagger-2">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl md:text-4xl font-sans font-semibold tracking-tight mb-3">Certifications</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
        {certifications.map((certification) => (
          <div class="flex items-center gap-5 group cursor-default border-b border-border-color/30 pb-4 hover:border-accent-color/50 transition-colors duration-300">
            <div class="w-8 h-8 flex items-center justify-center shrink-0">
              <img src={certification.logo.src} alt={certification.item} class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300 rounded-sm" />
            </div>
            <div class="flex flex-col gap-0.5 flex-1 pl-1">
              <span class="text-sm md:text-base font-sans font-semibold opacity-90 tracking-tight">{certification.item}</span>
              <span class="font-sans text-[11px] md:text-xs font-light opacity-60 tracking-wide">{certification.desc} • {certification.date}</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));

      document.querySelector<HTMLElement>("[data-copy-email]")?.addEventListener("click", () => {
        void navigator.clipboard.writeText("kimgh921@gmail.com");
        const label = document.querySelector<HTMLElement>(".email-text");
        if (!label) return;
        label.textContent = "COPIED!";
        window.setTimeout(() => (label.textContent = "Email"), 1500);
      });
    });
  </script>
</BaseLayout>

---

<BaseLayout title="About | DEVARCHIVE" description="김지훈의 개발 경험과 기술 스택">
  <main class="w-full min-h-screen pb-16 md:pb-20">
    <section class="relative w-full overflow-hidden px-6 pb-20 pt-32 reveal-up md:pb-28 md:pt-40">
      <div class="pointer-events-none absolute left-[16%] top-[42%] h-[28rem] w-[28rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent-color/[0.045] blur-[130px] dark:bg-accent-color/[0.08]" aria-hidden="true"></div>

      <div class="about-hero-glass glass-panel relative z-10 mx-auto grid w-full max-w-5xl items-start gap-12 rounded-[2rem] p-5 md:grid-cols-[200px_minmax(0,1fr)] md:gap-12 md:p-8 lg:gap-16 lg:p-10">
        <div class="about-portrait-column mx-auto w-full max-w-[190px] md:max-w-[200px]">
          <div class="mb-4 flex items-center justify-between border-b border-border-color/35 pb-4 font-mono text-[9px] font-semibold uppercase tracking-[0.18em] opacity-45">
            <span>Portrait / 01</span>
            <span>Daejeon · KR</span>
          </div>
          <div class="about-profile-plate">
            <img
              src="/images/profile.webp"
              alt="김지훈 프로필"
              width="720"
              height="960"
              decoding="async"
              fetchpriority="high"
              class="about-profile-image aspect-[4/5] w-full object-cover object-center"
            />
          </div>
          <div class="about-profile-meta">
            <span>Kim Jihun</span>
            <span>2026</span>
          </div>
        </div>

        <div class="min-w-0 text-center md:text-left">
          <div class="mb-7 flex items-center justify-between border-b border-border-color/35 pb-4 font-sans text-[9px] font-bold uppercase tracking-[0.24em] opacity-50">
            <span>About / Profile</span>
          </div>

          <h1 class="text-[clamp(2.35rem,4.2vw,3.6rem)] font-serif font-bold leading-[1.01] tracking-[-0.05em] break-keep">
            <BlurText client:load text="안녕하세요, 김지훈입니다." animateBy="words" delay={95} />
          </h1>

          <p class="mt-7 max-w-2xl border-t border-border-color/25 pt-7 text-sm font-sans leading-[1.85] opacity-65 break-keep md:text-base">
            <span class="block">Spring 기반 백엔드와 생성형 AI를 활용한 웹 서비스를 만들고 있습니다.</span>
            <span class="mt-1 block">새 기능을 서둘러 붙이기보다, 왜 필요한지부터 살펴보고 나중에도 쉽게 고칠 수 있게 만드는 편입니다.</span>
          </p>
          <blockquote class="mt-7 border-l-2 border-accent-color/65 pl-5 text-left text-lg font-serif italic leading-relaxed opacity-80 break-keep md:text-xl">
            조금은 느리더라도 문제의 본질을 놓치지 않는 개발자가 되겠습니다.
          </blockquote>

          <div class="mt-9 flex items-center justify-center gap-7 md:justify-start">
            <button type="button" data-copy-email aria-label="이메일 주소 복사" title="이메일 주소 복사" class="about-social-link about-social-link--email">
              <span class="material-symbols-outlined text-[22px]" aria-hidden="true">mail</span>
              <span class="email-text" aria-live="polite">Email</span>
            </button>
            <a href="https://github.com/2hnk" target="_blank" rel="noopener noreferrer" aria-label="GitHub 새 창에서 열기" class="about-social-link about-social-link--github">
              <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
              <span>Github</span>
            </a>
            <a href="https://www.instagram.com/__kimjihun" target="_blank" rel="noopener noreferrer" aria-label="Instagram 새 창에서 열기" class="about-social-link about-social-link--instagram">
              <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              <span>Instagram</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="relative mx-auto mt-16 w-full max-w-6xl px-6 md:mt-24" id="experience">
      <AnimatedContent client:visible distance={32} duration={0.85}>
        <div class="about-section-layout">
          <header class="about-section-rail">
            <span class="about-section-number">01</span>
            <p class="about-section-kicker">Experience</p>
            <h2 class="about-section-title">Milestones</h2>
          </header>

          <div class="about-milestone-ledger about-register-glass glass-panel overflow-hidden rounded-[1.75rem] px-5 md:px-7">
            {milestoneGroups.map((group, groupIndex) => (
              <article class="about-milestone-group">
                <div class="about-milestone-index" aria-hidden="true">{String(groupIndex + 1).padStart(2, "0")}</div>
                <div class="about-milestone-body">
                  <div class="flex flex-wrap items-center gap-3">
                    <time datetime={group.dateTime} class="font-mono text-[9px] font-bold uppercase tracking-[0.14em] opacity-55">{group.year}</time>
                  </div>
                  <h3 class="mt-4 text-2xl font-serif font-bold leading-tight tracking-tight md:text-3xl">{group.desc}</h3>
                  <p class="mt-3 max-w-2xl text-sm font-sans font-light leading-relaxed opacity-58 break-keep md:text-[15px]">{group.detail}</p>

                  <ol class="about-milestone-achievements mt-7">
                    {group.achievements.map((achievement) => (
                      <li class="about-milestone-achievement">
                        <time datetime={achievement.dateTime} class="font-mono text-[9px] font-semibold tracking-[0.1em] opacity-50">{achievement.year}</time>
                        <div class="min-w-0">
                          <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
                            <h4 class="text-lg font-serif font-bold leading-tight tracking-tight md:text-xl">{achievement.desc}</h4>
                            {achievement.badge && (
                              <span class="inline-flex shrink-0 items-center gap-1 rounded-full border border-amber-500/25 bg-amber-500/10 px-2 py-1 font-sans text-[9px] font-bold leading-none text-amber-700 dark:text-amber-400">
                                <span class="material-symbols-outlined award-icon leading-none">emoji_events</span>
                                {achievement.badge}
                              </span>
                            )}
                          </div>
                          <p class="mt-2 text-xs font-sans font-light leading-relaxed opacity-52 break-keep md:text-sm">{achievement.detail}</p>
                        </div>
                      </li>
                    ))}
                  </ol>
                </div>
              </article>
            ))}
          </div>
        </div>
      </AnimatedContent>
    </section>

    <section class="mx-auto mt-24 w-full max-w-6xl px-6 md:mt-36" id="capabilities">
      <AnimatedContent client:visible distance={32} duration={0.85} delay={0.05}>
        <div class="about-section-layout">
          <header class="about-section-rail">
            <span class="about-section-number">02</span>
            <p class="about-section-kicker">Capabilities</p>
            <h2 class="about-section-title">Tech Specs</h2>
          </header>

          <div class="about-tech-directory glass-panel overflow-hidden rounded-[1.75rem]">
            {skillGroups.map((group, index) => (
              <article class="about-tech-entry group">
                <div class="flex items-start justify-between gap-5">
                  <div>
                    <span class="font-mono text-[9px] font-bold tracking-[0.18em] opacity-32">{String(index + 1).padStart(2, "0")}</span>
                    <h3 class="mt-3 text-2xl font-serif font-bold tracking-tight">{group.name}</h3>
                  </div>
                  <span class="h-px w-8 bg-border-color opacity-20 transition-all duration-300 group-hover:w-12 group-hover:bg-accent-color group-hover:opacity-70" aria-hidden="true"></span>
                </div>
                <p class="mt-2 text-[9px] font-sans font-semibold uppercase tracking-[0.15em] opacity-40">{group.description}</p>
                <div class="mt-6 grid grid-cols-1 gap-x-4 gap-y-3 sm:grid-cols-2">
                  {group.skills.map((skill) => (
                    <div
                      class="tech-skill-item group/skill flex items-center gap-2.5"
                      style={`--skill-color: #${skill.icon?.hex ?? skill.color ?? "1e66f5"}; --skill-color-dark: #${(skill.icon?.hex ?? skill.color) === "000000" ? "f4f0db" : (skill.icon?.hex ?? skill.color ?? "89b4fa")}`}
                    >
                      {skill.icon ? (
                        <svg class="about-skill-icon" viewBox="0 0 24 24" aria-hidden="true">
                          <path d={skill.icon.path}></path>
                        </svg>
                      ) : (
                        <span class="about-skill-icon-mask" style={`--skill-icon: url(${skill.iconSrc})`} aria-hidden="true"></span>
                      )}
                      <span class="font-mono text-[11px] font-semibold tracking-wide">{skill.name}</span>
                    </div>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </AnimatedContent>
    </section>

    <section class="mx-auto mb-16 mt-24 w-full max-w-6xl px-6 md:mb-24 md:mt-36" id="credentials">
      <AnimatedContent client:visible distance={32} duration={0.85} delay={0.05}>
        <div class="about-section-layout">
          <header class="about-section-rail">
            <span class="about-section-number">03</span>
            <p class="about-section-kicker">Credentials</p>
            <h2 class="about-section-title about-section-title-long">Certifications</h2>
          </header>

          <div class="about-credential-register about-register-glass glass-panel overflow-hidden rounded-[1.75rem] px-5 md:px-0">
            {certifications.map((certification, index) => (
              <article class="about-credential-item group">
                <div class="flex items-center justify-between gap-4 font-mono text-[9px] font-semibold uppercase tracking-[0.14em] opacity-42">
                  <span>Credential {String(index + 1).padStart(2, "0")}</span>
                  <time datetime={certification.dateTime}>{certification.date}</time>
                </div>
                <div class="about-credential-heading">
                  <div class="min-w-0">
                    <h3 class="text-2xl font-serif font-bold leading-tight tracking-tight transition-colors duration-300 group-hover:text-accent-color md:text-3xl">{certification.item}</h3>
                    <p class="mt-2 font-sans text-[11px] tracking-wide opacity-48">{certification.desc}</p>
                  </div>
                  <img src={certification.logo.src} alt="" width="44" height="44" loading="lazy" decoding="async" class="about-credential-logo" />
                </div>
                <div class="mt-8 flex items-end justify-between border-t border-border-color/20 pt-4">
                  <span class="font-mono text-[8px] font-semibold uppercase tracking-[0.15em] opacity-35">Verified credential</span>
                  <span class="about-credential-mark" aria-hidden="true">✓</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      </AnimatedContent>
    </section>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));

      const aboutSections = Array.from(document.querySelectorAll<HTMLElement>("main > section[id]"));
      const aboutWindow = window as Window & { __aboutSectionController?: AbortController };
      aboutWindow.__aboutSectionController?.abort();
      const sectionController = new AbortController();
      aboutWindow.__aboutSectionController = sectionController;
      let sectionFrame = 0;

      const updateActiveSection = () => {
        if (!aboutSections.length) return;
        const marker = window.innerHeight * 0.4;
        const isPageEnd = window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 8;
        let activeSection = aboutSections[0];

        if (isPageEnd) {
          activeSection = aboutSections[aboutSections.length - 1];
        } else {
          aboutSections.forEach((section) => {
            if (section.getBoundingClientRect().top <= marker) activeSection = section;
          });
        }

        aboutSections.forEach((section) => section.classList.toggle("about-section-active", section === activeSection));
      };

      const requestSectionUpdate = () => {
        if (sectionFrame) return;
        sectionFrame = window.requestAnimationFrame(() => {
          updateActiveSection();
          sectionFrame = 0;
        });
      };

      updateActiveSection();
      window.addEventListener("scroll", requestSectionUpdate, { passive: true, signal: sectionController.signal });
      window.addEventListener("resize", requestSectionUpdate, { passive: true, signal: sectionController.signal });
      document.addEventListener("astro:before-swap", () => sectionController.abort(), { once: true });

      document.querySelector<HTMLElement>("[data-copy-email]")?.addEventListener("click", async () => {
        const label = document.querySelector<HTMLElement>(".email-text");
        if (!label) return;
        try {
          await navigator.clipboard.writeText("kimgh921@gmail.com");
          label.textContent = "COPIED!";
          window.setTimeout(() => (label.textContent = "Email"), 1500);
        } catch {
          window.location.href = "mailto:kimgh921@gmail.com";
        }
      });

    });
  </script>
</BaseLayout>

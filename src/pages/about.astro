---

<BaseLayout title="About | DEVARCHIVE" description="김지훈의 개발 경험과 기술 스택">
  <main class="w-full min-h-screen pb-16 md:pb-20">
    <section class="relative w-full min-h-[68vh] flex flex-col items-center justify-center px-6 reveal-up overflow-hidden pt-24 pb-12 md:pt-28 md:pb-16">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] md:w-[45vw] md:h-[45vw] bg-accent-color/8 dark:bg-accent-color/15 rounded-full blur-[120px] pointer-events-none animate-pulse duration-1000"></div>

      <div class="relative z-10 mx-auto grid w-full max-w-4xl items-center gap-10 md:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)] md:gap-16">
        <figure class="glass-panel mx-auto w-full max-w-[280px] rounded-[2rem] p-2 shadow-xl transition-transform duration-700 md:max-w-none md:-rotate-1 hover:rotate-0">
          <img
            src="/images/profile.webp"
            alt="김지훈 프로필"
            width="720"
            height="960"
            decoding="async"
            fetchpriority="high"
            class="aspect-[3/4] w-full rounded-[1.5rem] object-cover object-center"
          />
        </figure>

        <div class="text-center md:text-left">
          <h1 class="mb-4 text-2xl md:text-3xl font-serif font-bold tracking-tight">안녕하세요, 김지훈입니다.</h1>
          <p class="mb-4 px-4 text-sm font-sans leading-relaxed opacity-65 break-keep md:px-0 md:text-base">
            Spring 기반 백엔드와 생성형 AI 응용 서비스를 만들고 있습니다.
          </p>
          <p class="text-base md:text-lg font-serif leading-relaxed opacity-80 italic pb-8 border-b border-border-color/30 px-4 md:px-0 break-keep">
            조금은 느리더라도 문제의 본질을<br class="hidden md:block" /> 놓치지 않는 개발자가 되겠습니다.
          </p>

          <div class="flex items-center justify-center md:justify-start gap-10 mt-8">
            <button
              type="button"
              data-copy-email
              aria-label="이메일 주소 복사"
              title="이메일 주소 복사"
              class="flex flex-col items-center gap-3 opacity-50 hover:opacity-100 hover:text-accent-color hover:-translate-y-1 transition-all duration-300"
            >
              <span class="material-symbols-outlined text-[24px]" aria-hidden="true">mail</span>
              <span class="email-text text-[10px] font-sans font-bold tracking-widest uppercase w-12 text-center mt-[1px]" aria-live="polite">Email</span>
            </button>
            <a href="https://github.com/2hnk" target="_blank" rel="noopener noreferrer" aria-label="GitHub 새 창에서 열기" class="flex flex-col items-center gap-3 opacity-50 hover:opacity-100 hover:text-accent-color hover:-translate-y-1 transition-all duration-300 pt-1">
              <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
              <span class="text-[10px] font-sans font-bold tracking-widest uppercase mt-[1px]">Github</span>
            </a>
            <a href="https://www.instagram.com/__kimjihun" target="_blank" rel="noopener noreferrer" aria-label="Instagram 새 창에서 열기" class="flex flex-col items-center gap-3 opacity-50 hover:opacity-100 hover:text-accent-color hover:-translate-y-1 transition-all duration-300 pt-1">
              <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              <span class="text-[10px] font-sans font-bold tracking-widest uppercase mt-[1px]">Instagram</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="w-full relative px-6 mt-16 md:mt-32 reveal-up max-w-5xl mx-auto">
      <div class="border-b border-border-color/60 pb-6 mb-4">
        <p class="text-[10px] font-sans font-bold opacity-40 tracking-[0.24em] uppercase mb-2">Trajectory</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold tracking-tight">Milestones</h2>
      </div>

      <div class="relative w-full" data-milestone-timeline>
        <div class="absolute left-[14px] md:left-[179px] top-0 bottom-0 w-[2px]" data-milestone-track aria-hidden="true">
          <span class="absolute inset-0 bg-[var(--border-color)] opacity-20"></span>
          <span class="milestone-highlight" data-milestone-highlight></span>
        </div>

        <ol class="relative">
          {milestoneGroups.map((group, groupIndex) => (
            <li class="milestone-group relative border-b border-border-color/45" data-milestone-group>
              <div class="milestone-main-entry relative pl-12 md:pl-0 py-7 md:py-9" data-milestone-entry>
                <div class="md:grid md:grid-cols-[148px_30px_minmax(0,1fr)] md:gap-x-4 md:items-start">
                  <time datetime={group.dateTime} class="milestone-date milestone-main-date inline-flex w-fit items-center gap-2 mb-4 md:mb-0 md:justify-self-end">
                    <span class="milestone-date-mark" aria-hidden="true"></span>
                    <span>{group.year}</span>
                  </time>
                  <span class="milestone-node milestone-main-node absolute left-0 top-[28px] md:static md:mt-[2px] md:justify-self-center flex w-[30px] h-[30px] items-center justify-center rounded-full shadow-[0_0_0_6px_var(--bg-color)] text-[9px] font-mono font-bold transition-all duration-300 z-10" data-milestone-node aria-hidden="true">{String(groupIndex + 1).padStart(2, "0")}</span>
                  <div class="min-w-0">
                    <h3 class="text-2xl md:text-3xl font-serif font-bold tracking-tight leading-tight text-text-color">{group.desc}</h3>
                    <p class="mt-3 max-w-2xl text-sm md:text-[15px] font-sans opacity-60 leading-relaxed font-light break-keep">{group.detail}</p>

                    <ol class="milestone-branch-list mt-6 md:mt-7">
                      {group.achievements.map((achievement) => (
                        <li class="milestone-branch-item relative py-4 pl-8 md:pl-9 border-t border-border-color/25" data-milestone-entry data-milestone-child>
                          <span class="milestone-node milestone-child-node" data-milestone-node aria-hidden="true"></span>
                          <time datetime={achievement.dateTime} class="milestone-date milestone-child-date inline-flex w-fit items-center gap-2">
                            <span class="milestone-date-mark" aria-hidden="true"></span>
                            <span>{achievement.year}</span>
                          </time>
                          <div class="mt-2 flex items-center flex-wrap gap-x-3 gap-y-2">
                            <h4 class="text-xl md:text-2xl font-serif font-bold tracking-tight leading-tight text-text-color">{achievement.desc}</h4>
                            {achievement.badge && (
                              <span class="inline-flex shrink-0 items-center justify-center gap-1 text-[9px] font-sans font-bold text-amber-700 dark:text-amber-400 bg-amber-500/10 px-2 py-1 leading-none rounded-full border border-amber-500/25">
                                <span class="material-symbols-outlined award-icon leading-none">emoji_events</span>
                                {achievement.badge}
                              </span>
                            )}
                          </div>
                          <p class="mt-2 max-w-2xl text-xs md:text-sm font-sans opacity-55 leading-relaxed font-light break-keep">{achievement.detail}</p>
                        </li>
                      ))}
                    </ol>
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 mt-24 md:mt-32 reveal-up stagger-1">
      <div class="border-b border-border-color/60 pb-5 mb-2">
        <p class="text-[10px] font-sans font-bold opacity-40 tracking-[0.24em] uppercase mb-2">Technical Focus</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold tracking-tight">Tech Specs</h2>
      </div>

      <div class="tech-spec-list">
        {skillGroups.map((group, index) => (
          <div class="tech-spec-row grid grid-cols-1 md:grid-cols-[190px_minmax(0,1fr)] gap-4 md:gap-8 py-5 md:py-6 border-b border-border-color/30">
            <div class="tech-spec-label relative md:pr-7">
              <div class="mb-2">
                <span class="text-[9px] font-mono font-bold opacity-35 tracking-[0.18em]">{String(index + 1).padStart(2, "0")}</span>
              </div>
              <h3 class="text-xl md:text-2xl font-serif font-bold tracking-tight mb-1">{group.name}</h3>
              <p class="text-[9px] font-sans uppercase tracking-[0.13em] opacity-40">{group.description}</p>
            </div>
            <div class="flex flex-wrap content-center gap-x-7 gap-y-1">
              {group.skills.map((skill) => (
                <div class="tech-skill-item group/skill flex min-w-[112px] items-center gap-2.5 py-2.5">
                  {skill.icon ? (
                    <img src={skill.icon} alt="" width="20" height="20" loading="lazy" decoding="async" class="w-5 h-5 object-contain opacity-75 group-hover/skill:opacity-100 transition-opacity duration-300" />
                  ) : (
                    <span class="w-5 h-5 bg-[var(--text-color)] text-[var(--bg-color)] flex items-center justify-center text-[6px] font-mono font-bold tracking-tighter" aria-hidden="true">MB</span>
                  )}
                  <span class="text-[11px] font-mono font-semibold tracking-wide">{skill.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 mt-16 md:mt-24 mb-12 md:mb-16 reveal-up stagger-2">
      <div class="border-b border-border-color/60 pb-5 mb-0">
        <p class="text-[10px] font-sans font-bold opacity-40 tracking-[0.24em] uppercase mb-2">Credentials</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold tracking-tight">Certifications</h2>
      </div>
      <div class="certification-list grid grid-cols-1 md:grid-cols-2 md:gap-x-10">
        {certifications.map((certification) => (
          <article class="certification-item group grid grid-cols-[36px_minmax(0,1fr)_auto] items-center gap-4 py-5 border-b border-border-color/30 cursor-default">
            <div class="w-9 h-9 flex items-center justify-center shrink-0">
              <img src={certification.logo.src} alt="" width="28" height="28" loading="lazy" decoding="async" class="w-7 h-7 object-contain opacity-80 group-hover:opacity-100 transition-opacity duration-300 rounded-sm" />
            </div>
            <div class="min-w-0">
              <h3 class="text-lg md:text-xl font-serif font-bold tracking-tight leading-tight group-hover:text-accent-color transition-colors duration-300">{certification.item}</h3>
              <p class="mt-1 font-sans text-[10px] md:text-[11px] opacity-45 tracking-wide truncate">{certification.desc}</p>
            </div>
            <time datetime={certification.dateTime} class="font-mono text-[9px] font-bold tracking-[0.1em]">{certification.date}</time>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));

      document.querySelector<HTMLElement>("[data-copy-email]")?.addEventListener("click", async () => {
        const label = document.querySelector<HTMLElement>(".email-text");
        if (!label) return;
        try {
          await navigator.clipboard.writeText("kimgh921@gmail.com");
          label.textContent = "COPIED!";
          window.setTimeout(() => (label.textContent = "Email"), 1500);
        } catch {
          window.location.href = "mailto:kimgh921@gmail.com";
        }
      });

      type TimelineWindow = Window & { __milestoneController?: AbortController };
      const timelineWindow = window as TimelineWindow;
      timelineWindow.__milestoneController?.abort();

      const timeline = document.querySelector<HTMLElement>("[data-milestone-timeline]");
      const track = timeline?.querySelector<HTMLElement>("[data-milestone-track]");
      const highlight = timeline?.querySelector<HTMLElement>("[data-milestone-highlight]");
      const groups = Array.from(timeline?.querySelectorAll<HTMLElement>("[data-milestone-group]") ?? []);
      const entries = Array.from(timeline?.querySelectorAll<HTMLElement>("[data-milestone-entry]") ?? []);
      const nodes = entries.map((entry) => entry.querySelector<HTMLElement>("[data-milestone-node]"));

      if (timeline && track && highlight && groups.length > 0 && entries.length > 0 && nodes.every(Boolean)) {
        const controller = new AbortController();
        timelineWindow.__milestoneController = controller;
        let frame = 0;

        const updateTimeline = () => {
          const focusY = window.innerHeight * 0.46;
          const nodeElements = nodes as HTMLElement[];
          const centersInViewport = nodeElements.map((node) => {
            const rect = node.getBoundingClientRect();
            return rect.top + rect.height / 2;
          });
          const currentIndex = centersInViewport.reduce(
            (closestIndex, center, index) =>
              Math.abs(center - focusY) < Math.abs(centersInViewport[closestIndex] - focusY)
                ? index
                : closestIndex,
            0,
          );

          entries.forEach((entry, index) => {
            const isCurrent = index === currentIndex;
            if (isCurrent) entry.setAttribute("aria-current", "true");
            else entry.removeAttribute("aria-current");
          });

          const currentEntry = entries[currentIndex];
          const currentGroup = currentEntry.closest<HTMLElement>("[data-milestone-group]");

          groups.forEach((group) => group.classList.toggle("is-current-group", group === currentGroup));
          nodeElements.forEach((node) => node.classList.remove("is-current"));
          currentGroup?.querySelector<HTMLElement>(".milestone-main-node")?.classList.add("is-current");
          if (currentEntry.hasAttribute("data-milestone-child")) nodeElements[currentIndex].classList.add("is-current");

          const trackRect = track.getBoundingClientRect();
          const currentGroupRect = currentGroup?.getBoundingClientRect();
          if (!currentGroupRect) return;
          const slotTop = Math.max(0, currentGroupRect.top - trackRect.top);
          const slotBottom = Math.min(trackRect.height, currentGroupRect.bottom - trackRect.top);

          highlight.style.top = `${slotTop}px`;
          highlight.style.height = `${Math.max(0, slotBottom - slotTop)}px`;
        };

        const scheduleTimelineUpdate = () => {
          window.cancelAnimationFrame(frame);
          frame = window.requestAnimationFrame(updateTimeline);
        };

        window.addEventListener("scroll", scheduleTimelineUpdate, { passive: true, signal: controller.signal });
        window.addEventListener("resize", scheduleTimelineUpdate, { passive: true, signal: controller.signal });
        document.addEventListener("astro:before-swap", () => controller.abort(), { once: true, signal: controller.signal });
        scheduleTimelineUpdate();
      }
    });
  </script>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";

import ssafyLogo from "../assets/ssafy_logo.svg";
import hanbatLogo from "../assets/hanbat_logo.svg";
import kicsLogo from "../assets/kics_logo.jpg";
import sqldLogo from "../assets/sqld_logo.png";
import eipLogo from "../assets/engineer_information_processing_logo.png";

const timeline = [
  {
    year: "2026",
    desc: "삼성청년SW/AI아카데미(SSAFY)",
    detail: "웹 개발 및 AI 활용 능력 심화",
    logo: ssafyLogo,
  },
  {
    year: "2026",
    desc: "국립한밭대학교 컴퓨터공학 학사",
    detail: "소프트웨어 엔지니어링 펀더멘탈 확립",
    logo: hanbatLogo,
  },
  {
    year: "2026",
    desc: "KICS 동계종합학술발표회",
    detail: "비용효율적인 지능형 AICC 연구 논문 투고 - 장려상",
    logo: kicsLogo,
  },
];

const certifications = [
  { item: "정보처리기사", date: "2025.09", logo: eipLogo },
  { item: "SQLD", date: "2025.06", logo: sqldLogo },
];

const skills = [
  { name: "Java", icon: "https://cdn.simpleicons.org/openjdk" },
  { name: "Python", icon: "https://cdn.simpleicons.org/python" },
  { name: "Spring", icon: "https://cdn.simpleicons.org/spring" },
  { name: "Spring AI", icon: "https://cdn.simpleicons.org/spring" },
  { name: "LangChain", icon: "https://cdn.simpleicons.org/langchain" },
  { name: "MySQL", icon: "https://cdn.simpleicons.org/mysql" },
  { name: "PostgreSQL", icon: "https://cdn.simpleicons.org/postgresql" },
  { name: "Redis", icon: "https://cdn.simpleicons.org/redis" },
  { name: "Docker", icon: "https://cdn.simpleicons.org/docker" },
  { name: "AWS", icon: "https://cdn.simpleicons.org/amazonwebservices" },
];
---

<BaseLayout title="About | Min Archive" description="Minimalist About Page">
  <main class="w-full min-h-screen pt-[20vh] pb-32 px-6 md:px-12 lg:px-24 max-w-4xl mx-auto">
    <div class="mb-32 reveal-up">
      <h1 class="text-6xl md:text-8xl font-serif font-black tracking-tighter mb-12">
        I am a <br /> Developer.
      </h1>
      <div class="prose max-w-none text-xl md:text-2xl font-serif leading-relaxed opacity-90">
        <p>
          겉으로 보이는 결과보다 과정과 본질적인 것이 더 중요하다고 믿습니다. 조금은 느리더라도
          문제의 본질을 놓치지 않는 개발자가 되기 위해 끊임없이 탐구합니다.
        </p>
        <p class="mt-8">
          저는 시스템의 구조적 안정을 추구하며, 디지털 캔버스 위에 기능적 아름다움을 코드로
          설계합니다.
        </p>
      </div>
    </div>

    <!-- Timeline & Capabilities (Split) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-24 mt-24">
      <!-- Timeline -->
      <div class="reveal-up stagger-1">
        <h3
          class="text-sm font-sans font-bold uppercase tracking-widest text-accent-color mb-8 border-b border-border-color pb-4 flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[16px]">timeline</span>
          Milestones
        </h3>
        <ul class="flex flex-col gap-6">
          {
            timeline.map((t) => (
              <li class="glass-panel p-5 rounded-3xl flex items-center gap-3 hover:-translate-y-1 transition-transform duration-300">
                <img
                  src={typeof t.logo === "string" ? t.logo : t.logo.src}
                  alt={t.desc}
                  class="w-6 h-6 object-contain rounded shrink-0"
                />
                <div class="flex flex-col">
                  <span class="text-xs font-sans font-bold opacity-50 uppercase tracking-widest mb-0.5">
                    {t.year}
                  </span>
                  <span class="text-base font-serif font-bold leading-snug">{t.desc}</span>
                  <span class="text-xs font-sans opacity-60 uppercase tracking-wide mt-0.5">
                    {t.detail}
                  </span>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Skills & Certs -->
      <div class="reveal-up stagger-2">
        <h3
          class="text-sm font-sans font-bold uppercase tracking-widest text-accent-color mb-8 border-b border-border-color pb-4 flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[16px]">code</span>
          Technical Canvas
        </h3>

        <div class="glass-panel p-8 rounded-3xl mb-12 flex flex-col">
          <ul class="flex flex-wrap gap-3 font-sans text-sm">
            {
              skills.map((s) => (
                <li class="glass-pill px-3 py-1.5 hover:-translate-y-0.5 hover:shadow-md transition-all duration-300 cursor-default flex items-center gap-2">
                  <img src={s.icon} alt={s.name} class="w-4 h-4 object-contain" />
                  {s.name}
                </li>
              ))
            }
          </ul>
        </div>

        <h3
          class="text-sm font-sans font-bold uppercase tracking-widest text-accent-color mb-8 border-b border-border-color pb-4 flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[16px]">military_tech</span>
          Certifications
        </h3>
        <ul class="flex flex-col gap-4 font-serif text-base">
          {
            certifications.map((c) => (
              <li class="glass-panel p-5 rounded-3xl flex justify-between items-center hover:-translate-y-1 transition-transform duration-300">
                <div class="flex items-center gap-3">
                  <img
                    src={typeof c.logo === "string" ? c.logo : c.logo.src}
                    alt={c.item}
                    class="w-6 h-6 object-contain rounded"
                  />
                  <span>{c.item}</span>
                </div>
                <span class="text-xs font-sans opacity-60 glass-pill px-3 py-1">{c.date}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));
    });
  </script>
</BaseLayout>

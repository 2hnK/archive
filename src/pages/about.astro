---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import hanbatLogo from "../assets/hanbat_logo.svg";
import ssafyLogo from "../assets/ssafy_logo.svg";
---

<BaseLayout
  title="소개 | DevArchive"
  description="시스템 설계와 인간 중심의 의도에 대해 고민합니다."
>
  <main>
    <!-- Immersive Hero Section -->
    <section
      class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-black"
    >
      <div class="absolute inset-0 z-0">
        <img
          id="hero-bg"
          class="parallax-bg w-full h-[120%] object-cover object-center opacity-60"
          alt="Warm desk workspace"
          src="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?q=80&w=2670&auto=format&fit=crop"
        />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div
        id="hero-text"
        class="relative z-10 w-full max-w-[1400px] mx-auto text-center px-4 md:px-8 transition-transform duration-75"
      >
        <span
          class="text-[0.75rem] md:text-[0.85rem] tracking-[0.3em] font-semibold uppercase text-white/70 mb-5 block"
          >The Vision</span
        >
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] xl:text-[5rem] font-extrabold tracking-tight text-white mb-8 leading-[1.1] break-keep xl:whitespace-nowrap"
        >
          기술로 그려내는<br /> 더 나은 세상의 가능성
        </h1>
        <p
          class="text-[1.3rem] md:text-2xl text-white/90 font-medium max-w-4xl mx-auto leading-relaxed break-keep"
        >
          깊이 있는 통찰로 세상에 꼭 필요한 해답을 건네는 개발자가 되겠습니다.
        </p>
      </div>
      <!-- Scroll Indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 animate-bounce-subtle">
        <span class="material-symbols-outlined text-white/60 text-3xl">keyboard_arrow_down</span>
      </div>
    </section>

    <div class="bg-apple-background dark:bg-apple-darkBackground pt-24 transition-colors">
      <!-- Essay Content -->
      <section class="max-w-[700px] mx-auto px-6 mb-32">
        <div
          class="space-y-8 text-lg leading-relaxed text-apple-textMuted dark:text-apple-darkTextMuted"
        >
          <p
            class="reveal-up first-letter:text-7xl first-letter:font-bold first-letter:mr-3 first-letter:float-left first-letter:text-apple-text dark:first-letter:text-apple-darkText"
          >
            단순한 기능 구현을 넘어, '지금 우리에게 가장 필요한 선택이 무엇인지' 고민합니다. 문제를
            구조적으로 이해하고 상황에 맞는 최선의 해결책을 찾아내는 개발자가 되는 것이 저의
            지향점입니다.
          </p>
          <div class="pt-6 reveal-up stagger-2">
            <h3 class="text-2xl font-semibold text-apple-text dark:text-apple-darkText mb-4">
              함께 나아가는 여정
            </h3>
            <p>
              저에게 개발이란 동료들과 머리를 맞대고 정답을 찾아가는 즐거운 여정입니다. 서로의
              생각을 나누며 크고 작은 난관을 극복할 때 비로소 더 큰 성장이 가능하다고 생각합니다.
              언제나 배우는 마음을 잃지 않고, 주변 동료들과 함께 사회에 선한 영향력을 전하는
              개발자로 나아가겠습니다.
            </p>
          </div>
        </div>
      </section>

      <!-- Capabilities & Milestones (Bento Box) -->
      <section class="max-w-[900px] mx-auto px-6 mb-32">
        <div class="mb-10 reveal-up">
          <span
            class="text-[0.75rem] tracking-[0.08em] font-medium uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-2 block"
            >Capabilities</span
          >
          <h2 class="text-3xl font-bold tracking-tight text-apple-text dark:text-apple-darkText">
            역량 및 자격
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 auto-rows-[minmax(180px,auto)]">
          <!-- Backend Foundation (Span 2) -->
          <div
            class="md:col-span-2 bg-apple-surface dark:bg-[#1a1a1a] p-8 rounded-[2rem] border border-apple-border/50 dark:border-apple-darkBorder reveal-up transition-shadow hover:shadow-lg dark:hover:shadow-white/5 flex flex-col justify-between group"
          >
            <div class="mb-6">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-xs font-semibold tracking-wider uppercase mb-1 block"
                >Core</span
              >
              <h3 class="text-2xl font-bold text-apple-text dark:text-apple-darkText">
                Backend Foundation
              </h3>
            </div>
            <div class="flex flex-wrap gap-3">
              <!-- Java -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#E76F00]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg"
                  alt="Java"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#E76F00]"
                  >Java</span
                >
              </div>
              <!-- Python -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#3776AB]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
                  alt="Python"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#3776AB]"
                  >Python</span
                >
              </div>
              <!-- Spring -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#6DB33F]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg"
                  alt="Spring"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#6DB33F]"
                  >Spring</span
                >
              </div>
            </div>
          </div>

          <!-- Acquisitions / Certifications (Span 1, Row Span 2) -->
          <div
            class="md:col-span-1 md:row-span-2 bg-apple-surface dark:bg-[#1a1a1a] p-8 rounded-[2rem] border border-apple-border/50 dark:border-apple-darkBorder reveal-up stagger-1 transition-shadow hover:shadow-lg dark:hover:shadow-white/5 flex flex-col group relative overflow-hidden"
          >
            <div class="mb-8 relative z-10">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-xs font-semibold tracking-wider uppercase mb-1 block"
                >Milestones</span
              >
              <h3 class="text-2xl font-bold text-apple-text dark:text-apple-darkText">
                Certifications
              </h3>
            </div>
            <div class="space-y-4 relative z-10 flex-1 flex flex-col justify-center">
              <!-- 정보처리기사 -->
              <div
                class="flex items-center gap-4 bg-white/80 dark:bg-white/5 p-4 rounded-2xl border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.03] hover:shadow-lg dark:hover:bg-white/10 group/cert cursor-default"
              >
                <div
                  class="w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-500/20 flex flex-shrink-0 items-center justify-center text-blue-600 dark:text-blue-400 transition-colors duration-300 group-hover/cert:bg-blue-500 group-hover/cert:text-white"
                >
                  <span
                    class="material-symbols-outlined text-2xl transition-transform duration-300 group-hover/cert:scale-125 group-hover/cert:rotate-12"
                    >workspace_premium</span
                  >
                </div>
                <div>
                  <h4
                    class="font-bold text-sm text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/cert:text-blue-500"
                  >
                    정보처리기사
                  </h4>
                  <span
                    class="text-[0.7rem] font-medium text-apple-textMuted dark:text-apple-darkTextMuted"
                    >2025.09.12 취득</span
                  >
                </div>
              </div>
              <!-- SQLD -->
              <div
                class="flex items-center gap-4 bg-white/80 dark:bg-white/5 p-4 rounded-2xl border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.03] hover:shadow-lg dark:hover:bg-white/10 group/cert cursor-default"
              >
                <div
                  class="w-12 h-12 rounded-xl bg-emerald-50 dark:bg-emerald-500/20 flex flex-shrink-0 items-center justify-center text-emerald-600 dark:text-emerald-400 transition-colors duration-300 group-hover/cert:bg-emerald-500 group-hover/cert:text-white"
                >
                  <span
                    class="material-symbols-outlined text-2xl transition-transform duration-300 group-hover/cert:scale-125 group-hover/cert:-rotate-12"
                    >database</span
                  >
                </div>
                <div>
                  <h4
                    class="font-bold text-sm text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/cert:text-emerald-500"
                  >
                    SQLD
                  </h4>
                  <span
                    class="text-[0.7rem] font-medium text-apple-textMuted dark:text-apple-darkTextMuted"
                    >2025.06.27 취득</span
                  >
                </div>
              </div>
            </div>
          </div>

          <!-- Data Stores (Span 1) -->
          <div
            class="md:col-span-1 bg-apple-surface dark:bg-[#1a1a1a] p-8 rounded-[2rem] border border-apple-border/50 dark:border-apple-darkBorder reveal-up stagger-2 transition-shadow hover:shadow-lg dark:hover:shadow-white/5 flex flex-col justify-between group"
          >
            <div class="mb-6">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-xs font-semibold tracking-wider uppercase mb-1 block"
                >Storage</span
              >
              <h3 class="text-xl font-bold text-apple-text dark:text-apple-darkText">
                Data Stores
              </h3>
            </div>
            <div class="flex flex-wrap gap-3">
              <!-- MySQL -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#4479A1]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg"
                  alt="MySQL"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#4479A1]"
                  >MySQL</span
                >
              </div>
              <!-- PostgreSQL -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#336791]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg"
                  alt="PostgreSQL"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#336791]"
                  >PostgreSQL</span
                >
              </div>
              <!-- Redis -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#DC382D]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/redis/redis-original.svg"
                  alt="Redis"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#DC382D]"
                  >Redis</span
                >
              </div>
            </div>
          </div>

          <!-- Infrastructure (Span 1) -->
          <div
            class="md:col-span-1 bg-apple-surface dark:bg-[#1a1a1a] p-8 rounded-[2rem] border border-apple-border/50 dark:border-apple-darkBorder reveal-up stagger-3 transition-shadow hover:shadow-lg dark:hover:shadow-white/5 flex flex-col justify-between group"
          >
            <div class="mb-6">
              <span
                class="text-apple-textMuted dark:text-apple-darkTextMuted text-xs font-semibold tracking-wider uppercase mb-1 block"
                >Cloud & DevOps</span
              >
              <h3 class="text-xl font-bold text-apple-text dark:text-apple-darkText">
                Infrastructure
              </h3>
            </div>
            <div class="flex flex-wrap gap-3">
              <!-- Docker -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#2496ED]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg"
                  alt="Docker"
                  class="w-6 h-6 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#2496ED]"
                  >Docker</span
                >
              </div>
              <!-- AWS -->
              <div
                class="flex items-center gap-2.5 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-full border border-black/5 dark:border-white/5 backdrop-blur-md transition-all duration-300 hover:scale-[1.05] hover:bg-white dark:hover:bg-white/10 hover:shadow-md hover:shadow-[#FF9900]/10 group/tech cursor-default"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg"
                  alt="AWS"
                  class="w-8 h-8 object-contain transition-transform duration-300 group-hover/tech:-translate-y-0.5"
                />
                <span
                  class="font-semibold text-[0.85rem] text-apple-text dark:text-apple-darkText transition-colors duration-300 group-hover/tech:text-[#FF9900]"
                  >AWS</span
                >
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Timeline Section -->
      <section class="max-w-[700px] mx-auto px-6 pb-24">
        <div class="mb-12 reveal-up">
          <span
            class="text-[0.75rem] tracking-[0.08em] font-medium uppercase text-apple-textMuted dark:text-apple-darkTextMuted mb-2 block"
            >The Timeline</span
          >
          <h2 class="text-3xl font-bold tracking-tight text-apple-text dark:text-apple-darkText">
            주요 여정
          </h2>
        </div>

        <div class="space-y-16 relative">
          <!-- Vertical Line -->
          <div
            class="absolute left-[3px] top-4 bottom-0 w-[1px] bg-apple-border/70 dark:bg-apple-darkBorder/70"
          >
          </div>

          <div class="relative pl-10 reveal-up stagger-1">
            <div
              class="absolute left-[-1px] top-4 w-[8px] h-[8px] rounded-full bg-apple-text dark:bg-apple-darkText ring-4 ring-apple-background dark:ring-apple-darkBackground z-10"
            >
            </div>
            <div>
              <div class="flex items-center gap-4 mb-3">
                <div
                  class="w-12 h-12 flex-shrink-0 rounded-[12px] bg-white flex items-center justify-center p-2 border border-black/5 dark:border-white/5 shadow-sm"
                >
                  <Image src={ssafyLogo} alt="SSAFY Logo" class="w-full h-full object-contain" />
                </div>
                <div>
                  <span
                    class="text-[0.75rem] font-bold text-apple-text dark:text-apple-darkText mb-0.5 block"
                    >2026.03 ~ 현재</span
                  >
                  <h4 class="text-xl font-semibold text-apple-text dark:text-apple-darkText">
                    SSAFY 과정 이수
                  </h4>
                </div>
              </div>
              <p
                class="text-apple-textMuted dark:text-apple-darkTextMuted leading-relaxed break-keep"
              >
                삼성청년SW아카데미(SSAFY)에서 몰입형 소프트웨어 교육 과정을 이수하며, 실무 중심의 웹
                개발 역량과 알고리즘 문제 해결 능력을 키우고 있습니다.
              </p>
            </div>
          </div>

          <div class="relative pl-10 reveal-up stagger-2">
            <div
              class="absolute left-[-1px] top-4 w-[8px] h-[8px] rounded-full bg-apple-textMuted dark:bg-apple-darkTextMuted ring-4 ring-apple-background dark:ring-apple-darkBackground z-10"
            >
            </div>
            <div>
              <div class="flex items-center gap-4 mb-3">
                <div
                  class="w-12 h-12 flex-shrink-0 rounded-[12px] bg-white flex items-center justify-center p-2 border border-black/5 dark:border-white/5 shadow-sm"
                >
                  <Image
                    src={hanbatLogo}
                    alt="Hanbat University Logo"
                    class="w-full h-full object-contain"
                  />
                </div>
                <div>
                  <span
                    class="text-[0.75rem] font-bold text-apple-textMuted dark:text-apple-darkTextMuted mb-0.5 block"
                    >~ 2026.03</span
                  >
                  <h4 class="text-xl font-semibold text-apple-text dark:text-apple-darkText">
                    국립한밭대학교 컴퓨터공학과 학사 졸업
                  </h4>
                </div>
              </div>
              <p
                class="text-apple-textMuted dark:text-apple-darkTextMuted leading-relaxed break-keep"
              >
                컴퓨터공학 전공 지식을 바탕으로 프로그래밍 기초, 자료구조, 알고리즘 등 소프트웨어
                엔지니어링의 핵심 원리를 탄탄하게 학습했습니다.
              </p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      // 1. Immersive Parallax Hero
      const heroBg = document.getElementById("hero-bg");
      const heroText = document.getElementById("hero-text");

      const onScrollHero = () => {
        const scrolled = window.scrollY;

        if (scrolled < window.innerHeight && heroBg && heroText) {
          heroBg.style.transform = `translateY(${scrolled * 0.4}px)`;
          heroText.style.transform = `translateY(${scrolled * 0.15}px)`;
          heroText.style.opacity = (1 - scrolled / (window.innerHeight * 0.6)).toString();
        }
      };

      window.addEventListener("scroll", onScrollHero, { passive: true });

      // 2. Smooth Intersection Observer for Scroll Reveals
      const revealOptions = {
        root: null,
        rootMargin: "0px 0px -50px 0px",
        threshold: 0.1,
      };

      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          }
        });
      }, revealOptions);

      document.querySelectorAll(".reveal-up").forEach((el) => {
        revealObserver.observe(el);
      });
    });
  </script>
</BaseLayout>

    description: "Server & Persistence",
    skills: [
      { name: "Java", icon: "/icons/skills/openjdk.svg" },
      { name: "Spring", icon: "/icons/skills/spring.svg" },
      { name: "Spring AI", icon: "/icons/skills/spring.svg" },
      { name: "JPA", icon: "/icons/skills/hibernate.svg" },
      { name: "MyBatis", icon: null },
    ],
  },
  {
    name: "AI",
    description: "Models & Orchestration",
    skills: [
      { name: "Python", icon: "/icons/skills/python.svg" },
      { name: "LangChain", icon: "/icons/skills/langchain.svg" },
    ],
  },

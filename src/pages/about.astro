---
import BaseLayout from "../layouts/BaseLayout.astro";

import ssafyLogo from "../assets/ssafy_logo.svg";
import hanbatLogo from "../assets/hanbat_logo.svg";
import kicsLogo from "../assets/kics_logo.jpg";
import sqldLogo from "../assets/sqld_logo.png";
import eipLogo from "../assets/engineer_information_processing_logo.png";

const timeline = [
  {
    year: "2026",
    desc: "삼성청년SW/AI아카데미(SSAFY)",
    detail: "체계적인 실무 중심의 교육을 통해 웹 개발 및 AI 활용 능력 역량 강화 및 알고리즘 문제 해결 능력 향상",
    logo: ssafyLogo,
  },
  {
    year: "2026",
    desc: "국립한밭대학교 컴퓨터공학 학사 졸업",
    detail: "자료구조, 알고리즘 등 컴퓨터공학 전공 과정을 통해 소프트웨어 엔지니어링의 기본 소양 확립",
    logo: hanbatLogo,
  },
  {
    year: "2026",
    desc: "KICS 동계종합학술발표회",
    detail: "KICS 한국통신학회 · 2026년도 동계종합학술발표회(KICS Winter Conference 2026) - 비용효율적인 지능형 AICC를 위한 자가진화형 4계층 정규화 게이트",
    logo: kicsLogo,
    badge: "장려상",
  },
];

const certifications = [
  { item: "정보처리기사", date: "2025.09", desc: "한국산업인력공단", logo: eipLogo },
  { item: "SQLD", date: "2025.06", desc: "한국데이터산업진흥원", logo: sqldLogo },
];

const skills = [
  { name: "Java", icon: "https://cdn.simpleicons.org/openjdk" },
  { name: "Python", icon: "https://cdn.simpleicons.org/python" },
  { name: "Spring", icon: "https://cdn.simpleicons.org/spring" },
  { name: "Spring AI", icon: "https://cdn.simpleicons.org/spring" },
  { name: "LangChain", icon: "https://cdn.simpleicons.org/langchain" },
  { name: "MySQL", icon: "https://cdn.simpleicons.org/mysql" },
  { name: "PostgreSQL", icon: "https://cdn.simpleicons.org/postgresql" },
  { name: "Redis", icon: "https://cdn.simpleicons.org/redis" },
  { name: "Docker", icon: "https://cdn.simpleicons.org/docker" },
  { name: "AWS", icon: "https://upload.wikimedia.org/wikipedia/commons/9/93/Amazon_Web_Services_Logo.svg" },
];
---

<BaseLayout title="About | DEVARCHIVE" description="Professional Narrative About Page">
  <main class="w-full min-h-screen pb-40">
    
    <!-- Hero Narrative Canvas -->
    <section class="relative w-full min-h-screen flex items-center px-6 md:px-12 lg:px-24 overflow-hidden pt-20">
      <!-- Background Ambient Glow -->
      <div class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] bg-accent-color/5 dark:bg-accent-color/10 rounded-full blur-[150px] pointer-events-none animate-pulse"></div>
      
      <div class="max-w-[1700px] mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Left Side: Massive Vertical Identity -->
        <div class="lg:col-span-5 relative z-10 reveal-up">
          <div class="flex flex-col">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] opacity-30 mb-8 border-l-2 border-accent-color pl-4">Digital Architect</span>
            <h1 class="text-7xl md:text-[8.5rem] font-serif font-black leading-[0.85] tracking-tighter uppercase text-text-color">
              Software <br/> 
              <span class="text-transparent !bg-clip-text bg-gradient-to-r from-text-color to-text-color/40">Engineer</span>
            </h1>
          </div>
        </div>

        <!-- Right Side: Personal Bio & Contact -->
        <div class="lg:col-span-7 relative z-10 reveal-up stagger-1 mt-12 lg:mt-0">
          <div class="max-w-xl">
             <div class="mb-12">
               <p class="text-xl md:text-3xl font-serif leading-tight opacity-90 italic mb-8 break-keep">
                 "조금은 느리더라도 문제의 본질을 놓치지 않는 개발자가 되겠습니다."
               </p>
               <div class="h-[1px] w-24 bg-accent-color/40 mb-8"></div>
               <p class="text-sm md:text-base font-sans leading-relaxed opacity-60 font-light break-keep">
                 현실의 복잡한 문제를 단순하고 아름다운 코드로 풀어내는 과정에 매료되어 있습니다. 
                 사용자 중심의 가치를 공학적 정밀함으로 구현하는 것을 목표로 합니다.
               </p>
             </div>

             <!-- Contact Cards -->
             <div class="flex flex-wrap gap-4 mt-12">
                <a href="mailto:kimgh921@gmail.com" class="glass-panel px-8 py-4 flex items-center gap-4 group hover:border-accent-color/30 transition-all">
                   <span class="material-symbols-outlined text-[20px] opacity-40 group-hover:opacity-100 group-hover:text-accent-color transition-all">mail</span>
                   <div class="flex flex-col">
                      <span class="text-[9px] font-black uppercase tracking-widest opacity-30">Get in touch</span>
                      <span class="text-xs font-bold font-sans">kimgh921@gmail.com</span>
                   </div>
                </a>
                <a href="https://github.com/2hnk" target="_blank" class="glass-panel px-8 py-4 flex items-center gap-4 group hover:border-accent-color/30 transition-all">
                  <svg class="opacity-40 group-hover:opacity-100 group-hover:text-accent-color transition-all" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                  <div class="flex flex-col">
                     <span class="text-[9px] font-black uppercase tracking-widest opacity-30">Source</span>
                     <span class="text-xs font-bold font-sans">github.com/2hnk</span>
                  </div>
                </a>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Archival Milestones -->
    <section class="w-full relative px-6 mt-32 md:mt-48 reveal-up max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20 md:mb-32">
        <div class="lg:col-span-4 self-end">
          <span class="text-[10px] font-black uppercase tracking-[0.4em] opacity-30 mb-4 block">Historical Log</span>
          <h2 class="text-4xl md:text-6xl font-serif font-black tracking-tighter leading-none">Milestones</h2>
        </div>
      </div>

      <div class="flex flex-col gap-24 md:gap-40">
        {timeline.map((t, idx) => (
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center group relative">
            <!-- Background Year Watermark -->
            <div class="absolute -top-12 md:-top-20 left-0 text-[15vw] md:text-[12vw] font-black opacity-[-0.03] dark:opacity-[0.05] pointer-events-none select-none font-serif tracking-tighter italic">
              {t.year}
            </div>

            <!-- Image & Logo Area -->
            <div class="lg:col-span-5 relative z-10">
               <div class="relative glass-panel aspect-[4/3] rounded-[2.5rem] p-8 flex items-center justify-center overflow-hidden transition-all duration-700 group-hover:shadow-[0_40px_100px_-20px_rgba(0,0,0,0.1)]">
                  <div class="absolute inset-0 bg-gradient-to-br from-accent-color/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  <img src={typeof t.logo === "string" ? t.logo : t.logo.src} class="w-32 h-32 md:w-48 md:h-48 object-contain relative z-10 transition-transform duration-700 group-hover:scale-110" />
               </div>
            </div>

            <!-- Details Area -->
            <div class="lg:col-span-7 lg:pl-12 reveal-up stagger-1">
              <div class="flex flex-col gap-6">
                <div class="flex items-center gap-4">
                   <span class="text-xs font-black font-sans uppercase tracking-[0.3em] text-accent-color">{t.year} Phase</span>
                   <div class="h-[1px] flex-1 bg-text-color/10"></div>
                </div>
                <h3 class="text-3xl md:text-5xl font-sans font-bold tracking-tight text-text-color break-keep">
                  {t.desc}
                  {t.badge && (
                    <span class="inline-flex align-middle ml-4 items-center justify-center gap-1 text-[11px] font-bold text-amber-500 bg-amber-500/10 px-3 py-1 rounded-full border border-amber-500/20">
                      {t.badge}
                    </span>
                  )}
                </h3>
                <p class="text-base md:text-xl font-sans opacity-60 leading-relaxed font-light break-keep max-w-2xl">
                  {t.detail}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Technical Canvas -->
    <section class="max-w-[1400px] mx-auto px-6 mt-40 md:mt-60 reveal-up">
       <div class="mb-20 text-center">
          <span class="text-[10px] font-black uppercase tracking-[0.4em] opacity-30 mb-4 block">Knowledge Stack</span>
          <h2 class="text-4xl md:text-6xl font-serif font-black tracking-tighter leading-none mb-8">Technical Canvas</h2>
          <div class="flex justify-center gap-2 text-[10px] uppercase font-bold opacity-40">
             <span>Foundations</span> / <span>Architectures</span> / <span>AI & Data</span>
          </div>
       </div>

       <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 border border-text-color/5 rounded-[3rem] overflow-hidden glass-panel">
         {skills.map((s) => (
           <div class="relative bg-transparent p-12 flex flex-col items-center justify-center gap-6 group hover:bg-accent-color/5 transition-all duration-700 border-[0.5px] border-text-color/5">
             <div class="absolute top-4 right-6 text-[8px] font-black opacity-10 group-hover:opacity-100 transition-opacity uppercase tracking-widest">Runtime</div>
             <img src={s.icon} alt={s.name} class="w-10 h-10 object-contain grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700" />
             <span class="text-xs font-mono font-bold opacity-50 group-hover:opacity-100 text-center transition-all">{s.name}</span>
           </div>
         ))}
       </div>
    </section>

    <!-- Certifications Sleek List -->
    <section class="max-w-4xl mx-auto px-6 mt-32 md:mt-48 reveal-up stagger-2">
      <div class="flex items-center gap-8 mb-16">
        <h2 class="text-3xl md:text-5xl font-serif font-black tracking-tighter">Certifications</h2>
        <div class="h-[1px] flex-1 bg-text-color/10"></div>
      </div>

      <div class="flex flex-col gap-2">
        {certifications.map((c) => (
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 py-8 group border-b border-text-color/5 hover:bg-accent-color/5 px-6 transition-all rounded-2xl">
            <div class="flex items-center gap-6">
              <div class="w-10 h-10 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all">
                <img src={typeof c.logo === "string" ? c.logo : c.logo.src} alt={c.item} class="w-full h-full object-contain" />
              </div>
              <div class="flex flex-col">
                <span class="text-lg font-sans font-bold tracking-tight opacity-90 group-hover:text-accent-color transition-colors">{c.item}</span>
                <span class="text-xs opacity-50">{c.desc}</span>
              </div>
            </div>
            <div class="text-[11px] font-bold font-sans uppercase tracking-[0.2em] opacity-30 group-hover:opacity-100 transition-all">
               Issued {c.date}
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>
  
  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".reveal-up").forEach((el) => revealObserver.observe(el));
    });
  </script>
</BaseLayout>

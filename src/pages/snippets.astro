---
import BaseLayout from "../layouts/BaseLayout.astro";

// Mock snippets data
const snippets = [
  {
    title: "Centering a Div",
    description: "가장 클래식한 문제. Flexbox를 활용한 완벽한 뷰포트 정중앙 정렬.",
    code: `.container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  height: 100vh;\n}`,
    lang: "css",
    tag: "CSS"
  },
  {
    title: "Random UUID in Browser",
    description: "외부 라이브러리 의존성 없이 브라우저 내장 API를 활용해 UUIDv4를 생성하는 깔끔한 방법.",
    code: `const uuid = () => crypto.randomUUID();`,
    lang: "javascript",
    tag: "JS"
  },
  {
    title: "React useEffect Cleanup",
    description: "타이머나 이벤트 리스너를 붙일 때 메모리 누수를 방지하기 위해 잊지 말아야 할 클린업 패턴.",
    code: `useEffect(() => {\n  const timer = setInterval(() => {\n    console.log('tick');\n  }, 1000);\n\n  return () => clearInterval(timer);\n}, []);`,
    lang: "javascript",
    tag: "React"
  },
  {
    title: "Astro Content Collection 정렬",
    description: "Astro 3.0 이상에서 MDX 콘텐츠 컬렉션을 가져오고 날짜순으로 정렬하는 패턴입니다.",
    code: `import { getCollection } from "astro:content";\n\nconst posts = await getCollection("articles");\nposts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());`,
    lang: "javascript",
    tag: "Astro"
  },
  {
    title: "Tailwind Glassmorphism",
    description: "자주 쓰는 글래스모피즘(투명 유리) 느낌의 Tailwind 유틸리티 클래스 조합.",
    code: `bg-white/10 backdrop-blur-md border border-white/20 shadow-xl`,
    lang: "css",
    tag: "Tailwind"
  },
  {
    title: "Debounce Function",
    description: "연속된 이벤트 호출 시 마지막 호출만 실행되도록 제어하는 디바운스 유틸리티 함수.",
    code: `function debounce(func, wait) {\n  let timeout;\n  return function executedFunction(...args) {\n    const later = () => {\n      clearTimeout(timeout);\n      func(...args);\n    };\n    clearTimeout(timeout);\n    timeout = setTimeout(later, wait);\n  };\n}`,
    lang: "javascript",
    tag: "TS"
  }
];
---

<BaseLayout title="Snippets | DevArchive" description="유용한 코드 조각 및 실험실">
  <main class="pt-32 pb-24 max-w-7xl mx-auto px-6 h-full min-h-[80vh]" style="padding-top: 160px;">
    <div class="w-full flex flex-col sm:flex-row sm:justify-between sm:items-end mb-16 pb-6 border-b border-black/5 dark:border-white/5 gap-6">
      <div class="max-w-2xl">
        <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-apple-text dark:text-apple-darkText mb-2">
          Snippets
        </h1>
        <p class="text-apple-textMuted dark:text-apple-darkTextMuted text-[15px] md:text-[16px] tracking-tight font-medium break-keep">
          모아둔 작은 조각들의 모음
        </p>
      </div>
    </div>

    <!-- Masonry Grid Configuration -->
    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
      {
        snippets.map((snippet) => (
          <div class="break-inside-avoid bg-white dark:bg-[#111111] border border-black/5 dark:border-white/10 rounded-[1.5rem] p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
            <div class="flex items-center justify-between mb-5">
              <span class="text-[10px] font-bold uppercase tracking-widest text-[#1e66f5] dark:text-[#89b4fa] bg-[#1e66f5]/10 dark:bg-[#89b4fa]/10 px-2 py-1 rounded-md">
                {snippet.tag}
              </span>
              <div class="flex gap-1.5 opacity-80">
                <div class="w-3 h-3 rounded-full bg-[#f38ba8] border border-black/10"></div>
                <div class="w-3 h-3 rounded-full bg-[#f9e2af] border border-black/10"></div>
                <div class="w-3 h-3 rounded-full bg-[#a6e3a1] border border-black/10"></div>
              </div>
            </div>
            <h2 class="text-[18px] font-bold text-apple-text dark:text-apple-darkText mb-2 tracking-tight">
              {snippet.title}
            </h2>
            <p class="text-[14px] text-apple-textMuted dark:text-apple-darkTextMuted mb-5 leading-relaxed font-medium break-keep">
              {snippet.description}
            </p>
            <div class="bg-[#1e1e2e] dark:bg-black/50 rounded-xl p-4 overflow-x-auto border border-black/10 dark:border-white/5 relative group">
              <pre class="text-[13px] font-mono text-[#cdd6f4] leading-[1.6]"><code>{snippet.code}</code></pre>
            </div>
          </div>
        ))
      }
    </div>
  </main>
</BaseLayout>

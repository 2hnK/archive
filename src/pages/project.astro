    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuC5AEbqrNzQ1-SvYIJIWt1EuApIbBHl_HBblfMw96fDdkS7EzKHu6Zew16nnCG6WbwvC3aqDeHI0EFJeqB14NjzgjVvsEn67XJU_OV4uJscdG7XFLkIoYOclpv1m1ZPOgQLmeus5zT3nsjuPlZHEPgM298MUI-3mJiEwc_byTMWwtC93z0TzmIsh5nzbS8zndKZ_aGWJls6nfuWluG_lw7BqYVGhrj0lt521kef-xRmkyI83OhraLasbTeVB6f6BhrrLNwvuj8SjvMu",
  },
  {
    title: "Minimal Design System",
    description:
      "디자이너와 개발자 사이의 간극을 완전히 좁히기 위한 Tailwind CSS 기반 사내 공통 디자인 시스템 컴포넌트 프레임워크입니다.",
    tags: ["Storybook", "Figma", "Design", "CSS"],
    url: "#",
    year: "2024",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuC4eQMIkMBmHMy3whVOgSHFkBGYJ9Bcspd0PMXpnMrd2KLWPfT10Pbd5wWQ3W_-bRtrli8_P0ppaeAg_NZqzjWFAxixxlsgUYzpY98m81uCXn5c7sIAikTX7ioocJTKj9q0XPdEpQMU482kUmXh5zaDUW5GWUUcaHRsucLRWdzAepOgcw57JITm-UG49TI_cYso5dZR_hdhjWj2vogjS1-mnyOqLOu4elVXDrOKtj7gj6NU_eN_ykKRC-CtszyDvnJfT3zZqynw0Pst",
  },
];
---

<BaseLayout title="Project | DevArchive" description="사이드 프로젝트 쇼케이스">
  <main class="pt-32 pb-24 max-w-7xl mx-auto px-6 min-h-[70vh]" style="padding-top: 160px;">
    <div
      class="w-full flex flex-col sm:flex-row sm:justify-between sm:items-end mb-10 border-b border-apple-border dark:border-apple-darkBorder pb-6 gap-6"
    >
      <div class="max-w-2xl">
        <h1
          class="text-[2.5rem] md:text-5xl font-bold tracking-tighter text-apple-text dark:text-apple-darkText mb-3"
        >
          Project
        </h1>
        <p
          class="text-apple-textMuted dark:text-apple-darkTextMuted text-[17px] md:text-[19px] tracking-tight font-medium break-keep"
        >
          진행 중인 프로젝트
        </p>
      </div>
      <a href="/write-project" class="btn-premium self-start sm:self-auto shrink-0 mb-1 lg:mb-2">
        <span class="material-symbols-outlined text-[16px] leading-none">add</span>
        새 프로젝트
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[360px]">
      {
        projects.map((proj, i) => (
          <a
            href={proj.url}
            class={`group block relative rounded-3xl overflow-hidden bg-black border border-zinc-200 dark:border-white/10 hover:border-zinc-300 dark:hover:border-white/30 transition-all duration-700 ${i === 0 ? "md:col-span-2 lg:col-span-2" : ""} ${i === 2 ? "md:col-span-2 lg:col-span-2 aspect-[auto]" : ""}`}
          >
            <img
              src={proj.image}
              alt={proj.title}
              class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-105 opacity-60 mix-blend-luminosity group-hover:mix-blend-normal group-hover:opacity-80 saturate-50 group-hover:saturate-100"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10" />
            <div class="absolute inset-0 p-8 flex flex-col justify-between z-10">
              <div class="flex justify-end">
                <span class="px-3 py-1 bg-white/10 backdrop-blur-xl rounded-full text-[10px] font-bold tracking-widest uppercase text-white shadow-lg border border-white/20">
                  {proj.year}
                </span>
              </div>
              <div class="transform translate-y-3 group-hover:translate-y-0 transition-transform duration-500 ease-out">
                <div class="flex flex-wrap gap-2 mb-4 opacity-70 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                  {proj.tags.map((tag) => (
                    <span class="text-[10px] font-semibold tracking-widest uppercase text-white px-2 py-0.5 border border-white/20 rounded-md bg-white/5 backdrop-blur-sm">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-3xl font-bold text-white tracking-tight leading-tight mb-3">
                  {proj.title}
                </h2>
                <p class="text-zinc-300 text-sm leading-relaxed max-w-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-150 line-clamp-2 break-keep">
                  {proj.description}
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>

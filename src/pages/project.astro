---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "Soomgil",
    description: "스와이프 취향 데이터를 여행방 추천, 지도 일정 협업, 여행 기록 공유까지 연결한 그룹 여행 웹 앱",
    tags: ["Vue 3", "TypeScript", "Spring Boot", "Mapbox GL JS", "PostgreSQL", "Redis", "Spring AI", "STOMP"],
    url: "/project/soomgil",
    year: "2026",
    image: "/images/projects/soomgil-card-cover.png",
  },
  {
    title: "Dyslexia Kit",
    description: "학습 자료 PDF를 AI 활용해 난독증을 겪는 학생들을 위한 교안으로 변환하고, TTS·어휘 분석·쓰기 연습을 제공하는 서비스",
    tags: ["Spring Boot", "React", "FastAPI", "LangChain", "PostgreSQL", "Redis", "AWS"],
    url: "/project/dyslexia-kit",
    year: "2025",
    image: "/images/projects/dyslexia-kit-children-reading-public-domain.jpg",
  },
];
---

<BaseLayout title="Projects | DEVARCHIVE" description="Selected Projects">
  <main class="pt-[20vh] pb-32 max-w-7xl mx-auto px-6 md:px-12 lg:px-24 min-h-[70vh]">
    <div class="mb-24 reveal-up">
      <h1 class="text-6xl md:text-8xl font-serif font-black tracking-tighter mb-4 uppercase">
        Projects
      </h1>
    </div>

    <div class="flex flex-col gap-8 pt-8">
      {
        projects.map((proj, i) => (
          <a
            href={proj.url}
            class="group relative grid overflow-hidden rounded-[2.5rem] glass-panel reveal-up stagger-1 transition-[border-color,box-shadow,transform] duration-500 ease-out hover:-translate-y-0.5 hover:border-accent-color/20 focus-visible:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent-color md:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.85fr)] motion-reduce:transform-none motion-reduce:transition-none"
          >
            <!-- Content -->
            <div class="order-2 flex min-w-0 flex-col p-8 sm:p-10 md:order-1 md:p-12 lg:p-14">
              <div class="flex items-center gap-3 font-sans text-[9px] font-bold uppercase tracking-[0.2em]">
                <span class="glass-pill inline-flex border border-text-color/10 px-3 py-1.5">
                  {proj.year}
                </span>
                <span class="opacity-35">
                  Project {String(i + 1).padStart(2, '0')}
                </span>
              </div>

              <h2 class="mt-9 font-serif text-4xl font-black tracking-tighter transition-colors duration-300 group-hover:text-accent-color group-focus-visible:text-accent-color sm:text-5xl md:mt-12 md:text-6xl">
                {proj.title}
              </h2>

              <p class="mt-5 max-w-2xl font-sans text-sm font-medium leading-relaxed tracking-tight text-text-color opacity-70 break-keep md:text-base">
                {proj.description}
              </p>

              <div class="mt-8 flex flex-wrap gap-2">
                {proj.tags.map(tag => (
                  <span class="glass-pill border border-text-color/20 px-3 py-1 font-sans text-[9px] font-bold uppercase tracking-widest opacity-70 shadow-sm shadow-black/5 transition-[border-color,opacity] duration-300 group-hover:border-accent-color/50 group-hover:opacity-100 group-focus-visible:border-accent-color/50 group-focus-visible:opacity-100 dark:shadow-white/5">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Project visual -->
            <div class="relative order-1 min-h-[240px] overflow-hidden border-b border-text-color/10 bg-black/5 md:order-2 md:min-h-full md:border-b-0 md:border-l dark:bg-white/5">
              <img
                src={proj.image}
                alt=""
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.025] group-focus-visible:scale-[1.025] motion-reduce:transform-none motion-reduce:transition-none"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-black/5"></div>
              <div class="absolute bottom-5 right-5 flex h-14 w-14 items-center justify-center rounded-full border border-white/35 bg-black/25 text-white shadow-[0_10px_30px_-12px_rgba(0,0,0,0.65)] backdrop-blur-md transition-[background-color,border-color,transform] duration-300 group-hover:-translate-y-0.5 group-hover:border-white/60 group-hover:bg-accent-color group-focus-visible:-translate-y-0.5 group-focus-visible:border-white/60 group-focus-visible:bg-accent-color motion-reduce:transform-none motion-reduce:transition-none">
                <span class="material-symbols-outlined text-2xl transition-transform duration-300 group-hover:-rotate-45 group-focus-visible:-rotate-45 motion-reduce:transform-none motion-reduce:transition-none">
                  arrow_forward
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>
  
  <script>
    document.addEventListener("astro:page-load", () => {
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          }
        });
      }, { root: null, rootMargin: "0px 0px -50px 0px", threshold: 0.1 });

      document.querySelectorAll(".reveal-up").forEach(el => revealObserver.observe(el));
    });
  </script>

</BaseLayout>

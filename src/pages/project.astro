    tags: ["React", "Zustand", "TailwindCSS"],
    url: "/project/ai-canvas-writer",
    year: "2026",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuD6TjGTWs53bAhDdSkfxKbZdM2TzdQI_ZJtmDiDK-bbOzPxxSssBUA9FGmSjTtwcgK7txfWRF9vt7TvbvgbPq1PuassGBT7NETRH7F8x-cNetH-9yuMvSaiweyZStMjrtnCbvCfhkcgQ8Kyf4uE9HpJkV3GYFlP7w4aCH8Yn3tshg_UDfWDNBnT5BEM4cw804ZWp6CEeh2apzFDSwCCB2W7VEJcZe43KkAhavwv3opq_ebTxM_VC5EKdLBDvyn4K0p49vYkMzWJkVnJ",
  },
  {
    title: "DevJournal CLI",
    description: "마크다운 포스트 작성 및 Vercel 환경 배포 시스템.",
    tags: ["Rust", "CLI", "Astro"],
    url: "/project/devjournal-cli",
    year: "2025",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuC5AEbqrNzQ1-SvYIJIWt1EuApIbBHl_HBblfMw96fDdkS7EzKHu6Zew16nnCG6WbwvC3aqDeHI0EFJeqB14NjzgjVvsEn67XJU_OV4uJscdG7XFLkIoYOclpv1m1ZPOgQLmeus5zT3nsjuPlZHEPgM298MUI-3mJiEwc_byTMWwtC93z0TzmIsh5nzbS8zndKZ_aGWJls6nfuWluG_lw7BqYVGhrj0lt521kef-xRmkyI83OhraLasbTeVB6f6BhrrLNwvuj8SjvMu",
  },
  {
    title: "Minimal System",
    description: "사내 공통 디자인 시스템 컴포넌트 프레임워크.",
    tags: ["Storybook", "Figma", "CSS"],
    url: "/project/minimal-system",
    year: "2024",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuC4eQMIkMBmHMy3whVOgSHFkBGYJ9Bcspd0PMXpnMrd2KLWPfT10Pbd5wWQ3W_-bRtrli8_P0ppaeAg_NZqzjWFAxixxlsgUYzpY98m81uCXn5c7sIAikTX7ioocJTKj9q0XPdEpQMU482kUmXh5zaDUW5GWUUcaHRsucLRWdzAepOgcw57JITm-UG49TI_cYso5dZR_hdhjWj2vogjS1-mnyOqLOu4elVXDrOKtj7gj6NU_eN_ykKRC-CtszyDvnJfT3zZqynw0Pst",

{
  "name": "devarchive-spring-ssr",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "gradlew.bat bootRun",
    "build:css": "tailwindcss -i ./src/main/resources/styles/global.css -o ./build/generated-resources/main/static/css/app.css --minify",
    "watch:css": "tailwindcss -i ./src/main/resources/styles/global.css -o ./build/generated-resources/main/static/css/app.css --watch",
    "docs:validate": "node scripts/validate-docs.mjs",
    "gradle:build": "gradlew.bat build",
    "build": "npm run gradle:build",
    "verify": "npm run docs:validate && npm run gradle:build"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "yaml": "^2.9.0"
  }
}
